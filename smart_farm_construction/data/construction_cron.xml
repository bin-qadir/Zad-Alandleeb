<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Daily AI Insight refresh for all construction projects -->
    <record id="cron_construction_ai_insights" model="ir.cron">
        <field name="name">Construction: Refresh AI Insights (Daily)</field>
        <field name="model_id" ref="smart_farm_construction.model_construction_ai_insight"/>
        <field name="state">code</field>
        <field name="code">model.run_daily_construction_insights()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
        <field name="priority">100</field>
    </record>

</odoo>
