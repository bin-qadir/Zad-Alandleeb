<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!--
    ══════════════════════════════════════════════════════════════════
    SMART FARM CONSTRUCTION — Clean Enterprise Menu
    ══════════════════════════════════════════════════════════════════

    Visible:
      1. Dashboard  — Construction Executive Dashboard
      2. Projects   — All construction projects (gateway to all sub-flows)
      3. Configuration — Divisions · Subdivisions (reference data)

    All operational flows (BOQ, Materials, Procurement, Execution,
    Inspection, Approval, Claims, Invoices) are accessed from inside
    the Project form via tabs — NOT from the top-level menu.
    ══════════════════════════════════════════════════════════════════
-->

<!-- ROOT APP MENU -->
<menuitem
    id="menu_sf_construction_root"
    name="Construction"
    sequence="110"
    web_icon="smart_farm_construction,static/description/icon.png"
/>

<!-- 1. Dashboard -->
<menuitem
    id="menu_sf_construction_dashboard"
    name="Dashboard"
    parent="menu_sf_construction_root"
    action="action_con_dashboard"
    sequence="10"
/>

<!-- 2. Projects -->
<menuitem
    id="menu_sf_construction_projects"
    name="Projects"
    parent="menu_sf_construction_root"
    action="action_con_projects"
    sequence="20"
/>

<!-- 3. Configuration (parent) -->
<menuitem
    id="menu_sf_construction_config"
    name="Configuration"
    parent="menu_sf_construction_root"
    sequence="90"
/>

<!-- 3a. Divisions (under Configuration) -->
<menuitem
    id="menu_sf_construction_divisions"
    name="Divisions"
    parent="menu_sf_construction_config"
    action="action_con_divisions"
    sequence="10"
/>

<!-- 3b. Subdivisions (under Configuration) -->
<menuitem
    id="menu_sf_construction_subdivisions"
    name="Subdivisions"
    parent="menu_sf_construction_config"
    action="action_con_subdivisions"
    sequence="20"
/>

<!--
    ══════════════════════════════════════════════════════════════════
    DEACTIVATED — operational menus moved inside Project form tabs
    Records preserved; menus hidden at DB level (active=False).
    ══════════════════════════════════════════════════════════════════
-->
<record id="menu_sf_construction_boq"         model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_material"    model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_procurement" model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_execution"   model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_inspection"  model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_approval"    model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_claims"      model="ir.ui.menu"><field name="active" eval="False"/></record>
<record id="menu_sf_construction_invoices"    model="ir.ui.menu"><field name="active" eval="False"/></record>

</data>
</odoo>
