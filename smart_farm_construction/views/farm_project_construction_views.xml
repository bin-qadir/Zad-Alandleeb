<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ╔══════════════════════════════════════════════════════════════════════╗
     ║  FARM PROJECT — Construction overlay                               ║
     ║  Adds:                                                             ║
     ║    1. Construction Phase field in the main info group             ║
     ║    2. Smart button strip: Material Requests, Procurement, POs     ║
     ║    3. Project Definition tabs: Buildings, Building Structure,     ║
     ║       Zones (construction-only, replaces generic text tabs)       ║
     ║    4. Operational notebook: Scope/BOQ, Tasks, Materials, etc.     ║
     ╚══════════════════════════════════════════════════════════════════════╝ -->

<record id="view_farm_project_construction_form_inherit" model="ir.ui.view">
    <field name="name">farm.project.construction.form.inherit</field>
    <field name="model">farm.project</field>
    <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
    <field name="arch" type="xml">

        <!-- ── 1. Inject Construction Phase into the main info group ──── -->
        <field name="lifecycle_stage_id" position="before">
            <field name="construction_phase"
                   widget="radio"
                   invisible="business_activity != 'construction'"
                   options="{'horizontal': true}"/>
        </field>

        <!-- ── STEP 1 (removed): project_type no longer in form view ────── -->
        <!--  Field was removed from the base form view directly.           -->

        <!-- ── STEP 2: Hide generic text-only base tabs for construction  -->
        <!--  Construction replaces them with structured data tabs below.  -->
        <xpath expr="//page[@name='tab_consists']" position="attributes">
            <attribute name="invisible">business_activity == 'construction'</attribute>
        </xpath>
        <xpath expr="//page[@name='tab_fields']" position="attributes">
            <attribute name="invisible">business_activity == 'construction'</attribute>
        </xpath>
        <xpath expr="//page[@name='tab_zones']" position="attributes">
            <attribute name="invisible">business_activity == 'construction'</attribute>
        </xpath>

        <!-- ── STEP 5: Hide generic Area tab for construction ─────────── -->
        <!--  Construction gets its own Area tab in the construction       -->
        <!--  notebook below, with computed buildings + zones totals.      -->
        <xpath expr="//page[@name='tab_area']" position="attributes">
            <attribute name="invisible">business_activity == 'construction'</attribute>
        </xpath>

        <!-- ── 2a. Smart buttons: PROCUREMENT group (Materials, Procurement, POs) ── -->
        <xpath expr="//div[@name='anchor_procurement_end']" position="before">

            <button name="action_open_material_requests" type="object"
                    class="epd-mini-kpi epd-mini-kpi--blue"
                    title="Open Material Requests"
                    invisible="business_activity != 'construction'">
                <i class="fa fa-truck epd-mini-icon" title="Material Requests"/>
                <div class="epd-mini-value">
                    <field name="material_request_count" nolabel="1"/>
                </div>
                <div class="epd-mini-label">Materials</div>
            </button>

            <button name="action_open_procurement" type="object"
                    class="epd-mini-kpi epd-mini-kpi--amber"
                    title="Open Procurement Documents"
                    invisible="business_activity != 'construction'">
                <i class="fa fa-shopping-cart epd-mini-icon" title="Procurement"/>
                <div class="epd-mini-value">
                    <field name="procurement_count" nolabel="1"/>
                </div>
                <div class="epd-mini-label">Procurement</div>
            </button>

            <button name="action_open_purchase_orders" type="object"
                    class="epd-mini-kpi epd-mini-kpi--green"
                    title="Open Purchase Orders"
                    invisible="business_activity != 'construction'">
                <i class="fa fa-file-text-o epd-mini-icon" title="Purchase Orders"/>
                <div class="epd-mini-value">
                    <field name="purchase_order_count" nolabel="1"/>
                </div>
                <div class="epd-mini-label">POs</div>
            </button>

        </xpath>

        <!-- ── 2b. Smart button: AI group (AI Risk) ──────────────────────── -->
        <xpath expr="//div[@name='anchor_ai_end']" position="before">

            <button name="action_open_ai_insights" type="object"
                    class="epd-mini-kpi epd-mini-kpi--red"
                    title="AI Risk Insights"
                    invisible="business_activity != 'construction' or not ai_status">
                <i class="fa fa-robot epd-mini-icon" title="AI Insights"/>
                <div class="epd-mini-value">
                    <field name="ai_risk_score" nolabel="1"
                           widget="float" options="{'digits':[16,0]}"/>%
                </div>
                <div class="epd-mini-label">AI Risk</div>
            </button>

        </xpath>

        <!-- ── 3. Construction Notebook ─────────────────────────────────── -->
        <xpath expr="//sheet/div[@name='main_action_buttons']" position="after">

            <notebook invisible="business_activity != 'construction'">

                <!-- ════════════════════════════════════════════════════════ -->
                <!--  PROJECT DEFINITION TABS  (Phase 1 — before BOQ)       -->
                <!-- ════════════════════════════════════════════════════════ -->

                <!-- ── Tab: Buildings ──────────────────────────────────── -->
                <page string="Buildings" name="tab_buildings">
                    <field name="building_ids" nolabel="1"
                           context="{'default_project_id': id}">
                        <list string="Buildings" editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name" placeholder="Building name…"/>
                            <field name="floor_count"      readonly="1" string="Floors"/>
                            <field name="total_floor_area"  readonly="1" string="Total Floor Area (m²)"/>
                            <field name="boq_count"         readonly="1" string="BOQs" optional="show"/>
                        </list>
                    </field>
                </page>

                <!-- ── Tab: Building Structure ─────────────────────────── -->
                <page string="Building Structure" name="tab_building_structure">
                    <p class="text-muted" style="font-size:13px; margin-bottom:12px">
                        <i class="fa fa-info-circle me-1"/>
                        Click a building row to open it and add / edit its floors.
                    </p>
                    <field name="building_ids" nolabel="1"
                           context="{'default_project_id': id}">
                        <list string="Building Structure">
                            <field name="sequence" widget="handle"/>
                            <field name="name" string="Building"/>
                            <field name="floor_count" readonly="1" string="Floors"/>
                            <field name="total_floor_area" readonly="1" string="Total Area (m²)"/>
                        </list>
                        <form string="Building Detail">
                            <group>
                                <field name="name" placeholder="Building name…"/>
                                <field name="sequence"/>
                            </group>
                            <separator string="Floors"/>
                            <field name="floor_ids" nolabel="1">
                                <list string="Floors" editable="bottom">
                                    <field name="floor_no" string="Level"
                                           help="-1 = Basement · 0 = Ground · 1 = First…"/>
                                    <field name="name" placeholder="e.g. Ground Floor, Mezzanine…"/>
                                    <field name="area" string="Area (m²)"/>
                                </list>
                            </field>
                            <separator string="BOQs (optional)"/>
                            <field name="boq_ids" nolabel="1"
                                   context="{'default_building_id': id, 'default_project_id': project_id}">
                                <list string="BOQs" editable="bottom">
                                    <field name="name"  readonly="1"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'submitted'"
                                           decoration-success="state == 'approved'"/>
                                    <field name="total" optional="show" string="Amount"/>
                                </list>
                            </field>
                        </form>
                    </field>
                </page>

                <!-- ── Tab: Zones ──────────────────────────────────────── -->
                <page string="Zones" name="tab_zones_construction">
                    <field name="zone_ids" nolabel="1"
                           context="{'default_project_id': id}">
                        <list string="Zones" editable="bottom">
                            <field name="name"      placeholder="Zone name…"/>
                            <field name="zone_type" string="Type"
                                   widget="badge"
                                   decoration-info="zone_type == 'residential'"
                                   decoration-success="zone_type == 'amenity'"
                                   decoration-warning="zone_type == 'commercial'"
                                   decoration-danger="zone_type == 'industrial'"/>
                            <field name="area"      string="Area (m²)"/>
                            <field name="boq_count" readonly="1" string="BOQs" optional="show"/>
                        </list>
                        <form string="Zone Detail">
                            <group>
                                <field name="name" placeholder="Zone name…"/>
                                <field name="zone_type"/>
                                <field name="area" string="Area (m²)"/>
                            </group>
                            <separator string="BOQs (optional)"/>
                            <field name="boq_ids" nolabel="1"
                                   context="{'default_zone_id': id, 'default_project_id': project_id}">
                                <list string="BOQs" editable="bottom">
                                    <field name="name"  readonly="1"/>
                                    <field name="state" widget="badge"
                                           decoration-info="state == 'draft'"
                                           decoration-warning="state == 'submitted'"
                                           decoration-success="state == 'approved'"/>
                                    <field name="total" optional="show" string="Amount"/>
                                </list>
                            </field>
                        </form>
                    </field>
                </page>

                <!-- ── Tab: Area Summary ───────────────────────────────── -->
                <page string="Area" name="tab_area_construction">
                    <group string="Area Summary">
                        <group string="Buildings">
                            <field name="total_building_area" readonly="1"
                                   string="Buildings Total (m²)"/>
                        </group>
                        <group string="Zones">
                            <field name="total_zone_area" readonly="1"
                                   string="Zones Total (m²)"/>
                        </group>
                    </group>
                    <group>
                        <group string="Grand Total">
                            <field name="construction_total_area" readonly="1"
                                   string="Total Project Area (m²)"/>
                        </group>
                    </group>
                    <div class="alert alert-info mt-2" style="font-size:13px"
                         invisible="construction_total_area > 0">
                        <i class="fa fa-info-circle me-1"/>
                        Add buildings with floors or zones above to compute area totals.
                    </div>
                </page>

                <!-- ════════════════════════════════════════════════════════ -->
                <!--  OPERATIONAL TABS  (keep untouched)                     -->
                <!-- ════════════════════════════════════════════════════════ -->

                <!-- ── Tab 1: Scope (BOQ) ──────────────────────────────── -->
                <page string="Scope (BOQ)" name="tab_boq">
                    <div class="mb-3 d-flex gap-2">
                        <button name="action_new_boq" type="object"
                                string="New BOQ"
                                class="btn btn-primary btn-sm"
                                icon="fa-plus"/>
                        <button name="action_open_boqs" type="object"
                                string="All BOQs"
                                class="btn btn-outline-secondary btn-sm"
                                icon="fa-list"
                                invisible="boq_count == 0"/>
                    </div>
                    <field name="boq_ids" nolabel="1"
                           mode="list"
                           context="{'default_project_id': id}">
                        <list string="Cost Structures">
                            <field name="name"/>
                            <field name="building_id" optional="hide" string="Building"/>
                            <field name="zone_id"     optional="hide" string="Zone"/>
                            <field name="date" string="Date" optional="show"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-warning="state == 'submitted'"
                                   decoration-success="state == 'approved'"
                                   optional="show"/>
                            <field name="total" string="BOQ Amount" optional="show"/>
                        </list>
                    </field>
                </page>

                <!-- ── Tab 2: Tasks ────────────────────────────────────── -->
                <page string="Tasks" name="tab_tasks">
                    <div class="mb-3 d-flex align-items-center gap-3">
                        <button name="action_open_tasks" type="object"
                                string="Open All Tasks"
                                class="btn btn-primary btn-sm"
                                icon="fa-external-link"
                                invisible="not odoo_project_id"/>
                        <span class="text-muted" style="font-size:13px"
                              invisible="odoo_project_id">
                            <i class="fa fa-info-circle me-1"/>
                            Tasks are managed via the linked Odoo Project.
                            Save this project first to auto-create the Odoo project link.
                        </span>
                        <span class="text-muted" style="font-size:13px"
                              invisible="not odoo_project_id">
                            <i class="fa fa-check-square-o me-1"/>
                            <field name="task_count" nolabel="1"/> task(s) in
                            <field name="odoo_project_id" nolabel="1" readonly="1"/>
                        </span>
                    </div>
                </page>

                <!-- ── Tab 3: Materials ────────────────────────────────── -->
                <page string="Materials" name="tab_materials">
                    <div class="mb-3">
                        <button name="action_open_material_requests" type="object"
                                string="New Request"
                                class="btn btn-primary btn-sm"
                                icon="fa-plus"/>
                    </div>
                    <field name="material_request_ids" nolabel="1"
                           mode="list"
                           context="{
                               'default_project_id': id,
                               'default_business_activity': 'construction'
                           }">
                        <list string="Material Requests">
                            <field name="name"/>
                            <field name="request_date" optional="show"/>
                            <field name="state" widget="badge"
                                   decoration-info="state == 'draft'"
                                   decoration-warning="state == 'to_approve'"
                                   decoration-success="state == 'approved'"
                                   decoration-danger="state == 'rejected'"
                                   optional="show"/>
                            <field name="total_estimated_cost" string="Est. Cost" optional="show"/>
                        </list>
                    </field>
                </page>

                <!-- ── Tab 4: Procurement ──────────────────────────────── -->
                <page string="Procurement" name="tab_procurement">
                    <div class="mb-3">
                        <button name="action_open_procurement" type="object"
                                string="Open Procurement"
                                class="btn btn-primary btn-sm"
                                icon="fa-external-link"/>
                        <span class="ms-3 text-muted" style="font-size:13px">
                            <field name="procurement_count" nolabel="1"/> BOQ analysis document(s)
                        </span>
                    </div>
                </page>

                <!-- ── Tab 5: Resources ────────────────────────────────── -->
                <page string="Resources" name="tab_resources">
                    <div class="p-4 text-center text-muted" style="font-size:13px">
                        <i class="fa fa-users fa-2x mb-3 d-block"/>
                        <strong>Resource Allocation</strong><br/>
                        Assign labour, equipment, and subcontractors to this project.<br/>
                        <span class="badge bg-warning text-dark mt-2">Coming Next Phase</span>
                    </div>
                </page>

                <!-- ── Tab 6: Execution ────────────────────────────────── -->
                <page string="Execution" name="tab_execution">
                    <div class="mb-3 d-flex gap-2">
                        <button name="action_open_job_orders" type="object"
                                string="All Job Orders"
                                class="btn btn-outline-secondary btn-sm"
                                icon="fa-list"
                                invisible="job_order_count == 0"/>
                        <button name="action_open_execution_jos" type="object"
                                string="Active Execution"
                                class="btn btn-primary btn-sm"
                                icon="fa-play"/>
                    </div>
                    <div class="row g-3 mb-3" invisible="job_order_count == 0">
                        <div class="col-md-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4 fw-bold text-success">
                                    <field name="execution_progress_pct" nolabel="1"
                                           widget="float" options="{'digits': [16,1]}"/>%
                                </div>
                                <div class="text-muted small">Progress</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4 fw-bold text-primary">
                                    <field name="jo_count_in_progress" nolabel="1"/>
                                </div>
                                <div class="text-muted small">In Progress</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4 fw-bold text-warning">
                                    <field name="jo_count_under_inspection" nolabel="1"/>
                                </div>
                                <div class="text-muted small">Under Inspection</div>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="border rounded p-3 text-center">
                                <div class="fs-4 fw-bold text-info">
                                    <field name="job_order_count" nolabel="1"/>
                                </div>
                                <div class="text-muted small">Total JOs</div>
                            </div>
                        </div>
                    </div>
                    <field name="job_order_ids" nolabel="1"
                           mode="list"
                           domain="[('jo_stage', 'in', ['approved', 'in_progress'])]">
                        <list string="Active Execution">
                            <field name="name"/>
                            <field name="department" widget="badge" optional="show"/>
                            <field name="jo_stage" widget="badge"
                                   decoration-info="jo_stage == 'approved'"
                                   decoration-success="jo_stage == 'in_progress'"/>
                            <field name="planned_qty" optional="show"/>
                            <field name="approved_qty" optional="show"/>
                            <field name="approved_amount" optional="show"/>
                            <field name="planned_end_date" optional="show"/>
                        </list>
                    </field>
                </page>

                <!-- ── Tab 7: Inspection ───────────────────────────────── -->
                <page string="Inspection" name="tab_inspection">
                    <div class="mb-3">
                        <button name="action_open_inspection_jos" type="object"
                                string="Open Inspection"
                                class="btn btn-primary btn-sm"
                                icon="fa-external-link"/>
                    </div>
                    <field name="job_order_ids" nolabel="1"
                           mode="list"
                           domain="[('jo_stage', 'in', ['handover_requested','under_inspection','partially_accepted','accepted'])]">
                        <list string="Inspection &amp; Approval">
                            <field name="name"/>
                            <field name="department" widget="badge" optional="show"/>
                            <field name="jo_stage" widget="badge"
                                   decoration-warning="jo_stage == 'handover_requested'"
                                   decoration-info="jo_stage == 'under_inspection'"
                                   decoration-success="jo_stage in ['partially_accepted','accepted']"/>
                            <field name="approved_qty" optional="show"/>
                            <field name="approved_amount" optional="show"/>
                            <field name="claimable_amount" optional="show"/>
                        </list>
                    </field>
                </page>

                <!-- ── Tab 8: Claims ───────────────────────────────────── -->
                <page string="Claims" name="tab_claims">
                    <div class="mb-3 d-flex align-items-center gap-3">
                        <button name="action_open_claims_jos" type="object"
                                string="Open Claims"
                                class="btn btn-primary btn-sm"
                                icon="fa-external-link"/>
                        <span class="text-muted" style="font-size:13px">
                            Ready to Claim:
                            <field name="jo_count_ready_for_claim" nolabel="1"/> JOs ·
                            Claimed:
                            <field name="jo_count_claimed" nolabel="1"/> JOs
                        </span>
                    </div>
                    <field name="job_order_ids" nolabel="1"
                           mode="list"
                           domain="[('jo_stage', 'in', ['ready_for_claim', 'claimed'])]">
                        <list string="Claims">
                            <field name="name"/>
                            <field name="department" widget="badge" optional="show"/>
                            <field name="jo_stage" widget="badge"
                                   decoration-warning="jo_stage == 'ready_for_claim'"
                                   decoration-success="jo_stage == 'claimed'"/>
                            <field name="claimable_amount" optional="show"/>
                            <field name="claim_amount" optional="show"/>
                        </list>
                    </field>
                </page>

                <!-- ── Tab 9: Financial ────────────────────────────────── -->
                <page string="Financial" name="tab_financial">
                    <group string="Financial Summary" col="2">
                        <group>
                            <field name="total_approved_amount" readonly="1"
                                   widget="float" options="{'digits': [16,2]}"/>
                            <field name="total_claimable_amount" readonly="1"
                                   widget="float" options="{'digits': [16,2]}"/>
                        </group>
                        <group>
                            <field name="total_claimed_amount" readonly="1"
                                   widget="float" options="{'digits': [16,2]}"/>
                            <field name="execution_progress_pct" readonly="1"
                                   widget="float" options="{'digits': [16,1]}"/>
                        </group>
                    </group>
                    <div class="mb-3 mt-2">
                        <button name="action_open_purchase_orders" type="object"
                                string="View Purchase Orders"
                                class="btn btn-outline-secondary btn-sm"
                                icon="fa-file-text-o"/>
                    </div>
                </page>

                <!-- ── Tab 10: AI Insights ─────────────────────────────── -->
                <page string="AI Insights" name="tab_ai_insights">

                    <!-- Action buttons -->
                    <div class="mb-3 d-flex gap-2 align-items-center">
                        <button name="action_recompute_ai_insight" type="object"
                                string="Recompute AI"
                                class="btn btn-primary btn-sm"
                                icon="fa-refresh"/>
                        <button name="action_open_ai_insights" type="object"
                                string="View All Insights"
                                class="btn btn-outline-secondary btn-sm"
                                icon="fa-list"/>
                    </div>

                    <!-- Latest Insight Summary Panel -->
                    <div invisible="not latest_ai_insight_id">

                        <!-- Status banner -->
                        <div class="alert alert-danger mb-3 d-flex align-items-center gap-3"
                             invisible="ai_status != 'critical'">
                            <i class="fa fa-exclamation-circle fa-2x"/>
                            <div>
                                <strong>CRITICAL RISK</strong> — Immediate action required.
                                AI Risk Score: <field name="ai_risk_score" nolabel="1" readonly="1"
                                                      widget="float" options="{'digits':[16,1]}"/>%
                            </div>
                        </div>
                        <div class="alert alert-warning mb-3 d-flex align-items-center gap-3"
                             invisible="ai_status != 'warning'">
                            <i class="fa fa-exclamation-triangle fa-2x"/>
                            <div>
                                <strong>WARNING</strong> — Monitor closely.
                                AI Risk Score: <field name="ai_risk_score" nolabel="1" readonly="1"
                                                      widget="float" options="{'digits':[16,1]}"/>%
                            </div>
                        </div>
                        <div class="alert alert-success mb-3 d-flex align-items-center gap-3"
                             invisible="ai_status != 'healthy'">
                            <i class="fa fa-check-circle fa-2x"/>
                            <div>
                                <strong>HEALTHY</strong> — All indicators normal.
                                AI Risk Score: <field name="ai_risk_score" nolabel="1" readonly="1"
                                                      widget="float" options="{'digits':[16,1]}"/>%
                            </div>
                        </div>

                        <!-- Risk score breakdown -->
                        <group string="Risk Score Breakdown (0 = none · 100 = maximum)" col="2">
                            <group>
                                <field name="ai_risk_score" string="Overall Risk Score"
                                       widget="float" options="{'digits':[16,1]}" readonly="1"/>
                                <field name="latest_ai_insight_id" string="Latest Insight"
                                       readonly="1"/>
                            </group>
                            <group>
                                <field name="ai_status" string="AI Status"
                                       widget="badge"
                                       decoration-danger="ai_status == 'critical'"
                                       decoration-warning="ai_status == 'warning'"
                                       decoration-success="ai_status == 'healthy'"
                                       readonly="1"/>
                            </group>
                        </group>

                        <!-- AI narrative -->
                        <group string="AI Recommendation" col="1">
                            <field name="ai_recommendation" nolabel="1" readonly="1" colspan="2"/>
                        </group>

                    </div>

                    <!-- No insight yet -->
                    <div class="p-4 text-center text-muted" invisible="latest_ai_insight_id"
                         style="font-size:13px">
                        <i class="fa fa-robot fa-2x mb-3 d-block"/>
                        <strong>No AI Insight yet</strong><br/>
                        Click <em>Recompute AI</em> to generate the first insight for this project.
                    </div>

                    <!-- History list -->
                    <div invisible="not latest_ai_insight_id">
                        <field name="ai_insight_ids" nolabel="1"
                               mode="list"
                               context="{'default_project_id': id}"
                               readonly="1">
                            <list string="AI Insight History"
                                  decoration-danger="status == 'critical'"
                                  decoration-warning="status == 'warning'"
                                  decoration-success="status == 'healthy'">
                                <field name="date_generated" string="Date"/>
                                <field name="risk_score" string="Risk %" optional="show"/>
                                <field name="status" widget="badge"
                                       decoration-danger="status == 'critical'"
                                       decoration-warning="status == 'warning'"
                                       decoration-success="status == 'healthy'"/>
                                <field name="delay_score"       string="Delay"       optional="show"/>
                                <field name="procurement_risk"  string="Procurement" optional="show"/>
                                <field name="execution_risk"    string="Execution"   optional="show"/>
                                <field name="claim_risk"        string="Claims"      optional="show"/>
                                <field name="cost_risk"         string="Cost"        optional="show"/>
                                <field name="state" widget="badge"
                                       decoration-info="state == 'open'"
                                       decoration-warning="state == 'acknowledged'"
                                       decoration-success="state == 'resolved'"
                                       optional="show"/>
                                <button name="action_acknowledge" type="object"
                                        string="Acknowledge" icon="fa-check"
                                        invisible="state != 'open'"/>
                                <button name="action_resolve" type="object"
                                        string="Resolve" icon="fa-check-circle"
                                        invisible="state == 'resolved'"/>
                            </list>
                        </field>
                    </div>

                </page>

            </notebook>
        </xpath>

    </field>
</record>

</data>
</odoo>
