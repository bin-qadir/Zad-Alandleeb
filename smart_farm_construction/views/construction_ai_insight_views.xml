<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ╔══════════════════════════════════════════════════════════════════════╗
     ║  CONSTRUCTION AI INSIGHT — List + Form Views                       ║
     ╚══════════════════════════════════════════════════════════════════════╝ -->

<!-- List view -->
<record id="view_construction_ai_insight_list" model="ir.ui.view">
    <field name="name">construction.ai.insight.list</field>
    <field name="model">construction.ai.insight</field>
    <field name="arch" type="xml">
        <list string="AI Insights"
              decoration-danger="status == 'critical'"
              decoration-warning="status == 'warning'"
              decoration-success="status == 'healthy'">
            <field name="project_id"/>
            <field name="date_generated"/>
            <field name="risk_score" string="Risk %"/>
            <field name="status" widget="badge"
                   decoration-danger="status == 'critical'"
                   decoration-warning="status == 'warning'"
                   decoration-success="status == 'healthy'"/>
            <field name="delay_score"       string="Delay"   optional="show"/>
            <field name="procurement_risk"  string="Procurement" optional="show"/>
            <field name="execution_risk"    string="Execution" optional="show"/>
            <field name="claim_risk"        string="Claims"  optional="show"/>
            <field name="cost_risk"         string="Cost"    optional="show"/>
            <field name="state" widget="badge"
                   decoration-info="state == 'open'"
                   decoration-warning="state == 'acknowledged'"
                   decoration-success="state == 'resolved'"
                   optional="show"/>
            <field name="responsible_id"    optional="show"/>
            <button name="action_acknowledge" type="object"
                    string="Acknowledge" icon="fa-check"
                    invisible="state != 'open'"/>
            <button name="action_resolve" type="object"
                    string="Resolve" icon="fa-check-circle"
                    invisible="state == 'resolved'"/>
        </list>
    </field>
</record>

<!-- Form view -->
<record id="view_construction_ai_insight_form" model="ir.ui.view">
    <field name="name">construction.ai.insight.form</field>
    <field name="model">construction.ai.insight</field>
    <field name="arch" type="xml">
        <form string="AI Insight">
            <header>
                <button name="action_acknowledge" type="object"
                        string="Acknowledge"
                        class="btn-primary"
                        invisible="state != 'open'"/>
                <button name="action_resolve" type="object"
                        string="Mark Resolved"
                        class="btn-primary"
                        invisible="state == 'resolved'"/>
                <button name="action_recompute" type="object"
                        string="Recompute AI"
                        class="btn-secondary"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="open,acknowledged,resolved"/>
            </header>
            <sheet>
                <!-- Status banner -->
                <div class="alert mb-3 d-flex align-items-center gap-3"
                     style="border-radius:8px;"
                     invisible="status != 'critical'">
                    <i class="fa fa-exclamation-circle fa-2x text-danger"/>
                    <div>
                        <strong class="text-danger">CRITICAL RISK</strong> — Immediate action required.
                        Score: <field name="risk_score" nolabel="1" readonly="1" widget="float" options="{'digits':[16,1]}"/>%
                    </div>
                </div>
                <div class="alert alert-warning mb-3 d-flex align-items-center gap-3"
                     invisible="status != 'warning'">
                    <i class="fa fa-exclamation-triangle fa-2x"/>
                    <div>
                        <strong>WARNING</strong> — Monitor closely.
                        Score: <field name="risk_score" nolabel="1" readonly="1" widget="float" options="{'digits':[16,1]}"/>%
                    </div>
                </div>
                <div class="alert alert-success mb-3 d-flex align-items-center gap-3"
                     invisible="status != 'healthy'">
                    <i class="fa fa-check-circle fa-2x"/>
                    <div>
                        <strong>HEALTHY</strong> — All indicators normal.
                        Score: <field name="risk_score" nolabel="1" readonly="1" widget="float" options="{'digits':[16,1]}"/>%
                    </div>
                </div>

                <div class="oe_title">
                    <h1><field name="name" readonly="1"/></h1>
                </div>

                <group col="2">
                    <group string="Identity">
                        <field name="project_id" readonly="1"/>
                        <field name="business_activity" readonly="1"/>
                        <field name="date_generated" readonly="1"/>
                    </group>
                    <group string="Workflow">
                        <field name="responsible_id"/>
                        <field name="acknowledged_by" readonly="1" invisible="state == 'open'"/>
                        <field name="acknowledged_date" readonly="1" invisible="state == 'open'"/>
                        <field name="resolved_by" readonly="1" invisible="state != 'resolved'"/>
                        <field name="resolved_date" readonly="1" invisible="state != 'resolved'"/>
                    </group>
                </group>

                <!-- Risk Score Breakdown -->
                <group string="Risk Scores (0 = none, 100 = maximum)">
                    <group>
                        <field name="risk_score"       widget="float" options="{'digits':[16,1]}" readonly="1"/>
                        <field name="delay_score"      widget="float" options="{'digits':[16,1]}" readonly="1"/>
                        <field name="execution_risk"   widget="float" options="{'digits':[16,1]}" readonly="1"/>
                    </group>
                    <group>
                        <field name="procurement_risk" widget="float" options="{'digits':[16,1]}" readonly="1"/>
                        <field name="cost_risk"        widget="float" options="{'digits':[16,1]}" readonly="1"/>
                        <field name="claim_risk"       widget="float" options="{'digits':[16,1]}" readonly="1"/>
                    </group>
                </group>

                <group string="AI Analysis">
                    <field name="reason"             readonly="1" nolabel="1" colspan="2"/>
                </group>

                <group string="Recommended Actions">
                    <field name="recommended_action" readonly="1" nolabel="1" colspan="2"/>
                </group>

            </sheet>
        </form>
    </field>
</record>

<!-- Window action -->
<record id="action_construction_ai_insights" model="ir.actions.act_window">
    <field name="name">AI Insights</field>
    <field name="res_model">construction.ai.insight</field>
    <field name="view_mode">list,form</field>
    <field name="domain">[('business_activity','=','construction')]</field>
    <field name="context">{'default_business_activity': 'construction'}</field>
</record>

</data>
</odoo>
