<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- ============================================================
             Module Category
        ============================================================ -->
        <record id="module_category_smart_farm" model="ir.module.category">
            <field name="name">Smart Farm</field>
            <field name="description">Smart Farm Al Andleeb Management</field>
            <field name="sequence">50</field>
        </record>

        <!-- ============================================================
             Groups
        ============================================================ -->

        <!-- Farm User -->
        <record id="group_farm_user" model="res.groups">
            <field name="name">Farm User</field>
            <field name="category_id" ref="module_category_smart_farm"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view farm records and create basic entries.</field>
        </record>

        <!-- Farm Manager -->
        <record id="group_farm_manager" model="res.groups">
            <field name="name">Farm Manager</field>
            <field name="category_id" ref="module_category_smart_farm"/>
            <field name="implied_ids" eval="[(4, ref('group_farm_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Full access to all farm records including configuration.</field>
        </record>

        <!-- Farm Administrator -->
        <record id="group_farm_admin" model="res.groups">
            <field name="name">Farm Administrator</field>
            <field name="category_id" ref="module_category_smart_farm"/>
            <field name="implied_ids" eval="[(4, ref('group_farm_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">System configuration and advanced settings.</field>
        </record>
    </data>
</odoo>
