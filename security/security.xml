<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="group_boq_user" model="res.groups">
        <field name="name">BOQ User</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_boq_manager" model="res.groups">
        <field name="name">BOQ Manager</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[
            (4, ref('task_boq_advanced.group_boq_user')),
            (4, ref('project.group_project_manager'))
        ]"/>
    </record>

    <record id="group_ai_controller_manager" model="res.groups">
        <field name="name">AI Controller Manager</field>
        <field name="category_id" ref="base.module_category_project_management"/>
        <field name="implied_ids" eval="[(4, ref('task_boq_advanced.group_boq_manager'))]"/>
    </record>

    <record id="rule_task_boq_line_user_simple" model="ir.rule">
        <field name="name">BOQ Line - User Assigned or Created</field>
        <field name="model_id" ref="model_task_boq_line"/>
        <field name="groups" eval="[(4, ref('task_boq_advanced.group_boq_user'))]"/>
        <field name="domain_force">
            ['|',
                ('task_id.user_ids', 'in', [user.id]),
                ('create_uid', '=', user.id)
            ]
        </field>
    </record>

    <record id="rule_task_boq_resource_line_user_simple" model="ir.rule">
        <field name="name">BOQ Resource Line - User Assigned or Created</field>
        <field name="model_id" ref="model_task_boq_resource_line"/>
        <field name="groups" eval="[(4, ref('task_boq_advanced.group_boq_user'))]"/>
        <field name="domain_force">
            ['|',
                ('boq_line_id.task_id.user_ids', 'in', [user.id]),
                ('create_uid', '=', user.id)
            ]
        </field>
    </record>

    <record id="rule_task_ai_alert_user_simple" model="ir.rule">
        <field name="name">AI Alert - User Assigned or Created</field>
        <field name="model_id" ref="model_task_ai_alert"/>
        <field name="groups" eval="[(4, ref('task_boq_advanced.group_boq_user'))]"/>
        <field name="domain_force">
            ['|','|',
                ('task_id.user_ids', 'in', [user.id]),
                ('assigned_user_id', '=', user.id),
                ('create_uid', '=', user.id)
            ]
        </field>
    </record>

    <record id="rule_task_boq_line_manager_all" model="ir.rule">
        <field name="name">BOQ Line - Manager All</field>
        <field name="model_id" ref="model_task_boq_line"/>
        <field name="groups" eval="[(4, ref('task_boq_advanced.group_boq_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_task_boq_resource_line_manager_all" model="ir.rule">
        <field name="name">BOQ Resource Line - Manager All</field>
        <field name="model_id" ref="model_task_boq_resource_line"/>
        <field name="groups" eval="[(4, ref('task_boq_advanced.group_boq_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="rule_task_ai_alert_manager_all" model="ir.rule">
        <field name="name">AI Alert - AI Controller Manager All</field>
        <field name="model_id" ref="model_task_ai_alert"/>
        <field name="groups" eval="[(4, ref('task_boq_advanced.group_ai_controller_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

</odoo>
