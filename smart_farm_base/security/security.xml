<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Lavandula category -->
        <record id="module_category_smart_farm" model="ir.module.category">
            <field name="name">Lavandula</field>
            <field name="sequence">100</field>
        </record>

        <!-- Smart Farm User group -->
        <record id="group_smart_farm_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_smart_farm"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Smart Farm Manager group -->
        <record id="group_smart_farm_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_smart_farm"/>
            <field name="implied_ids" eval="[(4, ref('group_smart_farm_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
