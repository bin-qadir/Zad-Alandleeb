<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Extend the Farm Project form with:
            1. Sales Orders stat button (inserted after BOQ Analysis button)
            2. Cost Control tab with Estimated / Contract / Actual / Variance
        -->

        <record id="view_farm_project_sale_contract_inherit" model="ir.ui.view">
            <field name="name">farm.project.sale.contract.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">

                <!-- ── 1. Sales Orders — card IS the button (after BOQ Analysis) ── -->
                <xpath expr="//div[@name='btn_boq_analysis']" position="after">
                    <button name="action_open_sale_orders" type="object"
                            class="epd-mini-kpi epd-mini-kpi--indigo"
                            title="Open Sales Orders">
                        <i class="fa fa-file-text epd-mini-icon" title="Sales Orders"/>
                        <div class="epd-mini-value">
                            <field name="sale_order_count" nolabel="1"/>
                        </div>
                        <div class="epd-mini-label">Sales Orders</div>
                    </button>
                </xpath>

                <!-- ── 2. Cost Control tab ── -->
                <xpath expr="//notebook" position="inside">
                    <page string="Cost Control" name="tab_cost_control" icon="fa-usd">
                        <group>
                            <group string="Budget Summary">
                                <field name="estimated_cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="contract_value"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </group>
                            <group string="Actual Costs">
                                <field name="actual_material_cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="actual_labour_cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="actual_total_cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </group>
                        <group>
                            <group string="Variance">
                                <field name="cost_variance"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       decoration-danger="cost_variance &gt; 0"
                                       decoration-success="cost_variance &lt;= 0 and actual_total_cost &gt; 0"
                                       decoration-muted="actual_total_cost == 0"/>
                            </group>
                        </group>
                    </page>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
