<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Extend the Job Order form and list with:
            1. Tasks stat button (task_count)
            2. Sales Order / Contract Line fields in the General tab
        -->

        <record id="view_farm_job_order_sale_contract_inherit" model="ir.ui.view">
            <field name="name">farm.job.order.sale.contract.inherit</field>
            <field name="model">farm.job.order</field>
            <field name="inherit_id" ref="smart_farm_execution.view_farm_job_order_form"/>
            <field name="arch" type="xml">

                <!-- ── 1. Tasks stat button ── -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button class="oe_stat_button"
                            type="object"
                            name="action_view_tasks"
                            icon="fa-check-square-o"
                            invisible="task_count == 0">
                        <field name="task_count"
                               widget="statinfo"
                               string="Tasks"/>
                    </button>
                </xpath>

                <!-- ── 2. Sales Order + Contract Line after contract_id ── -->
                <xpath expr="//field[@name='contract_id']" position="after">
                    <field name="sale_order_id"
                           options="{'no_create': True}"
                           readonly="state not in ('draft', 'ready')"/>
                    <field name="sale_order_line_id"
                           options="{'no_create': True}"
                           readonly="1"
                           domain="[('order_id', '=', sale_order_id)]"/>
                </xpath>

            </field>
        </record>

        <!--
            Extend the Job Order list with optional SO column.
        -->

        <record id="view_farm_job_order_sale_contract_list_inherit" model="ir.ui.view">
            <field name="name">farm.job.order.sale.contract.list.inherit</field>
            <field name="model">farm.job.order</field>
            <field name="inherit_id" ref="smart_farm_execution.view_farm_job_order_list"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='contract_id']" position="after">
                    <field name="sale_order_id" string="Sales Order" optional="show"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
