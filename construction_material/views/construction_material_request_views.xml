<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Request List ──────────────────────────────────────────────────── -->

    <record id="view_construction_material_request_list" model="ir.ui.view">
        <field name="name">construction.material.request.list</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <list string="Material Requests"
                  decoration-muted="state == 'rejected'"
                  decoration-info="state == 'draft'"
                  decoration-warning="state == 'submitted'"
                  decoration-success="state == 'approved'"
                  decoration-primary="state == 'converted_to_procurement'">
                <field name="name"/>
                <field name="project_id"/>
                <field name="division_id" optional="show"/>
                <field name="requested_by" optional="show"/>
                <field name="request_date"/>
                <field name="line_count" string="Lines"/>
                <field name="shortage_line_count" string="Shortages"
                       decoration-danger="shortage_line_count > 0"
                       optional="show"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'submitted'"
                       decoration-success="state == 'approved'"
                       decoration-danger="state == 'rejected'"
                       decoration-primary="state == 'converted_to_procurement'"/>
            </list>
        </field>
    </record>

    <!-- ─── Request Form ──────────────────────────────────────────────────── -->

    <record id="view_construction_material_request_form" model="ir.ui.view">
        <field name="name">construction.material.request.form</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <form string="Material Request">

                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'submitted'"/>
                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_convert_to_procurement"
                            string="Convert to Procurement"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approved'"/>
                    <button name="action_reset_draft"
                            string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected',)"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,approved,converted_to_procurement"/>
                </header>

                <sheet>

                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_material_plans"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-list-ul">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Material Plans</span>
                            </div>
                        </button>
                        <button class="oe_stat_button"
                                icon="fa-exclamation-triangle"
                                type="object"
                                name="action_open_material_plans"
                                invisible="shortage_line_count == 0">
                            <field name="shortage_line_count"
                                   widget="statinfo"
                                   string="Shortages"/>
                        </button>
                    </div>

                    <!-- Title -->
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Header fields -->
                    <group>
                        <group string="Request Info">
                            <field name="project_id"
                                   readonly="state != 'draft'"/>
                            <field name="division_id"
                                   readonly="state != 'draft'"/>
                            <field name="subdivision_id"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Requestor">
                            <field name="requested_by"/>
                            <field name="request_date"/>
                        </group>
                    </group>

                    <notebook>

                        <!-- ── Tab 1: Request Lines ──────────────────────── -->
                        <page string="Request Lines" name="lines">
                            <field name="line_ids"
                                   readonly="state not in ('draft', 'submitted')">
                                <list editable="bottom"
                                      decoration-danger="shortage_qty > 0"
                                      open_form_view="True">
                                    <field name="sequence" widget="handle"/>
                                    <field name="material_plan_id" optional="show"/>
                                    <field name="boq_line_id" optional="show"/>
                                    <field name="product_id"/>
                                    <field name="description" optional="show"/>
                                    <field name="unit" optional="show"/>
                                    <field name="requested_qty"/>
                                    <field name="available_qty" readonly="1"/>
                                    <field name="shortage_qty" readonly="1"/>
                                    <field name="remarks" optional="show"/>
                                </list>
                            </field>

                            <!-- Summary footer -->
                            <group class="mt-3">
                                <group>
                                    <field name="line_count"
                                           string="Total Lines"
                                           readonly="1"/>
                                    <field name="total_requested"
                                           string="Total Qty Requested"
                                           readonly="1"/>
                                </group>
                                <group>
                                    <field name="shortage_line_count"
                                           string="Lines with Shortage"
                                           readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <!-- ── Tab 2: Notes ──────────────────────────────── -->
                        <page string="Notes" name="notes">
                            <field name="notes"
                                   placeholder="Add request notes, scope clarifications, urgency…"/>
                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <!-- ─── Request Search ────────────────────────────────────────────────── -->

    <record id="view_construction_material_request_search" model="ir.ui.view">
        <field name="name">construction.material.request.search</field>
        <field name="model">construction.material.request</field>
        <field name="arch" type="xml">
            <search string="Search Material Requests">
                <field name="name"/>
                <field name="project_id"/>
                <field name="division_id"/>
                <field name="requested_by"/>
                <separator/>
                <filter name="state_draft"
                        string="Draft"
                        domain="[('state','=','draft')]"/>
                <filter name="state_submitted"
                        string="Submitted"
                        domain="[('state','=','submitted')]"/>
                <filter name="state_approved"
                        string="Approved"
                        domain="[('state','=','approved')]"/>
                <filter name="state_converted"
                        string="Converted to Procurement"
                        domain="[('state','=','converted_to_procurement')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_project"
                            string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_division"
                            string="Division"
                            context="{'group_by': 'division_id'}"/>
                    <filter name="group_state"
                            string="Status"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_date"
                            string="Date"
                            context="{'group_by': 'request_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Action ────────────────────────────────────────────────────────── -->

    <record id="action_construction_material_request" model="ir.actions.act_window">
        <field name="name">Material Requests</field>
        <field name="res_model">construction.material.request</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id"
               ref="view_construction_material_request_search"/>
        <field name="context">{'search_default_state_draft': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No material requests yet.
            </p>
            <p>
                Generate material requests from material plan lines or BOQ lines
                to track procurement needs.
            </p>
        </field>
    </record>

</odoo>
