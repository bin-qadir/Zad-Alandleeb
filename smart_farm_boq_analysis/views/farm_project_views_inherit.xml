<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            BOQ Analysis stat button — injected into the Farm Project button_box.
            Opens all Analysis documents for this project (filtered by project_id).
        -->
        <record id="view_farm_project_form_analysis_inherit" model="ir.ui.view">
            <field name="name">farm.project.form.analysis.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">

                <!-- BOQ Analysis — card IS the button.
                     The outer div carries name="btn_boq_analysis" as an xpath anchor
                     for smart_farm_sale_contract (which inserts Sales Orders after it).
                     class="epd-kpi-anchor" → display:contents, so the div is invisible
                     to the flex layout and the inner button is a direct flex item. -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <div name="btn_boq_analysis" class="epd-kpi-anchor">
                        <button name="action_open_project_analysis" type="object"
                                class="epd-mini-kpi epd-mini-kpi--purple"
                                title="Open BOQ Analysis">
                            <i class="fa fa-bar-chart epd-mini-icon" title="BOQ Analysis"/>
                            <div class="epd-mini-value">
                                <field name="analysis_count" nolabel="1"/>
                            </div>
                            <div class="epd-mini-label">BOQ Analysis</div>
                        </button>
                    </div>
                </xpath>

            </field>
        </record>
    </data>
</odoo>
