<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="module_category_livestock" model="ir.module.category">
            <field name="name">Livestock</field>
            <field name="description">Lavandula — Livestock operational module.</field>
            <field name="sequence">80</field>
        </record>

        <record id="group_livestock_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_livestock"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_livestock_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_livestock"/>
            <field name="implied_ids" eval="[(4, ref('group_livestock_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
