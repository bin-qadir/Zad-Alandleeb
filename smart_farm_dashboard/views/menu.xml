<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            SMART FARM DASHBOARD — Executive Menu Hub
            ==========================================

            "Executive Dashboard" becomes a parent menu with two children:
              1. Portfolio Overview  — the singleton form (existing PMO cockpit)
              2. Analytics           — the new Owl chart dashboard
        -->

        <!-- Parent hub (no action — container only) -->
        <menuitem
            id="menu_executive_hub"
            name="Executive Dashboard"
            parent="smart_farm_base.menu_smart_farm_root"
            sequence="5"
        />

        <!-- 1 — Portfolio Overview (existing executive cockpit) -->
        <menuitem
            id="menu_farm_dashboard"
            name="Portfolio Overview"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_farm_dashboard_server"
            sequence="10"
        />

        <!-- 2 — Analytics Dashboard (new Owl + Chart.js dashboard) -->
        <menuitem
            id="menu_farm_analytics"
            name="Analytics"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_smart_farm_analytics"
            sequence="20"
        />

        <!-- ── Activity Dashboards separator ── -->

        <!-- 3 — Construction Projects Portfolio Dashboard (Level 1+2) -->
        <menuitem
            id="menu_farm_dashboard_construction"
            name="Construction"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_construction_projects_dashboard"
            sequence="30"
        />

        <!-- 3a — Construction Execution Dashboard (activity-level, all JOs) — kept for direct access, deactivated below -->
        <menuitem
            id="menu_farm_dashboard_construction_execution"
            name="Construction Execution"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_construction_dashboard"
            sequence="32"
        />

        <!-- 3b — Civil Division Dashboard (under Construction) — kept for direct access, deactivated below -->
        <menuitem
            id="menu_farm_dashboard_civil"
            name="Civil Division"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_civil_dashboard"
            sequence="35"
        />

        <!-- 4 — Agriculture Dashboard -->
        <menuitem
            id="menu_farm_dashboard_agriculture"
            name="Agriculture"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_agriculture_dashboard"
            sequence="40"
        />

        <!-- 5 — Manufacturing Dashboard -->
        <menuitem
            id="menu_farm_dashboard_manufacturing"
            name="Manufacturing"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_manufacturing_dashboard"
            sequence="50"
        />

        <!-- 6 — Livestock Dashboard -->
        <menuitem
            id="menu_farm_dashboard_livestock"
            name="Livestock"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_livestock_dashboard"
            sequence="60"
        />

        <!-- ══ Hard-deactivate menus that must never appear in the dropdown ══
             active=False is enforced at DB level and is not group-dependent.
             The action records and views are preserved for programmatic access. -->

        <!-- Deactivate execution/civil sub-menus (already done) -->
        <record id="menu_farm_dashboard_construction_execution" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>
        <record id="menu_farm_dashboard_civil" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <!--
            Agriculture / Manufacturing / Livestock dashboards are now enabled.
            All four activity dashboards are accessible under Executive Dashboard.
        -->

    </data>
</odoo>
