<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            SMART FARM DASHBOARD — Executive Menu Hub
            ==========================================

            "Executive Dashboard" becomes a parent menu with two children:
              1. Portfolio Overview  — the singleton form (existing PMO cockpit)
              2. Analytics           — the new Owl chart dashboard
        -->

        <!-- Parent hub (no action — container only) -->
        <menuitem
            id="menu_executive_hub"
            name="Executive Dashboard"
            parent="smart_farm_base.menu_smart_farm_root"
            sequence="5"
        />

        <!-- 1 — Portfolio Overview (existing executive cockpit) -->
        <menuitem
            id="menu_farm_dashboard"
            name="Portfolio Overview"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_farm_dashboard_server"
            sequence="10"
        />

        <!-- 2 — Analytics Dashboard (new Owl + Chart.js dashboard) -->
        <menuitem
            id="menu_farm_analytics"
            name="Analytics"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_smart_farm_analytics"
            sequence="20"
        />

        <!-- ── Activity Dashboards separator ── -->

        <!-- 3 — Construction Dashboard -->
        <menuitem
            id="menu_farm_dashboard_construction"
            name="Construction"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_construction_dashboard"
            sequence="30"
        />

        <!-- 4 — Agriculture Dashboard -->
        <menuitem
            id="menu_farm_dashboard_agriculture"
            name="Agriculture"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_agriculture_dashboard"
            sequence="40"
        />

        <!-- 5 — Manufacturing Dashboard -->
        <menuitem
            id="menu_farm_dashboard_manufacturing"
            name="Manufacturing"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_manufacturing_dashboard"
            sequence="50"
        />

        <!-- 6 — Livestock Dashboard -->
        <menuitem
            id="menu_farm_dashboard_livestock"
            name="Livestock"
            parent="smart_farm_dashboard.menu_executive_hub"
            action="smart_farm_dashboard.action_open_livestock_dashboard"
            sequence="60"
        />

    </data>
</odoo>
