<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ════════════════════════════════════════════════════════════════════════
     CIVIL DIVISION DASHBOARD — farm.civil.dashboard
     Priority-based visual hierarchy — 4 rows per card:
       ROW 1 PRIMARY   Contract | Executed | Remaining  (largest)
       ROW 2 FINANCIAL Approved | Claimed  | Invoiced   (medium)
       ROW 3 PROCESS   In Progress | Inspection | Handover | Not Started (compact)
       ROW 4 VARIATION Variation — Approved minus Contract (full-width, red)
     ════════════════════════════════════════════════════════════════════════ -->

<record id="view_farm_civil_dashboard_form" model="ir.ui.view">
    <field name="name">farm.civil.dashboard.form</field>
    <field name="model">farm.civil.dashboard</field>
    <field name="arch" type="xml">
        <form string="Civil Dashboard" create="0" delete="0" edit="0">
            <sheet>

                <!-- ── Project context banner (shown only when project_id is set) ── -->
                <div class="civil-project-ctx" invisible="not project_id">
                    <button name="action_back_to_project" type="object"
                            class="civil-project-ctx__back" title="Back to Project Dashboard">
                        <i class="fa fa-arrow-left me-1"/>Back
                    </button>
                    <i class="fa fa-filter me-2"/>
                    Filtered to project:
                    <strong>
                        <field name="project_id" readonly="1" nolabel="1"
                               options="{'no_open': True}"/>
                    </strong>
                </div>

                <!-- ── Header banner ──────────────────────────────────────── -->
                <div class="civil-dash-header">
                    <div class="civil-dash-header__left">
                        <i class="fa fa-building civil-dash-header__icon"/>
                        <div>
                            <div class="civil-dash-header__title">Civil Division</div>
                            <div class="civil-dash-header__sub">Construction — Site Works &amp; Civil Structures</div>
                        </div>
                    </div>
                    <div class="civil-dash-header__kpi">
                        <button name="action_view_all_civil" type="object"
                                class="sf-card-btn--light" title="View All Civil JOs"/>
                        <div class="civil-dash-header__kpi-num">
                            <field name="total_civil_jos" readonly="1"/>
                        </div>
                        <div class="civil-dash-header__kpi-lbl">Total Civil Job Orders</div>
                    </div>
                </div>

                <!-- ── Section label ──────────────────────────────────────── -->
                <div class="civil-section-label">
                    <i class="fa fa-th me-2"/>Subdivision Executive Breakdown
                </div>

                <!-- ── Legend ─────────────────────────────────────────────── -->
                <div class="civil-legend-row">
                    <span class="civil-legend-item civil-legend-item--contract">Contract</span>
                    <span class="civil-legend-item civil-legend-item--executed">Executed</span>
                    <span class="civil-legend-item civil-legend-item--remaining">Remaining</span>
                    <span class="civil-legend-item civil-legend-item--approved">Approved</span>
                    <span class="civil-legend-item civil-legend-item--claimed">Claimed</span>
                    <span class="civil-legend-item civil-legend-item--invoiced">Invoiced</span>
                    <span class="civil-legend-item civil-legend-item--progress">Progress</span>
                    <span class="civil-legend-item civil-legend-item--variation">Variation</span>
                </div>

                <!-- ── 8 Subdivision mini-dashboards ─────────────────────── -->
                <div class="civil-subdiv-grid">

<!-- CARD TEMPLATE (repeated x 8, prefix changes per card):
     civil-card-header   = icon + name + hint (no metric, just identity)
     civil-metric-row primary    3-col: Contract | Executed | Remaining
     civil-metric-row financial  3-col: Approved | Claimed  | Invoiced
     civil-metric-row process    4-col: InProg | Inspection | Handover | NotStart
     civil-metric-row variation  wide:  Variation -->

                    <!-- ── 1. Site Preparation ───────────────────────────── -->
                    <div class="civil-subdiv-card civil-subdiv-card--siteprep">
                        <button name="action_view_site_prep" type="object"
                                class="sf-card-btn--light" title="View Site Preparation JOs"/>
                        <div class="civil-card-header">
                            <div class="civil-card-header__icon"><i class="fa fa-road"/></div>
                            <div class="civil-card-header__info">
                                <div class="civil-card-header__name">Site Preparation</div>
                                <div class="civil-card-header__hint">Clearing, grading, levelling</div>
                            </div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--primary">
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--contract"><field name="sp_contract" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">Contract</div>
                            </div>
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--executed"><field name="sp_executed" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">Executed</div>
                            </div>
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--remaining"><field name="sp_remaining" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">Remaining</div>
                            </div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--financial">
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--approved"><field name="sp_approved" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">Approved</div>
                            </div>
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--claimed"><field name="sp_claimed" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">Claimed</div>
                            </div>
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--invoiced"><field name="sp_invoiced" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">Invoiced</div>
                            </div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--process">
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--inprog"><field name="sp_inprog" readonly="1"/></div>
                                <div class="civil-metric-item__lbl">In Progress</div>
                            </div>
                            <div class="civil-metric-item">
                                <div class="civil-metric-item__val civil-val--inspection"><field name="sp_inspection" readonly="1"/></div>
