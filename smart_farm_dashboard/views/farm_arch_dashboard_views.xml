                            <div class="civil-card-header__info">
                                <div class="civil-card-header__name">Block Work</div>
                                <div class="civil-card-header__hint">Masonry, block laying, mortar</div>
                            </div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--primary">
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--contract"><field name="bk_contract" readonly="1"/></div><div class="civil-metric-item__lbl">Contract</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--executed"><field name="bk_executed" readonly="1"/></div><div class="civil-metric-item__lbl">Executed</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--remaining"><field name="bk_remaining" readonly="1"/></div><div class="civil-metric-item__lbl">Remaining</div></div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--financial">
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--approved"><field name="bk_approved" readonly="1"/></div><div class="civil-metric-item__lbl">Approved</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--claimed"><field name="bk_claimed" readonly="1"/></div><div class="civil-metric-item__lbl">Claimed</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--invoiced"><field name="bk_invoiced" readonly="1"/></div><div class="civil-metric-item__lbl">Invoiced</div></div>
