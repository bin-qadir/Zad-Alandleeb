<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<record id="view_farm_structure_dashboard_form" model="ir.ui.view">
    <field name="name">farm.structure.dashboard.form</field>
    <field name="model">farm.structure.dashboard</field>
    <field name="arch" type="xml">
        <form string="Structure Dashboard" create="0" delete="0" edit="0">
            <sheet>

                <!-- Project context banner -->
                <div class="civil-project-ctx" invisible="not project_id">
                    <button name="action_back_to_project" type="object"
                            class="civil-project-ctx__back" title="Back to Project Dashboard">
                        <i class="fa fa-arrow-left me-1"/>Back
                    </button>
                    <i class="fa fa-filter me-2"/>
                    Filtered to project:
                    <strong>
                        <field name="project_id" readonly="1" nolabel="1"
                               options="{'no_open': True}"/>
                    </strong>
                </div>

                <!-- Header banner -->
                <div class="civil-dash-header">
                    <div class="civil-dash-header__left">
                        <i class="fa fa-object-group civil-dash-header__icon"/>
                        <div>
                            <div class="civil-dash-header__title">Structure Division</div>
                            <div class="civil-dash-header__sub">Construction — Structural Works</div>
                        </div>
                    </div>
                    <div class="civil-dash-header__kpi">
                        <button name="action_view_all_structure" type="object"
                                class="sf-card-btn--light" title="View All Structure JOs"/>
                        <div class="civil-dash-header__kpi-num">
                            <field name="total_structure_jos" readonly="1"/>
                        </div>
                        <div class="civil-dash-header__kpi-lbl">Total Structure Job Orders</div>
                    </div>
                </div>

                <div class="civil-section-label">
                    <i class="fa fa-th me-2"/>Subdivision Executive Breakdown
                </div>

                <div class="civil-legend-row">
                    <span class="civil-legend-item civil-legend-item--contract">Contract</span>
                    <span class="civil-legend-item civil-legend-item--executed">Executed</span>
                    <span class="civil-legend-item civil-legend-item--remaining">Remaining</span>
                    <span class="civil-legend-item civil-legend-item--approved">Approved</span>
                    <span class="civil-legend-item civil-legend-item--claimed">Claimed</span>
                    <span class="civil-legend-item civil-legend-item--invoiced">Invoiced</span>
                    <span class="civil-legend-item civil-legend-item--progress">Progress</span>
                    <span class="civil-legend-item civil-legend-item--variation">Variation</span>
                </div>

                <div class="civil-subdiv-grid">

                    <!-- 1. Foundations -->
                    <div class="civil-subdiv-card">
                        <button name="action_view_foundations" type="object"
                                class="sf-card-btn--light" title="View Foundations JOs"/>
                        <div class="civil-card-header">
                            <div class="civil-card-header__icon"><i class="fa fa-anchor"/></div>
                            <div class="civil-card-header__info">
                                <div class="civil-card-header__name">Foundations</div>
                                <div class="civil-card-header__hint">Deep foundations, piles, raft</div>
                            </div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--primary">
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--contract"><field name="fn_contract" readonly="1"/></div><div class="civil-metric-item__lbl">Contract</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--executed"><field name="fn_executed" readonly="1"/></div><div class="civil-metric-item__lbl">Executed</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--remaining"><field name="fn_remaining" readonly="1"/></div><div class="civil-metric-item__lbl">Remaining</div></div>
                        </div>
                        <div class="civil-metric-row civil-metric-row--financial">
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--approved"><field name="fn_approved" readonly="1"/></div><div class="civil-metric-item__lbl">Approved</div></div>
                            <div class="civil-metric-item"><div class="civil-metric-item__val civil-val--claimed"><field name="fn_claimed" readonly="1"/></div><div class="civil-metric-item__lbl">Claimed</div></div>
