<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Default Decision Rules
             noupdate=1 — admins can tune without upgrade reset
        ================================================================ -->

        <record id="rule_temp_high" model="farm.decision.rule">
            <field name="name">High Temperature → Cooling</field>
            <field name="sequence">10</field>
            <field name="metric">temperature</field>
            <field name="operator">gt</field>
            <field name="threshold">40.0</field>
            <field name="action">cooling</field>
            <field name="priority">2</field>
            <field name="cooldown_minutes">60</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports temperature {value:.1f}°C &gt; {threshold:.1f}°C. Activate cooling or increase ventilation immediately.</field>
        </record>

        <record id="rule_temp_warning" model="farm.decision.rule">
            <field name="name">Temperature Warning → Monitor</field>
            <field name="sequence">15</field>
            <field name="metric">temperature</field>
            <field name="operator">gt</field>
            <field name="threshold">35.0</field>
            <field name="action">manual_check</field>
            <field name="priority">1</field>
            <field name="cooldown_minutes">120</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports temperature {value:.1f}°C approaching limit {threshold:.1f}°C. Monitor closely and prepare cooling.</field>
        </record>

        <record id="rule_temp_low" model="farm.decision.rule">
            <field name="name">Low Temperature → Heating</field>
            <field name="sequence">20</field>
            <field name="metric">temperature</field>
            <field name="operator">lt</field>
            <field name="threshold">10.0</field>
            <field name="action">heating</field>
            <field name="priority">1</field>
            <field name="cooldown_minutes">60</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports temperature {value:.1f}°C below minimum {threshold:.1f}°C. Activate heating system.</field>
        </record>

        <record id="rule_humidity_low" model="farm.decision.rule">
            <field name="name">Low Humidity → Irrigation</field>
            <field name="sequence">30</field>
            <field name="metric">humidity</field>
            <field name="operator">lt</field>
            <field name="threshold">20.0</field>
            <field name="action">irrigation</field>
            <field name="priority">2</field>
            <field name="cooldown_minutes">90</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports humidity {value:.1f}% below minimum {threshold:.1f}%. Start irrigation cycle.</field>
        </record>

        <record id="rule_humidity_high" model="farm.decision.rule">
            <field name="name">High Humidity → Dehumidify</field>
            <field name="sequence">35</field>
            <field name="metric">humidity</field>
            <field name="operator">gt</field>
            <field name="threshold">90.0</field>
            <field name="action">dehumidify</field>
            <field name="priority">1</field>
            <field name="cooldown_minutes">60</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports humidity {value:.1f}% above maximum {threshold:.1f}%. Activate dehumidification.</field>
        </record>

        <record id="rule_co2_critical" model="farm.decision.rule">
            <field name="name">Critical CO₂ → Inject / Ventilate</field>
            <field name="sequence">40</field>
            <field name="metric">co2</field>
            <field name="operator">gt</field>
            <field name="threshold">1000.0</field>
            <field name="action">co2_inject</field>
            <field name="priority">2</field>
            <field name="cooldown_minutes">30</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports CO₂ at {value:.0f} ppm above critical {threshold:.0f} ppm. Open vents or check CO₂ supply.</field>
        </record>

        <record id="rule_co2_warning" model="farm.decision.rule">
            <field name="name">CO₂ Warning Level</field>
            <field name="sequence">45</field>
            <field name="metric">co2</field>
            <field name="operator">gt</field>
            <field name="threshold">800.0</field>
            <field name="action">co2_reduce</field>
            <field name="priority">1</field>
            <field name="cooldown_minutes">60</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} reports CO₂ at {value:.0f} ppm near limit {threshold:.0f} ppm. Increase ventilation.</field>
        </record>

        <record id="rule_sensor_offline" model="farm.decision.rule">
            <field name="name">Sensor Offline → Manual Check</field>
            <field name="sequence">50</field>
            <field name="metric">offline</field>
            <field name="operator">offline</field>
            <field name="offline_minutes">30</field>
            <field name="action">manual_check</field>
            <field name="priority">1</field>
            <field name="cooldown_minutes">120</field>
            <field name="auto_execute">False</field>
            <field name="recommendation_template">Sensor {sensor} on {farm} has not reported for over 30 minutes. Check connectivity and power supply.</field>
        </record>

    </data>
</odoo>
