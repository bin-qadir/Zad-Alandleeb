<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ================================================================
             Scheduled: Check for offline sensors (every 30 minutes)
        ================================================================ -->
        <record id="ir_cron_check_offline_sensors" model="ir.cron">
            <field name="name">Smart Farm: Check Offline Sensors</field>
            <field name="model_id" ref="model_farm_sensor_maintenance"/>
            <field name="state">code</field>
            <field name="code">model.check_offline_sensors(timeout_minutes=30)</field>
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- ================================================================
             Scheduled: Purge old sensor readings (weekly, keep 90 days)
        ================================================================ -->
        <record id="ir_cron_purge_sensor_data" model="ir.cron">
            <field name="name">Smart Farm: Purge Old Sensor Readings</field>
            <field name="model_id" ref="model_farm_sensor_maintenance"/>
            <field name="state">code</field>
            <field name="code">model.purge_old_readings(days=90)</field>
            <field name="interval_number">7</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- ================================================================
             Server Action: Manual "Purge Now" button for admin use
        ================================================================ -->
        <record id="action_purge_sensor_data_now" model="ir.actions.server">
            <field name="name">Purge Old Sensor Readings Now</field>
            <field name="model_id" ref="model_farm_sensor_maintenance"/>
            <field name="state">code</field>
            <field name="code">model.purge_old_readings(days=90)</field>
        </record>

    </data>
</odoo>
