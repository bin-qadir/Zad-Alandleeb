<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         project.task — Form View Extension (Cost Control Center)
    ================================================================ -->
    <record id="view_task_form_cost_control" model="ir.ui.view">
        <field name="name">project.task.form.cost.control</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">

            <!-- ── Header: "Create RFQ" action button ──────────────────── -->
            <xpath expr="//header" position="inside">
                <button name="action_create_rfq"
                        string="Create RFQ"
                        type="object"
                        class="btn-primary"
                        icon="fa-shopping-cart"
                        invisible="not has_draft_material_lines"
                        title="Create one RFQ per vendor from all Draft material lines"/>
                <button name="action_create_quotation"
                        string="Create Quotation"
                        type="object"
                        class="btn-success"
                        icon="fa-file-text"
                        invisible="not total_cost"
                        title="Generate a Sale Order from this task's costs and margin"/>
            </xpath>

            <!-- ── Smart Buttons ────────────────────────────────────────── -->
            <xpath expr="//div[@name='button_box']" position="inside">

                <!-- Materials -->
                <button name="action_view_materials"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-cubes"
                        invisible="material_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="material_count"/>
                        </span>
                        <span class="o_stat_text">Materials</span>
                    </div>
                </button>

                <!-- Labor -->
                <button name="action_view_labor"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-users"
                        invisible="labor_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="labor_count"/>
                        </span>
                        <span class="o_stat_text">Labor</span>
                    </div>
                </button>

                <!-- RFQ count -->
                <button name="action_view_rfqs"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-shopping-cart"
                        invisible="rfq_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="rfq_count"/>
                        </span>
                        <span class="o_stat_text">RFQ</span>
                    </div>
                </button>

                <!-- Quotations -->
                <button name="action_view_quotations"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-file-text-o"
                        invisible="sale_order_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="sale_order_count"/>
                        </span>
                        <span class="o_stat_text">Quotations</span>
                    </div>
                </button>

                <!-- Hidden compute driver fields -->
                <field name="has_draft_material_lines" invisible="1"/>

            </xpath>

            <!-- ── Farm / Field link fields ─────────────────────────────── -->
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="farm_id" options="{'no_create': True}"/>
                <field name="farm_field_id"
                       options="{'no_create': True}"
                       invisible="not farm_id"/>
            </xpath>

            <!-- ── Cost Control Notebook Page ───────────────────────────── -->
            <xpath expr="//notebook" position="inside">
                <page string="Cost Control" name="cost_control" icon="fa-usd">

                    <!-- ── Cost Summary Banner ───────────────────────────── -->
                    <div class="o_farm_cost_summary row mb-3">
                        <div class="col-sm-3">
                            <div class="o_farm_cost_box o_farm_cost_material p-3 rounded text-center">
                                <div class="fw-bold text-muted small mb-1">MATERIAL COST</div>
                                <div class="fs-5 fw-bold">
                                    <field name="material_cost" widget="monetary"
                                           options="{'currency_field': 'cost_currency_id'}"
                                           readonly="True"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="o_farm_cost_box o_farm_cost_labor p-3 rounded text-center">
                                <div class="fw-bold text-muted small mb-1">LABOR COST</div>
                                <div class="fs-5 fw-bold">
                                    <field name="labor_cost" widget="monetary"
                                           options="{'currency_field': 'cost_currency_id'}"
                                           readonly="True"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="o_farm_cost_box o_farm_cost_overhead p-3 rounded text-center">
                                <div class="fw-bold text-muted small mb-1">OVERHEAD COST</div>
                                <div class="fs-5 fw-bold">
                                    <field name="overhead_cost" widget="monetary"
                                           options="{'currency_field': 'cost_currency_id'}"/>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-3">
                            <div class="o_farm_cost_box o_farm_cost_total p-3 rounded text-center">
                                <div class="fw-bold text-muted small mb-1">TOTAL COST</div>
                                <div class="fs-5 fw-bold text-danger">
                                    <field name="total_cost" widget="monetary"
                                           options="{'currency_field': 'cost_currency_id'}"
                                           readonly="True"/>
                                </div>
                            </div>
                        </div>
                        <field name="cost_currency_id" invisible="1"/>
                    </div>

                    <!-- ── Budget ─────────────────────────────────────────── -->
                    <group string="Budget">
                        <group>
                            <field name="budget_amount"/>
                            <field name="budget_variance" readonly="True" widget="monetary"/>
                        </group>
                        <group>
                            <field name="budget_progress" readonly="True" widget="progressbar"/>
                        </group>
                    </group>

                    <!-- ── Pricing & Margin ──────────────────────────────── -->
                    <group string="Pricing &amp; Margin">
                        <group>
                            <field name="margin_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="margin_percent"
                                   invisible="margin_type != 'percent'"
                                   string="Margin %"/>
                            <field name="margin_amount" widget="monetary"
                                   invisible="margin_type != 'fixed'"
                                   options="{'currency_field': 'cost_currency_id'}"
                                   string="Margin Amount"/>
                        </group>
                        <group>
                            <field name="margin_value" readonly="True" widget="monetary"
                                   options="{'currency_field': 'cost_currency_id'}"
                                   string="Margin Value"/>
                            <field name="selling_price" readonly="True" widget="monetary"
                                   options="{'currency_field': 'cost_currency_id'}"
                                   class="fw-bold text-success"/>
                        </group>
                    </group>

                    <!-- ── Material Lines ─────────────────────────────────── -->
                    <div class="d-flex align-items-center justify-content-between mt-3 mb-1">
                        <h4 class="mb-0">
                            <i class="fa fa-cubes me-1"/> Material Lines
                        </h4>
                        <div class="d-flex gap-2 align-items-center">
                            <!-- Receipt summary badges -->
                            <span class="badge text-bg-success"
                                  invisible="not materials_all_received">
                                <i class="fa fa-check me-1"/>All Received
                            </span>
                            <span class="badge text-bg-warning"
                                  invisible="not materials_partial">
                                <i class="fa fa-adjust me-1"/>Partially Received
                            </span>
                            <button name="action_create_rfq"
                                    type="object"
                                    string="Create RFQ"
                                    class="btn btn-sm btn-primary"
                                    icon="fa-shopping-cart"
                                    invisible="not has_draft_material_lines"
                                    title="Creates one RFQ per vendor for all Draft lines"/>
                        </div>
                    </div>

                    <field name="material_line_ids"
                           context="{'default_task_id': id}">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="product_id" required="1"/>
                            <field name="description" optional="show"/>
                            <field name="vendor_id"
                                   optional="show"/>
                            <field name="quantity" string="Ordered"/>
                            <field name="received_qty" readonly="True" string="Received"/>
                            <field name="remaining_qty" readonly="True" string="Remaining"
                                   optional="show"/>
                            <field name="uom_id" optional="show"/>
                            <field name="unit_price" optional="show"/>
                            <field name="subtotal" widget="monetary" readonly="True"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="purchase_order_id"
                                   optional="show"
                                   readonly="True"/>
                            <field name="state" widget="badge"
                                   readonly="True"/>
                            <!-- Reset to Draft (only when no qty received yet) -->
                            <button name="action_reset_to_draft"
                                    type="object"
                                    string=""
                                    title="Reset to Draft"
                                    icon="fa-undo"
                                    class="btn-link text-warning p-0"
                                    invisible="state not in ('requested',)"/>
                            <!-- Cancel line -->
                            <button name="action_cancel"
                                    type="object"
                                    string=""
                                    title="Cancel Line"
                                    icon="fa-times"
                                    class="btn-link text-danger p-0"
                                    invisible="state in ('received', 'cancelled')"/>
                            <!-- Re-open cancelled line -->
                            <button name="action_reopen"
                                    type="object"
                                    string=""
                                    title="Re-open (Reset to Draft)"
                                    icon="fa-refresh"
                                    class="btn-link text-primary p-0"
                                    invisible="state != 'cancelled'"/>
                        </list>
                    </field>

                    <!-- ── Labor Lines ────────────────────────────────────── -->
                    <div class="d-flex align-items-center mt-4 mb-1">
                        <h4 class="mb-0">
                            <i class="fa fa-users me-1"/> Labor Lines
                        </h4>
                    </div>

                    <field name="labor_line_ids"
                           context="{'default_task_id': id}">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="work_date"/>
                            <field name="employee_id"/>
                            <field name="job_title"/>
                            <field name="description"/>
                            <field name="hours"/>
                            <field name="hourly_rate" widget="monetary"/>
                            <field name="subtotal" widget="monetary" readonly="True"/>
                            <field name="currency_id" column_invisible="1"/>
                        </list>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

    <!-- ================================================================
         project.task — List View Extension
    ================================================================ -->
    <record id="view_task_list_cost_control" model="ir.ui.view">
        <field name="name">project.task.list.cost.control</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="material_cost"  optional="hide" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}"/>
                <field name="labor_cost"     optional="hide" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}"/>
                <field name="overhead_cost"  optional="hide" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}"/>
                <field name="total_cost"     optional="show" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}"/>
                <field name="budget_amount"  optional="hide" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}"/>
                <field name="budget_variance" optional="hide" widget="monetary"
                       options="{'currency_field': 'cost_currency_id'}"/>
                <field name="rfq_count"      optional="show"/>
                <field name="materials_all_received" optional="hide"
                       widget="boolean_toggle" readonly="True"/>
                <field name="cost_currency_id" column_invisible="1"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         task.material — Standalone list / form / search + action
         (used by the Materials smart button and Reporting menu)
    ================================================================ -->
    <record id="view_task_material_list" model="ir.ui.view">
        <field name="name">task.material.list</field>
        <field name="model">task.material</field>
        <field name="arch" type="xml">
            <list string="Material Lines"
                  editable="bottom"
                  decoration-success="state == 'received'"
                  decoration-warning="state == 'partial'"
                  decoration-info="state == 'requested'"
                  decoration-muted="state == 'cancelled'">
                <field name="sequence" widget="handle"/>
                <field name="task_id"    optional="show"/>
                <field name="project_id" optional="show" readonly="True"/>
                <field name="product_id"/>
                <field name="description" optional="show"/>
                <field name="vendor_id"/>
                <field name="quantity"     string="Ordered"/>
                <field name="received_qty" string="Received" readonly="True"/>
                <field name="remaining_qty" string="Remaining" readonly="True" optional="show"/>
                <field name="receipt_progress" string="%" readonly="True" optional="show"
                       widget="progressbar"/>
                <field name="uom_id" optional="show"/>
                <field name="unit_price" optional="show"/>
                <field name="subtotal" widget="monetary" readonly="True"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="purchase_order_id" optional="show" readonly="True"/>
                <field name="state" widget="badge"
                       readonly="True"/>
                <button name="action_reset_to_draft" type="object" string=""
                        title="Reset to Draft" icon="fa-undo"
                        class="btn-link text-warning"
                        invisible="state != 'requested'"/>
                <button name="action_cancel" type="object" string=""
                        title="Cancel" icon="fa-times"
                        class="btn-link text-danger"
                        invisible="state in ('received','cancelled')"/>
                <button name="action_reopen" type="object" string=""
                        title="Re-open" icon="fa-refresh"
                        class="btn-link text-primary"
                        invisible="state != 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="view_task_material_form" model="ir.ui.view">
        <field name="name">task.material.form</field>
        <field name="model">task.material</field>
        <field name="arch" type="xml">
            <form string="Material Line">
                <header>
                    <button name="action_reset_to_draft"
                            string="Reset to Draft"
                            type="object"
                            class="btn-warning"
                            invisible="state not in ('requested',)"/>
                    <button name="action_cancel"
                            string="Cancel Line"
                            type="object"
                            class="btn-danger"
                            invisible="state in ('received','cancelled')"/>
                    <button name="action_reopen"
                            string="Re-open"
                            type="object"
                            class="btn-secondary"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,requested,partial,received"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="product_id" readonly="state != 'draft'"/></h1>
                    </div>
                    <group>
                        <group string="Task">
                            <field name="task_id"/>
                            <field name="project_id" readonly="True"/>
                            <field name="vendor_id"/>
                        </group>
                        <group string="Material">
                            <field name="description"/>
                            <field name="quantity" string="Ordered Qty"/>
                            <field name="uom_id"/>
                        </group>
                    </group>
                    <!-- Receipt progress -->
                    <group string="Receipt Status"
                           invisible="state == 'draft'">
                        <group>
                            <field name="received_qty" readonly="True"/>
                            <field name="remaining_qty" readonly="True"/>
                        </group>
                        <group>
                            <field name="receipt_progress" readonly="True"
                                   widget="progressbar"/>
                        </group>
                    </group>
                    <group string="Costing">
                        <group>
                            <field name="unit_price"/>
                            <field name="subtotal" readonly="True" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <group string="Purchase Link">
                        <group>
                            <field name="purchase_order_id" readonly="True"/>
                            <field name="purchase_line_id"  readonly="True"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_task_material_search" model="ir.ui.view">
        <field name="name">task.material.search</field>
        <field name="model">task.material</field>
        <field name="arch" type="xml">
            <search string="Search Materials">
                <field name="task_id"/>
                <field name="project_id"/>
                <field name="product_id"/>
                <field name="vendor_id"/>
                <filter name="draft"     string="Draft"              domain="[('state','=','draft')]"/>
                <filter name="requested" string="RFQ Created"        domain="[('state','=','requested')]"/>
                <filter name="partial"   string="Partially Received" domain="[('state','=','partial')]"/>
                <filter name="received"  string="Fully Received"     domain="[('state','=','received')]"/>
                <filter name="cancelled" string="Cancelled"          domain="[('state','=','cancelled')]"/>
                <separator/>
                <filter name="no_vendor" string="Missing Vendor"
                        domain="[('vendor_id','=',False),('state','=','draft')]"/>
                <filter name="not_received" string="Pending Receipt"
                        domain="[('state','in',('requested','partial'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_task"    string="Task"    context="{'group_by': 'task_id'}"/>
                    <filter name="group_project" string="Project" context="{'group_by': 'project_id'}"/>
                    <filter name="group_vendor"  string="Vendor"  context="{'group_by': 'vendor_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="group_state"   string="Status"  context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_task_material" model="ir.actions.act_window">
        <field name="name">Task Materials</field>
        <field name="res_model">task.material</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_task_material_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No material lines yet.</p>
        </field>
    </record>

    <!-- ================================================================
         task.labor — Standalone list / form / search + action
    ================================================================ -->
    <record id="view_task_labor_list" model="ir.ui.view">
        <field name="name">task.labor.list</field>
        <field name="model">task.labor</field>
        <field name="arch" type="xml">
            <list string="Labor Lines" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="task_id"    optional="hide"/>
                <field name="project_id" optional="show" readonly="True"/>
                <field name="work_date"/>
                <field name="employee_id"/>
                <field name="job_title"/>
                <field name="description"/>
                <field name="hours"/>
                <field name="hourly_rate" widget="monetary"/>
                <field name="subtotal" widget="monetary" readonly="True"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_task_labor_form" model="ir.ui.view">
        <field name="name">task.labor.form</field>
        <field name="model">task.labor</field>
        <field name="arch" type="xml">
            <form string="Labor Line">
                <sheet>
                    <group>
                        <group string="Task">
                            <field name="task_id"/>
                            <field name="project_id" readonly="True"/>
                            <field name="work_date"/>
                        </group>
                        <group string="Worker">
                            <field name="employee_id"/>
                            <field name="job_title"/>
                            <field name="description"/>
                        </group>
                    </group>
                    <group>
                        <group string="Time &amp; Cost">
                            <field name="hours"/>
                            <field name="hourly_rate" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="subtotal" readonly="True" widget="monetary"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_task_labor_search" model="ir.ui.view">
        <field name="name">task.labor.search</field>
        <field name="model">task.labor</field>
        <field name="arch" type="xml">
            <search string="Search Labor">
                <field name="task_id"/>
                <field name="project_id"/>
                <field name="employee_id"/>
                <filter name="this_month" string="This Month"
                        domain="[('work_date','&gt;=', (context_today()).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_task"     string="Task"     context="{'group_by': 'task_id'}"/>
                    <filter name="group_project"  string="Project"  context="{'group_by': 'project_id'}"/>
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_date"     string="Month"    context="{'group_by': 'work_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_task_labor" model="ir.actions.act_window">
        <field name="name">Task Labor</field>
        <field name="res_model">task.labor</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_task_labor_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No labor lines yet.</p>
        </field>
    </record>

    <!-- ================================================================
         Cost Analysis — Pivot + Graph + Action
    ================================================================ -->
    <record id="view_task_cost_pivot" model="ir.ui.view">
        <field name="name">project.task.cost.pivot</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <pivot string="Task Cost Analysis">
                <field name="project_id"    type="row"/>
                <field name="stage_id"      type="col"/>
                <field name="material_cost" type="measure"/>
                <field name="labor_cost"    type="measure"/>
                <field name="overhead_cost" type="measure"/>
                <field name="total_cost"    type="measure"/>
                <field name="budget_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_task_cost_graph" model="ir.ui.view">
        <field name="name">project.task.cost.graph</field>
        <field name="model">project.task</field>
        <field name="arch" type="xml">
            <graph string="Task Cost Overview" type="bar" stacked="1">
                <field name="project_id"    type="row"/>
                <field name="material_cost" type="measure"/>
                <field name="labor_cost"    type="measure"/>
                <field name="overhead_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_task_cost_analysis" model="ir.actions.act_window">
        <field name="name">Task Cost Analysis</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="context">{'search_default_open_tasks': 1}</field>
    </record>

</odoo>
