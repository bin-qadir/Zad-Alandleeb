<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Livestock Category -->
    <record id="view_farm_livestock_category_list" model="ir.ui.view">
        <field name="name">farm.livestock.category.list</field>
        <field name="model">farm.livestock.category</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_farm_livestock_category" model="ir.actions.act_window">
        <field name="name">Livestock Categories</field>
        <field name="res_model">farm.livestock.category</field>
        <field name="view_mode">list</field>
    </record>

    <!-- Livestock -->
    <record id="view_farm_livestock_list" model="ir.ui.view">
        <field name="name">farm.livestock.list</field>
        <field name="model">farm.livestock</field>
        <field name="arch" type="xml">
            <list string="Livestock" decoration-danger="state == 'sick'" decoration-muted="state in ('sold','deceased')">
                <field name="tag_number"/>
                <field name="name"/>
                <field name="farm_id"/>
                <field name="category_id"/>
                <field name="species"/>
                <field name="gender"/>
                <field name="date_of_birth"/>
                <field name="age"/>
                <field name="weight"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_farm_livestock_form" model="ir.ui.view">
        <field name="name">farm.livestock.form</field>
        <field name="model">farm.livestock</field>
        <field name="arch" type="xml">
            <form string="Livestock">
                <header>
                    <button name="action_mark_sick" string="Mark Sick"
                            type="object" class="btn-warning"
                            invisible="state != 'active'"/>
                    <button name="action_mark_active" string="Mark Active"
                            type="object" class="btn-primary"
                            invisible="state != 'sick'"/>
                    <button name="action_mark_sold" string="Mark Sold"
                            type="object"
                            invisible="state in ('sold','deceased')"/>
                    <button name="action_mark_deceased" string="Mark Deceased"
                            type="object" class="btn-danger"
                            invisible="state in ('sold','deceased')"/>
                    <field name="state" widget="statusbar" statusbar_visible="active,sick,sold,deceased"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Animal Name / ID"/></h1>
                        <h3 class="text-muted">Tag: <field name="tag_number" placeholder="Ear Tag..."/></h3>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="farm_id"/>
                            <field name="category_id"/>
                            <field name="species"/>
                            <field name="gender"/>
                        </group>
                        <group string="Details">
                            <field name="date_of_birth"/>
                            <field name="age" readonly="True"/>
                            <field name="weight"/>
                            <field name="responsible_id"/>
                        </group>
                    </group>
                    <group string="Acquisition &amp; Sale">
                        <group>
                            <field name="purchase_date"/>
                            <field name="purchase_price"/>
                            <field name="purchase_order_id"/>
                        </group>
                        <group>
                            <field name="sale_order_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_farm_livestock_search" model="ir.ui.view">
        <field name="name">farm.livestock.search</field>
        <field name="model">farm.livestock</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="tag_number"/>
                <field name="farm_id"/>
                <field name="category_id"/>
                <filter name="active" string="Active" domain="[('state','=','active')]"/>
                <filter name="sick" string="Sick" domain="[('state','=','sick')]"/>
                <filter name="sold" string="Sold" domain="[('state','=','sold')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_farm" string="Farm" context="{'group_by': 'farm_id'}"/>
                    <filter name="group_category" string="Category" context="{'group_by': 'category_id'}"/>
                    <filter name="group_gender" string="Gender" context="{'group_by': 'gender'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_farm_livestock" model="ir.actions.act_window">
        <field name="name">Livestock</field>
        <field name="res_model">farm.livestock</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_farm_livestock_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first animal!</p>
        </field>
    </record>

</odoo>
