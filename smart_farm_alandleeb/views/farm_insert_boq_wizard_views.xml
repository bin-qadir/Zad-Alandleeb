<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
         Insert BOQ Item Template Wizard — Form View
    ========================================================= -->
    <record id="view_farm_insert_boq_wizard_form" model="ir.ui.view">
        <field name="name">farm.insert.boq.item.template.wizard.form</field>
        <field name="model">farm.insert.boq.item.template.wizard</field>
        <field name="arch" type="xml">
            <form string="Insert BOQ Item Template">
                <sheet>
                    <div class="oe_title">
                        <h2>Insert BOQ Item Template</h2>
                    </div>

                    <group>
                        <group string="Selection">
                            <field name="field_id" readonly="1"/>
                            <field name="template_id" required="1"/>
                            <field name="target_section" required="1"/>
                            <field name="main_quantity" string="Main Quantity"
                                   help="Quantity of the main item. Component quantities are calculated automatically."/>
                        </group>
                        <group string="Template Preview" invisible="not template_id">
                            <field name="template_description" readonly="1" nolabel="1"
                                   invisible="not template_description"/>
                            <field name="template_section" readonly="1"/>
                            <field name="template_line_count" readonly="1" string="Component Lines"/>
                        </group>
                    </group>

                    <group string="Placement in Costing Workspace">
                        <group>
                            <field name="parent_section_id"
                                   domain="[('field_id','=',field_id),('display_type','=','line_section')]"
                                   string="Under Division Header"/>
                        </group>
                        <group>
                            <field name="parent_subsection_id"
                                   domain="[('field_id','=',field_id),('display_type','=','line_subsection')]"
                                   string="Under Sub-division Header"/>
                        </group>
                    </group>

                    <!-- Cost summary preview -->
                    <group string="Cost Preview" invisible="not template_id"
                           class="oe_subtotal_footer oe_right">
                        <field name="template_material_total" readonly="1" string="Material"/>
                        <field name="template_labor_total" readonly="1" string="Labor"/>
                        <field name="template_overhead_total" readonly="1" string="Overhead"/>
                        <field name="template_total_cost" readonly="1" string="Total Cost / Item"
                               class="oe_subtotal_footer_separator"/>
                        <field name="template_profit_percent" readonly="1" string="Profit %"/>
                        <field name="template_sales_price" readonly="1" string="Total Sales Price"
                               class="oe_subtotal_footer_separator"/>
                    </group>

                </sheet>
                <footer>
                    <button name="action_insert" string="Insert Template" type="object"
                            class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"
                            data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- =========================================================
         Action (used by server action / button)
    ========================================================= -->
    <record id="action_farm_insert_boq_wizard" model="ir.actions.act_window">
        <field name="name">Insert BOQ Item Template</field>
        <field name="res_model">farm.insert.boq.item.template.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
