<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =========================================================
         B.O.Q Item Template — List View
    ========================================================= -->
    <record id="view_farm_boq_item_template_list" model="ir.ui.view">
        <field name="name">farm.boq.item.template.list</field>
        <field name="model">farm.boq.item.template</field>
        <field name="arch" type="xml">
            <list string="BOQ Item Templates">
                <field name="code" optional="show"/>
                <field name="name"/>
                <field name="costing_section"/>
                <field name="work_type_id" optional="show"/>
                <field name="product_id" optional="show"/>
                <field name="unit_name" optional="show"/>
                <field name="qty_item"/>
                <field name="profit_percent" string="Profit %"/>
                <field name="material_total" sum="Material Total"/>
                <field name="labor_total" sum="Labor Total"/>
                <field name="overhead_total" sum="Overhead Total"/>
                <field name="total_cost_per_item" sum="Cost Total"/>
                <field name="total_sales_price_qty_item" sum="Sales Total"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- =========================================================
         B.O.Q Item Template — Form View
    ========================================================= -->
    <record id="view_farm_boq_item_template_form" model="ir.ui.view">
        <field name="name">farm.boq.item.template.form</field>
        <field name="model">farm.boq.item.template</field>
        <field name="arch" type="xml">
            <form string="BOQ Item Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Item name..."/></h1>
                    </div>

                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="costing_section"/>
                            <field name="work_type_id"
                                   domain="[('costing_section', '=', costing_section), ('active', '=', True)]"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Unit &amp; Quantity">
                            <field name="product_id"/>
                            <field name="unit_name"/>
                            <field name="qty_item" string="Qty per Item"/>
                            <field name="profit_percent" string="Profit %"/>
                        </group>
                    </group>

                    <group string="Description">
                        <field name="description" nolabel="1" placeholder="Detailed description of this BOQ item..."/>
                    </group>

                    <!-- Component Lines -->
                    <notebook>
                        <page string="Component Lines" name="lines">
                            <field name="line_ids">
                                <list editable="bottom"
                                      decoration-bf="display_type == 'line_section'"
                                      decoration-it="display_type == 'line_note'">
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="line_no" string="Line No."
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="description" string="Description"/>
                                    <field name="product_id"
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="unit_name" string="Unit"
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="qty_1" string="Qty"
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="base_ratio_qty" string="Ratio / 1 Unit"
                                           invisible="display_type in ('line_section','line_note')"
                                           help="Quantity per 1 unit of the main parent item"/>
                                    <field name="cost_type_id"
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="cost_category" string="Category"
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="cost_unit" string="Unit Cost"
                                           invisible="display_type in ('line_section','line_note')"/>
                                    <field name="material_amount" string="Material"
                                           invisible="display_type in ('line_section','line_note')"
                                           sum="Material"/>
                                    <field name="labor_amount" string="Labor"
                                           invisible="display_type in ('line_section','line_note')"
                                           sum="Labor"/>
                                    <field name="overhead_amount" string="Overhead"
                                           invisible="display_type in ('line_section','line_note')"
                                           sum="Overhead"/>
                                    <field name="total_line_cost" string="Total"
                                           invisible="display_type in ('line_section','line_note')"
                                           sum="Grand Total"/>
                                    <control>
                                        <create string="Add a line"/>
                                        <create string="Add a section"
                                                context="{'default_display_type': 'line_section'}"/>
                                        <create string="Add a note"
                                                context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <!-- Summary Block -->
                    <div class="oe_clear"/>
                    <group string="Cost Summary" class="oe_subtotal_footer oe_right">
                        <field name="material_total" readonly="1" string="Total Material"/>
                        <field name="labor_total" readonly="1" string="Total Labor"/>
                        <field name="overhead_total" readonly="1" string="Total Overhead"/>
                        <field name="total_cost_per_item" readonly="1" string="Total Cost / Item"
                               class="oe_subtotal_footer_separator"/>
                        <field name="profit_percent" string="Profit %" widget="percentage"/>
                        <field name="profit_amount" readonly="1" string="Profit Amount"/>
                        <field name="total_sales_price_qty_item" readonly="1"
                               string="Total Sales Price (qty)" class="oe_subtotal_footer_separator"/>
                        <field name="total_sales_price_per_item" readonly="1"
                               string="Sales Price / Unit"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- =========================================================
         B.O.Q Item Template — Search View
    ========================================================= -->
    <record id="view_farm_boq_item_template_search" model="ir.ui.view">
        <field name="name">farm.boq.item.template.search</field>
        <field name="model">farm.boq.item.template</field>
        <field name="arch" type="xml">
            <search string="Search BOQ Templates">
                <field name="name"/>
                <field name="code"/>
                <field name="costing_section"/>
                <field name="product_id"/>
                <filter string="Active" name="active" domain="[('active','=',True)]"/>
                <filter string="Archived" name="archived" domain="[('active','=',False)]"/>
                <separator/>
                <filter string="Civil" name="civil" domain="[('costing_section','=','civil')]"/>
                <filter string="Architecture" name="arch" domain="[('costing_section','=','arch')]"/>
                <filter string="Mechanical" name="mechanical" domain="[('costing_section','=','mechanical')]"/>
                <filter string="Electrical" name="electrical" domain="[('costing_section','=','electrical')]"/>
                <filter string="Irrigation" name="irrigation" domain="[('costing_section','=','irrigation')]"/>
                <filter string="Control System" name="control_system" domain="[('costing_section','=','control_system')]"/>
                <filter string="Other" name="other" domain="[('costing_section','=','other')]"/>
                <group expand="0" string="Group By">
                    <filter string="Works Division" name="by_section" context="{'group_by': 'costing_section'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- =========================================================
         Action
    ========================================================= -->
    <record id="action_farm_boq_item_template" model="ir.actions.act_window">
        <field name="name">B.O.Q Item Templates</field>
        <field name="res_model">farm.boq.item.template</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first BOQ Item Template
            </p>
            <p>
                BOQ Item Templates are reusable definitions of complete BOQ items
                (materials, labor, overhead). Insert them into any field section
                to instantly populate a full cost breakdown.
            </p>
        </field>
    </record>

</odoo>
