<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_farm_irrigation_type_list" model="ir.ui.view">
        <field name="name">farm.irrigation.type.list</field>
        <field name="model">farm.irrigation.type</field>
        <field name="arch" type="xml">
            <list string="Irrigation Types">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <record id="view_farm_irrigation_type_form" model="ir.ui.view">
        <field name="name">farm.irrigation.type.form</field>
        <field name="model">farm.irrigation.type</field>
        <field name="arch" type="xml">
            <form string="Irrigation Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Irrigation Type Name..."/></h1>
                    </div>
                    <group>
                        <field name="description" placeholder="Describe this irrigation method..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_farm_irrigation_type" model="ir.actions.act_window">
        <field name="name">Irrigation Types</field>
        <field name="res_model">farm.irrigation.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first irrigation type!</p>
        </field>
    </record>

</odoo>
