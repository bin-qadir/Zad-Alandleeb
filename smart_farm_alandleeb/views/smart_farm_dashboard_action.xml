<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Smart Farm — Overview landing page
         Pure act_window — no Owl/JS client action.
    ============================================================ -->
    <record id="action_smart_farm_overview" model="ir.actions.act_window">
        <field name="name">Farms Overview</field>
        <field name="res_model">farm.farm</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Welcome to Smart Farm — Al Andleeb
            </p>
            <p>Start by creating your first farm.</p>
        </field>
    </record>

    <menuitem
        id="menu_smart_farm_dashboard_root"
        name="Overview"
        parent="smart_farm_alandleeb.menu_smart_farm_root"
        action="action_smart_farm_overview"
        sequence="1"
        groups="smart_farm_alandleeb.group_farm_user"/>

</odoo>
