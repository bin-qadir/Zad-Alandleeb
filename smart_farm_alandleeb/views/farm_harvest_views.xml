<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_farm_harvest_list" model="ir.ui.view">
        <field name="name">farm.harvest.list</field>
        <field name="model">farm.harvest</field>
        <field name="arch" type="xml">
            <list string="Harvests">
                <field name="name"/>
                <field name="harvest_date"/>
                <field name="farm_id"/>
                <field name="field_id"/>
                <field name="crop_id"/>
                <field name="product_id"/>
                <field name="quantity_harvested"/>
                <field name="uom_id"/>
                <field name="quality_grade"/>
                <field name="total_value" widget="monetary"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_farm_harvest_form" model="ir.ui.view">
        <field name="name">farm.harvest.form</field>
        <field name="model">farm.harvest</field>
        <field name="arch" type="xml">
            <form string="Harvest Record">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_receive_stock" string="Receive into Stock"
                            type="object" class="btn-success"
                            invisible="state != 'confirmed'"/>
                    <button name="action_create_sale_order" string="Create Sale Order"
                            type="object" class="btn-primary"
                            invisible="state not in ('confirmed','in_stock')"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('cancelled','sold')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,in_stock,sold"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="True"/></h1>
                    </div>
                    <group>
                        <group string="Source">
                            <field name="crop_id"/>
                            <field name="field_id" readonly="True"/>
                            <field name="farm_id" readonly="True"/>
                            <field name="responsible_id"/>
                            <field name="harvest_date"/>
                        </group>
                        <group string="Product">
                            <field name="product_id"/>
                            <field name="quantity_harvested"/>
                            <field name="uom_id"/>
                            <field name="quality_grade"/>
                            <field name="loss_quantity"/>
                            <field name="loss_reason" invisible="not loss_quantity"/>
                        </group>
                    </group>
                    <group string="Valuation &amp; Stock">
                        <group>
                            <field name="unit_price"/>
                            <field name="total_value" readonly="True" widget="monetary"/>
                        </group>
                        <group>
                            <field name="location_dest_id"/>
                            <field name="stock_picking_id" readonly="True"/>
                            <field name="sale_order_id" readonly="True"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_farm_harvest_search" model="ir.ui.view">
        <field name="name">farm.harvest.search</field>
        <field name="model">farm.harvest</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="farm_id"/>
                <field name="crop_id"/>
                <field name="product_id"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                <filter name="in_stock" string="In Stock" domain="[('state','=','in_stock')]"/>
                <filter name="this_year" string="This Year"
                        domain="[('harvest_date','&gt;=', (context_today()).strftime('%Y-01-01'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_farm" string="Farm" context="{'group_by': 'farm_id'}"/>
                    <filter name="group_crop" string="Crop" context="{'group_by': 'crop_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                    <filter name="group_quality" string="Quality" context="{'group_by': 'quality_grade'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'harvest_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_farm_harvest" model="ir.actions.act_window">
        <field name="name">Harvest Records</field>
        <field name="res_model">farm.harvest</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_farm_harvest_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first harvest!</p>
        </field>
    </record>

</odoo>
