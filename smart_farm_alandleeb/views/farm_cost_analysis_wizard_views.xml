                            <group class="oe_subtotal_footer oe_right"
                                   invisible="not has_irrigation_costing and not has_irrigation_boq">
                                <field name="irrigation_material_total" readonly="1" string="Material"/>
                                <field name="irrigation_labor_total" readonly="1" string="Labor"/>
                                <field name="irrigation_overhead_total" readonly="1" string="Overhead"/>
                                <field name="irrigation_cost_total" readonly="1" string="Irrigation Subtotal"
                                       class="oe_subtotal_footer_separator"/>
                            </group>

                            <!-- ── CONTROL SYSTEM ─────────────────────────── -->
                            <separator string="Control System Costing" invisible="not has_control_system_costing and not has_control_system_boq"/>

                            <field name="control_system_boq_item_ids" readonly="1" nolabel="1"
                                   invisible="not has_control_system_boq">
                                <list string="Control System BOQ Items">
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="code" string="Code" optional="show"/>
                                    <field name="name" string="Item Name"/>
                                    <field name="unit_name" string="Unit" optional="show"/>
                                    <field name="qty_item" string="Qty"/>
                                    <field name="material_total" string="Material" sum="Material"/>
                                    <field name="labor_total" string="Labor" sum="Labor"/>
                                    <field name="overhead_total" string="Overhead" sum="Overhead"/>
