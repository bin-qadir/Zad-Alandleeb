<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_farm_cost_analysis_wizard_form" model="ir.ui.view">
        <field name="name">farm.cost.analysis.wizard.form</field>
        <field name="model">farm.cost.analysis.wizard</field>
        <field name="arch" type="xml">
            <form string="Cost Analysis Report">
                <sheet>
                    <div class="oe_title">
                        <h1>Cost Analysis Report</h1>
                        <h3>
                            <field name="field_name" readonly="1"/> —
                            <field name="farm_name" readonly="1"/>
                        </h3>
                    </div>

                    <!-- Current Status badge -->
                    <group>
                        <field name="cost_analysis_state" readonly="1" widget="badge"
                               decoration-success="cost_analysis_state == 'approved'"
                               decoration-warning="cost_analysis_state == 'under_review'"
                               decoration-danger="cost_analysis_state == 'rejected'"
                               decoration-muted="cost_analysis_state == 'draft'"
                               string="Current Status"/>
                    </group>

                    <notebook>

                        <!-- ══════════════════════════════════════════════════ -->
                        <!--  PAGE 1 — BOQ SUMMARY                            -->
                        <!-- ══════════════════════════════════════════════════ -->
                        <page string="BOQ Summary" name="boq_summary">

                            <!-- Field details -->
                            <group string="Field Details">
                                <group>
                                    <field name="area" readonly="1"/>
                                    <field name="area_ha" readonly="1"/>
                                </group>
                                <group>
                                    <field name="soil_type" readonly="1"/>
                                    <field name="irrigation_type" readonly="1"/>
                                </group>
                            </group>

                            <!-- Section Totals -->
                            <group string="Section Totals">
                                <group>
                                    <field name="civil_total" readonly="1"/>
                                    <field name="arch_total" readonly="1"/>
                                    <field name="mechanical_total" readonly="1"/>
                                    <field name="electrical_total" readonly="1"/>
                                </group>
                                <group>
                                    <field name="irrigation_cost_total" readonly="1"/>
                                    <field name="control_system_total" readonly="1"/>
                                    <field name="other_total" readonly="1"/>
                                </group>
                            </group>

                            <!-- Category Totals -->
                            <group string="Category Totals">
                                <group>
                                    <field name="material_total" readonly="1"/>
                                    <field name="labor_total" readonly="1"/>
                                    <field name="overhead_total" readonly="1"/>
                                </group>
                            </group>

                            <!-- Analysis Indicators -->
                            <group string="Analysis Indicators">
                                <group>
                                    <field name="cost_per_m2" readonly="1"/>
                                    <field name="cost_line_count" readonly="1"/>
                                </group>
                                <group>
                                    <field name="material_line_count" readonly="1"/>
                                    <field name="labor_line_count" readonly="1"/>
                                    <field name="overhead_line_count" readonly="1"/>
                                </group>
                            </group>

                            <!-- Grand Total -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="grand_total" readonly="1"
                                       string="Grand Total"
                                       class="oe_subtotal_footer_separator"/>
                            </group>

                        </page><!-- /BOQ Summary -->

                        <!-- ══════════════════════════════════════════════════ -->
                        <!--  PAGE 2 — BOQ BREAKDOWN (item-level by section)  -->
                        <!-- ══════════════════════════════════════════════════ -->
                        <page string="BOQ Breakdown" name="boq_breakdown">

                            <!-- ── CIVIL ──────────────────────────────────── -->
                            <separator string="Civil Costing" invisible="not has_civil_costing"/>

                            <!-- BOQ Items -->
                            <field name="civil_boq_item_ids" readonly="1" nolabel="1"
                                   invisible="not has_civil_boq">
                                <list string="Civil BOQ Items">
                                    <field name="sequence" column_invisible="1"/>
                                    <field name="code" string="Code" optional="show"/>
                                    <field name="name" string="Item Name"/>
                                    <field name="unit_name" string="Unit" optional="show"/>
                                    <field name="qty_item" string="Qty"/>
                                    <field name="material_total" string="Material" sum="Material"/>
                                    <field name="labor_total" string="Labor" sum="Labor"/>
                                    <field name="overhead_total" string="Overhead" sum="Overhead"/>
                                    <field name="total_cost_per_item" string="Total Cost" sum="Total Cost"/>
                                    <field name="profit_percent" string="Profit %" optional="show"/>
                                    <field name="total_sales_price_qty_item" string="Sales Price" sum="Sales" optional="show"/>
                                </list>
                            </field>

                            <!-- Flat cost lines -->
                            <field name="civil_cost_line_ids" readonly="1" nolabel="1"
                                   invisible="not has_civil_costing">
                                <list string="Civil Cost Lines"
                                      decoration-bf="display_type == 'line_section'"
                                      decoration-it="display_type == 'line_note'">
                                    <field name="sequence" widget="handle" column_invisible="1"/>
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="name" string="Description"/>
                                    <field name="product_id" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="cost_category" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="quantity" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="unit_cost" string="Unit Cost" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="total_cost" string="Total" invisible="display_type in ('line_section','line_note')" sum="Lines Total"/>
                                </list>
                            </field>
                            <p invisible="has_civil_costing or has_civil_boq"
                               class="text-muted fst-italic">No Civil costing entries.</p>
                            <group class="oe_subtotal_footer oe_right"
                                   invisible="not has_civil_costing and not has_civil_boq">
                                <field name="civil_material_total" readonly="1" string="Material"/>
                                <field name="civil_labor_total" readonly="1" string="Labor"/>
                                <field name="civil_overhead_total" readonly="1" string="Overhead"/>
                                <field name="civil_total" readonly="1" string="Civil Subtotal"
                                       class="oe_subtotal_footer_separator"/>
                            </group>

                            <!-- ── ARCHITECTURE ───────────────────────────── -->
                            <separator string="Architecture Costing" invisible="not has_arch_costing and not has_arch_boq"/>

                            <field name="arch_boq_item_ids" readonly="1" nolabel="1"
