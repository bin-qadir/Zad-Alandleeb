                        <!-- ══════════════════════════════════════════════════ -->
                        <!--  PAGE 3 — ANALYSIS NOTES                         -->
                        <!-- ══════════════════════════════════════════════════ -->
                        <page string="Analysis Notes" name="analysis_notes">
                            <group string="Analysis Notes / Comments">
                                <field name="analysis_note" nolabel="1"
                                       placeholder="Enter analysis notes or comments..."/>
                            </group>
                        </page>

                    </notebook>
                </sheet>

                <footer>
                    <!-- Submit: visible in Draft -->
                    <button name="action_submit" string="Submit for Review"
                            type="object" class="btn-primary"
                            invisible="cost_analysis_state != 'draft'"/>
                    <!-- Approve: visible in Under Review (manager/admin) -->
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            groups="smart_farm_alandleeb.group_farm_manager"
                            invisible="cost_analysis_state != 'under_review'"/>
                    <!-- Reject: visible in Under Review (manager/admin) -->
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            groups="smart_farm_alandleeb.group_farm_manager"
                            invisible="cost_analysis_state != 'under_review'"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>
