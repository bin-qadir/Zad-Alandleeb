                                    <field name="display_type" column_invisible="1"/>
                                    <field name="name" string="Description"/>
                                    <field name="product_id" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="cost_category" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="quantity" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="unit_cost" string="Unit Cost" invisible="display_type in ('line_section','line_note')"/>
                                    <field name="total_cost" string="Total" invisible="display_type in ('line_section','line_note')" sum="Lines Total"/>
                                </list>
                            </field>
                            <p invisible="has_mechanical_costing or has_mechanical_boq"
