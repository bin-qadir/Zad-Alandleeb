<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_farm_expense_list" model="ir.ui.view">
        <field name="name">farm.expense.list</field>
        <field name="model">farm.expense</field>
        <field name="arch" type="xml">
            <list string="Farm Expenses">
                <field name="reference"/>
                <field name="expense_date"/>
                <field name="farm_id"/>
                <field name="field_id"/>
                <field name="name"/>
                <field name="expense_type"/>
                <field name="amount" widget="monetary"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_farm_expense_form" model="ir.ui.view">
        <field name="name">farm.expense.form</field>
        <field name="model">farm.expense</field>
        <field name="arch" type="xml">
            <form string="Farm Expense">
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_create_purchase_order" string="Create Purchase Order"
                            type="object" class="btn-secondary"
                            invisible="state != 'confirmed' or purchase_order_id"/>
                    <button name="action_mark_paid" string="Mark Paid"
                            type="object" class="btn-success"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('paid','cancelled')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Expense Description..."/></h1>
                        <h4 class="text-muted"><field name="reference" readonly="True"/></h4>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="expense_date"/>
                            <field name="expense_type"/>
                            <field name="amount"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="responsible_id"/>
                        </group>
                        <group string="Assignment">
                            <field name="farm_id"/>
                            <field name="field_id" domain="[('farm_id','=',farm_id)]"/>
                            <field name="crop_id" domain="[('farm_id','=',farm_id)]"/>
                            <field name="analytic_account_id"/>
                        </group>
                    </group>
                    <group string="Linked Documents">
                        <group>
                            <field name="purchase_order_id"/>
                            <field name="vendor_bill_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes" placeholder="Additional notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_farm_expense_search" model="ir.ui.view">
        <field name="name">farm.expense.search</field>
        <field name="model">farm.expense</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="reference"/>
                <field name="farm_id"/>
                <field name="expense_type"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                <filter name="paid" string="Paid" domain="[('state','=','paid')]"/>
                <separator/>
                <filter name="my_expenses" string="My Expenses" domain="[('responsible_id','=',uid)]"/>
                <filter name="this_year" string="This Year"
                        domain="[('expense_date','&gt;=', (context_today()).strftime('%Y-01-01'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_farm" string="Farm" context="{'group_by': 'farm_id'}"/>
                    <filter name="group_type" string="Expense Type" context="{'group_by': 'expense_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'expense_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_farm_expense" model="ir.actions.act_window">
        <field name="name">Farm Expenses</field>
        <field name="res_model">farm.expense</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_farm_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Record your first farm expense!</p>
        </field>
    </record>

</odoo>
