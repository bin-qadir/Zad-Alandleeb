<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         Extend product.template form — add Default Cost Type field
         under the "Purchase" tab so Farm costing lines can auto-fill it.
    ================================================================ -->
    <record id="view_product_template_form_cost_type" model="ir.ui.view">
        <field name="name">product.template.form.cost.type</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <!-- Insert after the internal reference / sales description group -->
            <xpath expr="//page[@name='general_information']" position="after">
                <page string="Smart Farm" name="smart_farm_costing">
                    <group>
                        <group string="Farm Costing Defaults">
                            <field name="cost_type_id"
                                   string="Default Cost Type"
                                   help="When this product is selected in a Farm costing line, this cost type will be auto-filled."/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
