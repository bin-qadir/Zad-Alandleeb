<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══ Optimization Suggestion List ════════════════════════════════════ -->
<record id="view_smart_ai_optimization_suggestion_list" model="ir.ui.view">
    <field name="name">smart.ai.optimization.suggestion.list</field>
    <field name="model">smart.ai.optimization.suggestion</field>
    <field name="arch" type="xml">
        <list string="Optimization Suggestions"
              decoration-danger="priority=='high'"
              decoration-warning="priority=='medium'">
            <field name="project_id"/>
            <field name="suggestion_type" widget="badge"/>
            <field name="title"/>
            <field name="priority" widget="badge"
                   decoration-danger="priority=='high'"
                   decoration-warning="priority=='medium'"/>
            <field name="confidence_score" string="Confidence (%)"/>
            <field name="state" widget="badge"
                   decoration-info="state=='pending'"
                   decoration-success="state=='applied'"
                   decoration-muted="state=='dismissed'"/>
            <field name="suggested_at"/>
            <button name="action_apply" type="object" string="Apply"
                    icon="fa-check" invisible="state != 'pending'"/>
            <button name="action_dismiss" type="object" string="Dismiss"
                    icon="fa-times" invisible="state != 'pending'"/>
        </list>
    </field>
</record>

<!-- ══ Optimization Suggestion Form ════════════════════════════════════ -->
<record id="view_smart_ai_optimization_suggestion_form" model="ir.ui.view">
    <field name="name">smart.ai.optimization.suggestion.form</field>
    <field name="model">smart.ai.optimization.suggestion</field>
    <field name="arch" type="xml">
        <form string="Optimization Suggestion">
            <header>
                <button name="action_apply" type="object" string="Apply"
                        class="btn-primary" invisible="state != 'pending'"/>
                <button name="action_dismiss" type="object" string="Dismiss"
                        class="btn-secondary" invisible="state != 'pending'"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="pending,applied,dismissed"/>
            </header>
            <sheet>
                <group>
                    <group string="Suggestion">
                        <field name="name"/>
                        <field name="title"/>
                        <field name="project_id"/>
                        <field name="business_activity"/>
                        <field name="suggestion_type"/>
                        <field name="priority" widget="badge"
                               decoration-danger="priority=='high'"
                               decoration-warning="priority=='medium'"/>
                        <field name="confidence_score"/>
                        <field name="suggested_at"/>
                        <field name="risk_score_id"/>
                    </group>
                    <group string="Details">
                        <field name="description"    nolabel="1" string="Description"/>
                        <field name="expected_impact" nolabel="1" string="Expected Impact"/>
                        <field name="reason"         nolabel="1" string="AI Reasoning"/>
                    </group>
                </group>
                <group string="Audit Trail" invisible="state == 'pending'">
                    <group>
                        <field name="applied_by"    readonly="1"/>
                        <field name="applied_at"    readonly="1"/>
                    </group>
                    <group>
                        <field name="dismissed_by"  readonly="1"/>
                        <field name="dismissed_at"  readonly="1"/>
                    </group>
                </group>
            </sheet>
        </form>
    </field>
</record>

<!-- ══ Window action ════════════════════════════════════════════════════ -->
<record id="action_smart_ai_optimization" model="ir.actions.act_window">
    <field name="name">Optimization Suggestions</field>
    <field name="res_model">smart.ai.optimization.suggestion</field>
    <field name="view_mode">list,form</field>
</record>

</data>
</odoo>
