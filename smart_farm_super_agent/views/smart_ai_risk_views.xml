<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══ Risk Score List ══════════════════════════════════════════════════ -->
<record id="view_smart_ai_risk_score_list" model="ir.ui.view">
    <field name="name">smart.ai.risk.score.list</field>
    <field name="model">smart.ai.risk.score</field>
    <field name="arch" type="xml">
        <list string="AI Risk Scores"
              decoration-danger="status=='critical'"
              decoration-warning="status=='warning'"
              decoration-success="status=='healthy'">
            <field name="project_id"/>
            <field name="overall_risk_score" string="Risk %" widget="progressbar"
                   options="{'overflow_class': 'text-danger'}"/>
            <field name="status" widget="badge"
                   decoration-danger="status=='critical'"
                   decoration-warning="status=='warning'"
                   decoration-success="status=='healthy'"/>
            <field name="delay_risk"       string="Delay"    optional="show"/>
            <field name="cost_risk"        string="Cost"     optional="show"/>
            <field name="procurement_risk" string="Proc."    optional="show"/>
            <field name="execution_risk"   string="Exec."    optional="show"/>
            <field name="claim_risk"       string="Claims"   optional="show"/>
            <field name="triggered_rule_count" string="Rules"/>
            <field name="computed_at"      string="Computed" optional="show"/>
            <field name="state" widget="badge"
                   decoration-info="state=='open'"
                   decoration-warning="state=='acknowledged'"
                   decoration-success="state=='resolved'"/>
            <button name="action_acknowledge" type="object" string="Acknowledge"
                    icon="fa-check"
                    invisible="state != 'open'"/>
            <button name="action_resolve" type="object" string="Resolve"
                    icon="fa-check-circle"
                    invisible="state == 'resolved'"/>
        </list>
    </field>
</record>

<!-- ══ Risk Score Form ══════════════════════════════════════════════════ -->
<record id="view_smart_ai_risk_score_form" model="ir.ui.view">
    <field name="name">smart.ai.risk.score.form</field>
    <field name="model">smart.ai.risk.score</field>
    <field name="arch" type="xml">
        <form string="AI Risk Score">
            <header>
                <button name="action_acknowledge" type="object" string="Acknowledge"
                        class="btn-primary" invisible="state != 'open'"/>
                <button name="action_resolve" type="object" string="Resolve"
                        class="btn-primary" invisible="state == 'resolved'"/>
                <button name="action_recompute" type="object" string="Recompute AI"
                        class="btn-secondary"/>
                <field name="state" widget="statusbar"
                       statusbar_visible="open,acknowledged,resolved"/>
            </header>
            <sheet>

                <!-- Status banner -->
                <div class="alert alert-danger mb-3" invisible="status != 'critical'">
                    <strong><i class="fa fa-exclamation-circle me-2" title="Critical"/> CRITICAL RISK</strong>
                    — Overall score: <field name="overall_risk_score" nolabel="1" readonly="1"/>%
                    · <field name="triggered_rule_count" nolabel="1" readonly="1"/> rule(s) triggered
                </div>
                <div class="alert alert-warning mb-3" invisible="status != 'warning'">
                    <strong><i class="fa fa-exclamation-triangle me-2" title="Warning"/> WARNING</strong>
                    — Overall score: <field name="overall_risk_score" nolabel="1" readonly="1"/>%
                </div>
                <div class="alert alert-success mb-3" invisible="status != 'healthy'">
                    <strong><i class="fa fa-check-circle me-2" title="Healthy"/> HEALTHY</strong>
                    — All risk indicators within normal range.
                </div>

                <group>
                    <group string="Identity">
                        <field name="name"/>
                        <field name="project_id"/>
                        <field name="business_activity"/>
                        <field name="computed_at"/>
                    </group>
                    <group string="Overall">
                        <field name="overall_risk_score" widget="progressbar"/>
                        <field name="status" widget="badge"
                               decoration-danger="status=='critical'"
                               decoration-warning="status=='warning'"
                               decoration-success="status=='healthy'"/>
                    </group>
                </group>

                <group string="Risk Dimensions">
                    <group>
                        <field name="delay_risk"       widget="progressbar" string="Delay Risk"/>
                        <field name="cost_risk"        widget="progressbar" string="Cost Risk"/>
                        <field name="procurement_risk" widget="progressbar" string="Procurement Risk"/>
                    </group>
                    <group>
                        <field name="execution_risk"   widget="progressbar" string="Execution Risk"/>
                        <field name="claim_risk"       widget="progressbar" string="Claim Risk"/>
                        <field name="triggered_rule_ids" widget="many2many_tags"/>
                    </group>
                </group>

                <group string="Risk Reasons">
                    <field name="delay_reason"        nolabel="1" string="Delay"       placeholder="Delay reason..."/>
                    <field name="cost_reason"         nolabel="1" string="Cost"        placeholder="Cost reason..."/>
                    <field name="procurement_reason"  nolabel="1" string="Procurement" placeholder="Procurement reason..."/>
                    <field name="execution_reason"    nolabel="1" string="Execution"   placeholder="Execution reason..."/>
                    <field name="claim_reason"        nolabel="1" string="Claims"      placeholder="Claim reason..."/>
                </group>

                <group string="Audit Trail">
                    <group>
                        <field name="acknowledged_by" readonly="1"/>
                        <field name="acknowledged_at" readonly="1"/>
                    </group>
                    <group>
                        <field name="resolved_by"     readonly="1"/>
                        <field name="resolved_at"     readonly="1"/>
                    </group>
                </group>

            </sheet>
        </form>
    </field>
</record>

<!-- ══ Window action ════════════════════════════════════════════════════ -->
<record id="action_smart_ai_risk_score" model="ir.actions.act_window">
    <field name="name">AI Risk Scores</field>
    <field name="res_model">smart.ai.risk.score</field>
    <field name="view_mode">list,form</field>
</record>

</data>
</odoo>
