<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         farm.control.action — Form View Extension
         Adds: actuator_device_id field, resolution + online-check buttons,
               resolution log, skip-online-check option,
               actuator status indicator.
    ================================================================ -->
    <record id="view_farm_control_action_form_bridge" model="ir.ui.view">
        <field name="name">farm.control.action.form.bridge</field>
        <field name="model">farm.control.action</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_control_action_form"/>
        <field name="arch" type="xml">

            <!-- ── Add "Resolve Actuator" + "Skip Online Check" to header ─── -->
            <xpath expr="//header/button[@name='action_execute_now']" position="before">
                <button name="action_resolve_actuator"
                        string="Find Actuator"
                        type="object"
                        class="btn-secondary"
                        icon="fa-search"
                        invisible="actuator_device_id or state not in ('draft','queued')"
                        data-tooltip="Auto-resolve the best matching actuator device"/>
                <button name="action_skip_online_check"
                        string="Skip Online Check"
                        type="object"
                        class="btn-warning"
                        icon="fa-exclamation-triangle"
                        invisible="online_check_skipped or state not in ('draft','queued')"
                        groups="smart_farm_alandleeb.group_farm_manager"
                        data-tooltip="Allow execution even if the actuator reports offline"/>
            </xpath>

            <!-- ── Inject actuator device group inside the Target section ──── -->
            <!-- We look for the existing actuator_id field and insert after -->
            <xpath expr="//field[@name='actuator_id']" position="after">

                <!-- Divider -->
                <div class="o_horizontal_separator mt-2 mb-2">
                    <span class="text-muted">farm.actuator.device (new)</span>
                </div>

                <!-- Auto-resolved device field -->
                <field name="actuator_device_id"
                       options="{'no_create': True}"
                       string="Actuator Device"
                       help="Auto-resolved from action_type, farm, field, sensor."/>

                <!-- Device status badge -->
                <field name="actuator_device_status"
                       widget="badge"
                       string="Device Status"
                       readonly="1"
                       invisible="not actuator_device_id"
                       decoration-success="actuator_device_status == 'online'"
                       decoration-warning="actuator_device_status in ('offline','maintenance')"
                       decoration-danger="actuator_device_status == 'error'"
                       decoration-secondary="actuator_device_status == 'unknown'"/>

                <!-- Warning banner when device is not online -->
                <div class="alert alert-warning col-12 mt-1" role="alert"
                     invisible="not actuator_device_id or actuator_device_status == 'online'">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    Actuator is <b><field name="actuator_device_status" readonly="1" nolabel="1"/></b>.
                    Commands will be blocked until the device is online,
                    unless "Skip Online Check" is enabled.
                    <button name="action_skip_online_check" type="object"
                            string="Skip Online Check"
                            class="btn btn-sm btn-warning ms-2"
                            invisible="online_check_skipped"
                            groups="smart_farm_alandleeb.group_farm_manager"/>
                </div>

                <!-- Warning banner when NO device resolved -->
                <div class="alert alert-danger col-12 mt-1" role="alert"
                     invisible="actuator_device_id or not action_type">
                    <i class="fa fa-times-circle me-1"/>
                    No actuator device found for action <b><field name="action_type" readonly="1" nolabel="1"/></b>.
                    State is kept as <b>Draft</b> until a device is assigned.
                    <button name="action_resolve_actuator" type="object"
                            string="Try Again"
                            class="btn btn-sm btn-danger ms-2"/>
                </div>

                <!-- Online check skipped badge -->
                <div class="badge text-bg-warning mt-1"
                     invisible="not online_check_skipped">
                    <i class="fa fa-exclamation-triangle me-1"/>
                    Online check skipped — command will be sent regardless of device status.
                </div>

                <!-- Hidden fields needed by conditionals -->
                <field name="online_check_skipped" invisible="1"/>

            </xpath>

            <!-- ── Resolution log notebook page ─────────────────────────────── -->
            <xpath expr="//notebook" position="inside">
                <page string="Actuator Resolution" name="actuator_resolution"
                      invisible="not resolution_log">
                    <group>
                        <field name="resolution_log" readonly="1" nolabel="1"
                               widget="text"
                               placeholder="Resolution log appears here after auto-resolve..."/>
                        <field name="online_check_skipped"
                               string="Online Check Skipped"
                               readonly="1"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- ================================================================
         farm.control.action — List View Extension
         Adds actuator_device_id and its status as optional columns
    ================================================================ -->
    <record id="view_farm_control_action_list_bridge" model="ir.ui.view">
        <field name="name">farm.control.action.list.bridge</field>
        <field name="model">farm.control.action</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_control_action_list"/>
        <field name="arch" type="xml">
            <!-- Append after actuator_id column -->
            <xpath expr="//field[@name='actuator_id']" position="after">
                <field name="actuator_device_id"   optional="show" string="Device"/>
                <field name="actuator_device_status" optional="show" string="Device Status"
                       widget="badge"
                       decoration-success="actuator_device_status == 'online'"
                       decoration-warning="actuator_device_status in ('offline','maintenance')"
                       decoration-danger="actuator_device_status == 'error'"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         farm.decision — Form View Extension
         Adds Control Actions smart button + "Create Control Action" button
    ================================================================ -->
    <record id="view_farm_decision_form_control_bridge" model="ir.ui.view">
        <field name="name">farm.decision.form.control.bridge</field>
        <field name="model">farm.decision</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_decision_form"/>
        <field name="arch" type="xml">

            <!-- Add "Create Control Action" to header buttons -->
            <xpath expr="//button[@name='action_acknowledge']" position="before">
                <button name="action_create_control_action"
                        string="Create Control Action"
                        type="object"
                        class="btn-info"
                        icon="fa-bolt"
                        invisible="status in ('executed','dismissed') or not action_type"
                        data-tooltip="Create a control action with auto-resolved actuator device"/>
            </xpath>

            <!-- Add Control Actions smart button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_control_actions" type="object"
                        class="oe_stat_button" icon="fa-bolt"
                        invisible="control_action_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="control_action_count"/>
                        </span>
                        <span class="o_stat_text">Control Actions</span>
                    </div>
                </button>
            </xpath>

        </field>
    </record>

</odoo>
