<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         farm.actuator — Views
    ================================================================ -->
    <record id="view_farm_actuator_list" model="ir.ui.view">
        <field name="name">farm.actuator.list</field>
        <field name="model">farm.actuator</field>
        <field name="arch" type="xml">
            <list string="Actuators"
                  decoration-success="last_result == 'success'"
                  decoration-danger="last_result == 'failed'"
                  decoration-muted="not active">
                <field name="name"/>
                <field name="device_id"/>
                <field name="actuator_type"/>
                <field name="farm_id"/>
                <field name="field_id" optional="show"/>
                <field name="broker_id"/>
                <field name="mqtt_topic" optional="show"/>
                <field name="last_command" optional="show" string="Last Command"/>
                <field name="last_command_at" string="Last Sent"/>
                <field name="last_result" widget="badge"
                       decoration-success="last_result == 'success'"
                       decoration-danger="last_result == 'failed'"/>
                <field name="control_action_count" string="Actions"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_farm_actuator_form" model="ir.ui.view">
        <field name="name">farm.actuator.form</field>
        <field name="model">farm.actuator</field>
        <field name="arch" type="xml">
            <form string="Actuator Device">
                <header>
                    <field name="active" widget="boolean_button"
                           options="{'terminology': {'string_true': 'Active', 'string_false': 'Disabled'}}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_control_actions" type="object"
                                class="oe_stat_button" icon="fa-bolt"
                                invisible="control_action_count == 0">
                            <field name="control_action_count" widget="statinfo" string="Actions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Actuator name..."/></h1>
                        <h4 class="text-muted"><field name="device_id" placeholder="device-id"/></h4>
                    </div>
                    <group>
                        <group string="Device">
                            <field name="actuator_type"/>
                            <field name="farm_id"/>
                            <field name="field_id" domain="[('farm_id','=',farm_id)]"/>
                            <field name="broker_id"/>
                            <field name="mqtt_topic" readonly="1"/>
                        </group>
                        <group string="Last Status">
                            <field name="last_command"    readonly="1"/>
                            <field name="last_command_at" readonly="1"/>
                            <field name="last_result"     readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_farm_actuator_search" model="ir.ui.view">
        <field name="name">farm.actuator.search</field>
        <field name="model">farm.actuator</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="device_id"/>
                <field name="farm_id"/>
                <field name="actuator_type"/>
                <filter name="active"      string="Active"  domain="[('active','=',True)]"/>
                <filter name="last_failed" string="Last Failed" domain="[('last_result','=','failed')]"/>
                <group expand="0" string="Group By">
                    <filter name="g_farm" string="Farm" context="{'group_by':'farm_id'}"/>
                    <filter name="g_type" string="Type" context="{'group_by':'actuator_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_farm_actuator" model="ir.actions.act_window">
        <field name="name">Actuators</field>
        <field name="res_model">farm.actuator</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_farm_actuator_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register your first actuator device!</p>
            <p>Actuators receive MQTT commands from the decision engine.</p>
        </field>
    </record>

    <!-- ================================================================
         farm.actuator.mapping — Views
    ================================================================ -->
    <record id="view_farm_actuator_mapping_list" model="ir.ui.view">
        <field name="name">farm.actuator.mapping.list</field>
        <field name="model">farm.actuator.mapping</field>
        <field name="arch" type="xml">
            <list string="Actuator Mappings" editable="top"
                  decoration-muted="not active">
                <field name="farm_id"/>
                <field name="field_id" optional="show"/>
                <field name="action_type"/>
                <field name="actuator_device_id" optional="show" string="Device"/>
                <field name="actuator_id" optional="hide"/>
                <field name="execution_mode" widget="badge"
                       decoration-success="execution_mode == 'auto'"
                       decoration-warning="execution_mode == 'semi_auto'"
                       decoration-secondary="execution_mode == 'manual'"/>
                <field name="custom_payload" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_farm_actuator_mapping_form" model="ir.ui.view">
        <field name="name">farm.actuator.mapping.form</field>
        <field name="model">farm.actuator.mapping</field>
        <field name="arch" type="xml">
            <form string="Actuator Mapping">
                <sheet>
                    <group>
                        <group string="Scope">
                            <field name="farm_id"/>
                            <field name="field_id" domain="[('farm_id','=',farm_id)]"/>
                            <field name="active"/>
                        </group>
                        <group string="Routing">
                            <field name="action_type"/>
                            <field name="actuator_id"
                                   domain="[('farm_id','=',farm_id)]"/>
                            <field name="execution_mode"/>
                        </group>
                    </group>
                    <group string="Custom Payload (JSON — leave empty for default)">
                        <field name="custom_payload" nolabel="1"
                               placeholder='{"action":"cooling_on","value":1}'/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_farm_actuator_mapping" model="ir.actions.act_window">
        <field name="name">Actuator Mappings</field>
        <field name="res_model">farm.actuator.mapping</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No actuator mappings yet.</p>
            <p>Map each action type (e.g. cooling) to the physical actuator that should be triggered.</p>
        </field>
    </record>

    <!-- ================================================================
         farm.control.action — Kanban View
    ================================================================ -->
    <record id="view_farm_control_action_kanban" model="ir.ui.view">
        <field name="name">farm.control.action.kanban</field>
        <field name="model">farm.control.action</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false"
                    class="o_kanban_small_column"
                    group_delete="false" group_create="false">
                <field name="name"/>
                <field name="action_type"/>
                <field name="state"/>
                <field name="execution_mode"/>
                <field name="farm_id"/>
                <field name="actuator_device_id" string="Actuator Device"/>
                <field name="actuator_id" string="Legacy Actuator"/>
                <field name="sensor_id"/>
                <field name="result_message"/>
                <field name="executed_at"/>
                <field name="forced"/>
                <templates>
                    <t t-name="card">
                        <t t-set="strip_color"
                           t-value="{
                               'draft':     '#94a3b8',
                               'queued':    '#f59e0b',
                               'sent':      '#3b82f6',
                               'success':   '#16a34a',
                               'failed':    '#ef4444',
                               'cancelled': '#6b7280'
                           }[record.state.raw_value] or '#94a3b8'"/>
                        <div t-attf-style="border-left:4px solid #{strip_color};border-radius:6px;padding:12px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="fw-bold small" style="font-family:monospace" t-esc="record.name.value"/>
                                <span t-attf-class="badge {{ {
                                    'draft':'text-bg-secondary','queued':'text-bg-warning',
                                    'sent':'text-bg-primary','success':'text-bg-success',
                                    'failed':'text-bg-danger','cancelled':'text-bg-light'
                                }[record.state.raw_value] or 'text-bg-secondary' }}">
                                    <t t-esc="record.state.value"/>
                                </span>
                            </div>
                            <div class="mb-1">
                                <span class="badge text-bg-info" style="font-size:10px">
                                    <t t-esc="record.action_type.value"/>
                                </span>
                                <span class="badge text-bg-secondary ms-1" style="font-size:10px">
                                    <t t-esc="record.execution_mode.value"/>
                                </span>
                                <span class="badge text-bg-warning ms-1" style="font-size:10px"
                                      t-if="record.forced.raw_value">⚡ forced</span>
                            </div>
                            <div class="small text-muted">
                                <i class="fa fa-map-marker me-1"/>
                                <t t-esc="record.farm_id.value"/>
                            </div>
                            <div class="small text-muted" t-if="record.actuator_id.value">
                                <i class="fa fa-bolt me-1"/>
                                <t t-esc="record.actuator_id.value"/>
                            </div>
                            <div class="small mt-1" t-if="record.result_message.value"
                                 t-attf-style="color:#{strip_color}">
                                <t t-esc="record.result_message.value"/>
                            </div>
                            <div class="d-flex gap-1 mt-2" t-if="record.state.raw_value in ('draft','queued')">
                                <button name="action_execute_now" type="object"
                                        class="btn btn-sm btn-success flex-fill">
                                    ⚡ Execute
                                </button>
                                <button name="action_cancel" type="object"
                                        class="btn btn-sm btn-outline-secondary">
                                    ✕
                                </button>
                            </div>
                            <div class="mt-2" t-if="record.state.raw_value == 'failed'">
                                <button name="action_force_execute" type="object"
                                        class="btn btn-sm btn-warning w-100">
                                    ↺ Retry
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         farm.control.action — List View
    ================================================================ -->
    <record id="view_farm_control_action_list" model="ir.ui.view">
        <field name="name">farm.control.action.list</field>
        <field name="model">farm.control.action</field>
        <field name="arch" type="xml">
            <list string="Control Actions"
                  decoration-success="state == 'success'"
                  decoration-danger="state == 'failed'"
                  decoration-warning="state in ('draft','queued')"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="create_date" string="Created"/>
                <field name="farm_id"/>
                <field name="sensor_id"/>
                <field name="actuator_id"/>
                <field name="action_type"/>
                <field name="execution_mode" widget="badge"
                       decoration-success="execution_mode == 'auto'"
                       decoration-warning="execution_mode == 'semi_auto'"
                       decoration-secondary="execution_mode == 'manual'"/>
                <field name="retry_count" optional="show" string="Retries"/>
                <field name="state" widget="badge"
                       decoration-secondary="state == 'draft'"
                       decoration-warning="state == 'queued'"
                       decoration-primary="state == 'sent'"
                       decoration-success="state == 'success'"
                       decoration-danger="state == 'failed'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="executed_at"/>
                <field name="executed_by" widget="many2one_avatar_user" optional="show"/>
                <field name="forced" optional="show"/>
                <field name="result_message" optional="show"/>
                <button name="action_execute_now" type="object" string="Execute"
                        class="btn-sm btn-success" invisible="state not in ('draft','queued')"/>
                <button name="action_force_execute" type="object" string="Retry"
                        class="btn-sm btn-warning" invisible="state != 'failed'"/>
                                <button name="action_retry" type="object" string="↺ Retry" class="btn-warning" invisible="state not in (\'failed\',\'cancelled\')"/>
</list>
        </field>
    </record>

    <!-- ================================================================
         farm.control.action — Form View
    ================================================================ -->
    <record id="view_farm_control_action_form" model="ir.ui.view">
        <field name="name">farm.control.action.form</field>
        <field name="model">farm.control.action</field>
        <field name="arch" type="xml">
            <form string="Control Action">
                <header>
                    <button name="action_send_command"
                            string="⚡ Send Command"
                            type="object"
                            class="btn-primary"
                            icon="fa-bolt"
                            invisible="state not in ('draft','queued')"
                            data-tooltip="Auto-resolve actuator device, build payload, and publish MQTT command"/>
                    <button name="action_resolve_actuator_device"
                            string="🔍 Find Actuator"
                            type="object"
                            class="btn-secondary"
                            invisible="actuator_device_id or state not in ('draft','queued')"/>
                    <button name="action_execute_now" string="Execute (Legacy)"
                            type="object" class="btn-secondary"
                            invisible="state not in ('draft','queued')"/>
                    <button name="action_force_execute" string="↺ Force Re-execute"
                            type="object" class="btn-warning"
                            invisible="state not in ('success','failed')"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state not in ('draft','queued')"/>
                    <button name="action_reset_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('failed','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,queued,sent,success"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object"
                                class="oe_stat_button" icon="fa-list-alt"
                                invisible="log_count == 0">
                            <field name="log_count" widget="statinfo" string="Log Entries"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Result banner -->
                    <div class="alert alert-success mb-3" role="alert"
                         invisible="state != 'success'">
                        <i class="fa fa-check-circle me-1"/>
                        <strong>Success</strong>
                        <field name="result_message" readonly="1" nolabel="1"/>
                    </div>
                    <div class="alert alert-danger mb-3" role="alert"
                         invisible="state != 'failed'">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        <strong>Failed</strong>
                        <field name="result_message" readonly="1" nolabel="1"/>
                    </div>

                    <group>
                        <group string="Source">
                            <field name="decision_id"/>
                            <field name="sensor_id"  readonly="1"/>
                            <field name="farm_id"    readonly="1"/>
                            <field name="field_id"   readonly="1"/>
                            <field name="task_id"    readonly="1"/>
                        </group>
                        <group string="Target">
                            <!-- farm.actuator.device (new integration) -->
                            <field name="actuator_device_id"
                                   options="{'no_create': True}"
                                   string="Actuator Device"
                                   help="Auto-resolved from action_type, farm, field, and sensor"/>
                            <!-- Warning banner when no device found -->
                            <div class="alert alert-warning mb-0 col-12" role="alert"
                                 invisible="not no_actuator_warning">
                                <i class="fa fa-exclamation-triangle me-1"/>
                                <field name="no_actuator_warning" readonly="1" nolabel="1"
                                       class="d-inline"/>
                                <button name="action_resolve_actuator_device"
                                        type="object"
                                        string="Find Actuator"
                                        class="btn btn-sm btn-warning ms-2"/>
                            </div>
                            <!-- Legacy farm.actuator linkage -->
                            <field name="actuator_id" optional="show" string="Legacy Actuator"/>
                            <field name="broker_id"    readonly="1"/>
                            <field name="topic"        readonly="1"/>
                            <field name="device_target" optional="show"/>
                        </group>
                    </group>
                    <group>
                        <group string="Action">
                            <field name="action_type"/>
                            <field name="execution_mode"/>
                            <field name="forced" readonly="1"/>
                        </group>
                        <group string="Execution">
                            <field name="executed_at" readonly="1"/>
                            <field name="executed_by" readonly="1" widget="many2one_avatar_user"/>
                        </group>
                    </group>
                    <group string="Command Payload">
                        <group string="Auto-Built Preview" col="1">
                            <field name="send_command_payload" readonly="1" nolabel="1"
                                   widget="text" style="font-family:monospace;font-size:11px;color:#1e3a5f"/>
                        </group>
                        <group string="Custom Override (optional)" col="1">
                            <field name="command_payload" nolabel="1"
                                   placeholder='{"action":"cooling_on","value":1} — leave empty to use auto-built payload'/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Execution Log" name="log">
                            <field name="log_ids" readonly="1">
                                <list create="0">
                                    <field name="create_date" string="Time"/>
                                    <field name="method"/>
                                    <field name="success" widget="boolean"/>
                                    <field name="message"/>
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                    <field name="payload" optional="hide"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================
         farm.control.action — Search View
    ================================================================ -->
    <record id="view_farm_control_action_search" model="ir.ui.view">
        <field name="name">farm.control.action.search</field>
        <field name="model">farm.control.action</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="farm_id"/>
                <field name="actuator_id"/>
                <field name="action_type"/>
                <filter name="draft"     string="Draft"   domain="[('state','=','draft')]"/>
                <filter name="queued"    string="Queued"  domain="[('state','=','queued')]"/>
                <filter name="success"   string="Success" domain="[('state','=','success')]"/>
                <filter name="failed"    string="Failed"  domain="[('state','=','failed')]"/>
                <filter name="active_actions" string="Active"
                        domain="[('state','in',('draft','queued','sent'))]"/>
                <filter name="today" string="Today"
                        domain="[('create_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="auto" string="Auto" domain="[('execution_mode','=','auto')]"/>
                <filter name="forced" string="Forced" domain="[('forced','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="g_farm"   string="Farm"       context="{'group_by':'farm_id'}"/>
                    <filter name="g_action" string="Action"     context="{'group_by':'action_type'}"/>
                    <filter name="g_state"  string="State"      context="{'group_by':'state'}"/>
                    <filter name="g_mode"   string="Mode"       context="{'group_by':'execution_mode'}"/>
                    <filter name="g_day"    string="Day"        context="{'group_by':'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         farm.control.action — Actions
    ================================================================ -->
    <record id="action_farm_control_action" model="ir.actions.act_window">
        <field name="name">Control Actions</field>
        <field name="res_model">farm.control.action</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_farm_control_action_search"/>
        <field name="context">{'search_default_active_actions': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No control actions yet.</p>
            <p>Control actions are created from decisions and send MQTT commands to actuators.</p>
        </field>
    </record>

    <!-- ================================================================
         farm.decision form — Add "Execute Action" button + smart button
         (inherits the existing decision form view)
    ================================================================ -->
    <record id="view_farm_decision_control_btn" model="ir.ui.view">
        <field name="name">farm.decision.form.control.btn</field>
        <field name="model">farm.decision</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_decision_form"/>
        <field name="arch" type="xml">

            <!-- Button in header: "Execute Action" -->
            <xpath expr="//header/button[@name='action_acknowledge']" position="before">
                <button name="action_create_and_execute"
                        string="⚡ Execute Action"
                        type="object"
                        class="btn-danger"
                        invisible="status in ('executed','dismissed') or action_type == 'alert_only'"
                        data-tooltip="Create and execute a control action for this decision"/>
            </xpath>

            <!-- Smart button in button_box -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_control_actions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-bolt"
                        invisible="control_action_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="control_action_count"/>
                        </span>
                        <span class="o_stat_text">Actions</span>
                    </div>
                </button>
                <field name="has_active_action" invisible="1"/>
            </xpath>

        </field>
    </record>

    <!-- ================================================================
         farm.sensor form — Control Actions smart button
    ================================================================ -->
    <record id="view_farm_sensor_form_control_btn" model="ir.ui.view">
        <field name="name">farm.sensor.form.control.btn</field>
        <field name="model">farm.sensor</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_sensor_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sensor_control_actions"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-bolt"
                        invisible="sensor_control_action_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="sensor_control_action_count"/>
                        </span>
                        <span class="o_stat_text">Actions</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
