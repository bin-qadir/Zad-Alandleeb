<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         farm.mqtt.publish.log — List View
    ================================================================ -->
    <record id="view_farm_mqtt_publish_log_list" model="ir.ui.view">
        <field name="name">farm.mqtt.publish.log.list</field>
        <field name="model">farm.mqtt.publish.log</field>
        <field name="arch" type="xml">
            <list string="MQTT Publish Log" create="0" edit="0"
                  decoration-success="success"
                  decoration-danger="not success">
                <field name="create_date"  string="Time"/>
                <field name="broker_id"    optional="show"/>
                <field name="topic"/>
                <field name="qos"          optional="show"/>
                <field name="message_id"   optional="show" string="MID"/>
                <field name="source_model" optional="show"/>
                <field name="sent_by"      widget="many2one_avatar_user" optional="show"/>
                <field name="success"      widget="boolean" string="OK"/>
                <field name="confirmed"    widget="boolean" string="ACK"
                       optional="show"/>
                <field name="rc"           optional="show" string="RC"/>
                <field name="duration_ms"  optional="show" string="ms"
                       widget="float" digits="[8,1]"/>
                <field name="message"      string="Result"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         farm.mqtt.publish.log — Form View
    ================================================================ -->
    <record id="view_farm_mqtt_publish_log_form" model="ir.ui.view">
        <field name="name">farm.mqtt.publish.log.form</field>
        <field name="model">farm.mqtt.publish.log</field>
        <field name="arch" type="xml">
            <form string="MQTT Publish Log Entry" create="0">
                <sheet>
                    <!-- Outcome banner -->
                    <div t-attf-class="alert {{ record.success ? 'alert-success' : 'alert-danger' }} mb-3"
                         role="alert">
                        <b t-if="success">✓ Published successfully</b>
                        <b t-else="">✗ Publish failed</b>
                        — <field name="message" readonly="1" nolabel="1"/>
                    </div>
                    <group>
                        <group string="Destination">
                            <field name="broker_id" readonly="1"/>
                            <field name="topic"     readonly="1"/>
                            <field name="qos"       readonly="1"/>
                            <field name="retain"    readonly="1"/>
                        </group>
                        <group string="Outcome">
                            <field name="success"    readonly="1"/>
                            <field name="confirmed"  readonly="1"/>
                            <field name="rc"         readonly="1"/>
                            <field name="message_id" readonly="1" string="MQTT MID"/>
                            <field name="duration_ms" readonly="1"/>
                        </group>
                    </group>
                    <group string="Source">
                        <group>
                            <field name="source_model" readonly="1"/>
                            <field name="source_id"    readonly="1"/>
                            <field name="sent_by"      readonly="1"/>
                        </group>
                    </group>
                    <group string="Payload">
                        <field name="payload" readonly="1" nolabel="1"
                               widget="code"
                               options="{'mode': 'json'}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ================================================================
         farm.mqtt.publish.log — Search View
    ================================================================ -->
    <record id="view_farm_mqtt_publish_log_search" model="ir.ui.view">
        <field name="name">farm.mqtt.publish.log.search</field>
        <field name="model">farm.mqtt.publish.log</field>
        <field name="arch" type="xml">
            <search string="Search Publish Log">
                <field name="topic"/>
                <field name="broker_id"/>
                <field name="source_model"/>
                <filter name="success" string="Success"   domain="[('success','=',True)]"/>
                <filter name="failed"  string="Failed"    domain="[('success','=',False)]"/>
                <filter name="unconfirmed" string="No ACK"
                        domain="[('confirmed','=',False),('success','=',True),('qos','>',0)]"/>
                <filter name="today"   string="Today"
                        domain="[('create_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter name="g_broker" string="Broker"
                            context="{'group_by':'broker_id'}"/>
                    <filter name="g_topic"  string="Topic"
                            context="{'group_by':'topic'}"/>
                    <filter name="g_source" string="Source Model"
                            context="{'group_by':'source_model'}"/>
                    <filter name="g_day"    string="Day"
                            context="{'group_by':'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         farm.mqtt.publish.log — Action
    ================================================================ -->
    <record id="action_farm_mqtt_publish_log" model="ir.actions.act_window">
        <field name="name">MQTT Publish Log</field>
        <field name="res_model">farm.mqtt.publish.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_farm_mqtt_publish_log_search"/>
        <field name="context">{'search_default_today': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No MQTT publish attempts yet.</p>
            <p>Every command published to an actuator is logged here
               with its delivery confirmation status.</p>
        </field>
    </record>

    <!-- ================================================================
         farm.control.action form — show publish log count
    ================================================================ -->
    <record id="view_control_action_publish_log_btn" model="ir.ui.view">
        <field name="name">farm.control.action.form.publish.log.btn</field>
        <field name="model">farm.control.action</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_control_action_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_mqtt_publish_logs" type="object"
                        class="oe_stat_button" icon="fa-paper-plane"
                        invisible="mqtt_publish_log_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="mqtt_publish_log_count"/>
                        </span>
                        <span class="o_stat_text">MQTT Logs</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
