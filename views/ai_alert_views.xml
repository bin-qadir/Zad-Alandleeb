<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_ai_alert_list" model="ir.ui.view">
        <field name="name">task.ai.alert.list</field>
        <field name="model">task.ai.alert</field>
        <field name="arch" type="xml">
            <list string="AI Alerts" default_order="create_date desc">
                <field name="name"/>
                <field name="alert_type"/>
                <field name="severity"/>
                <field name="state"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="boq_line_id"/>
                <field name="assigned_user_id"/>
                <field name="resolved_by" optional="show"/>
                <field name="resolved_date" optional="show"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_task_ai_alert_search" model="ir.ui.view">
        <field name="name">task.ai.alert.search</field>
        <field name="model">task.ai.alert</field>
        <field name="arch" type="xml">
            <search string="Search AI Alerts">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="boq_line_id"/>
                <field name="alert_type"/>
                <field name="severity"/>
                <field name="state"/>
                <field name="assigned_user_id"/>

                <filter string="Open Alerts" name="open_alerts" domain="[('state', 'in', ['new', 'open', 'in_progress'])]"/>
                <filter string="Critical" name="critical" domain="[('severity', '=', 'critical')]"/>
                <filter string="High" name="high" domain="[('severity', '=', 'high')]"/>
                <filter string="Resolved" name="resolved" domain="[('state', '=', 'resolved')]"/>
            </search>
        </field>
    </record>

    <record id="view_task_ai_alert_form" model="ir.ui.view">
        <field name="name">task.ai.alert.form</field>
        <field name="model">task.ai.alert</field>
        <field name="arch" type="xml">
            <form string="AI Alert">
                <header>
                    <button name="action_open" type="object" string="Open" invisible="state not in ('new',)"/>
                    <button name="action_start_progress" type="object" string="Start Progress" class="btn-primary" invisible="state not in ('new', 'open')"/>
                    <button name="action_resolve" type="object" string="Resolve" class="btn-success" invisible="state in ('resolved', 'ignored')"/>
                    <button name="action_ignore" type="object" string="Ignore" invisible="state in ('resolved', 'ignored')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,open,in_progress,resolved,ignored"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="alert_type"/>
                            <field name="severity"/>
                            <field name="assigned_user_id"/>
                            <field name="project_id"/>
                        </group>
                        <group>
                            <field name="task_id"/>
                            <field name="boq_line_id"/>
                            <field name="company_id" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description"/>
                        <field name="reason"/>
                        <field name="recommendation"/>
                        <field name="action_taken"/>
                    </group>
                    <group>
                        <field name="resolved_by" readonly="1"/>
                        <field name="resolved_date" readonly="1"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_task_ai_alert" model="ir.actions.act_window">
        <field name="name">AI Alerts</field>
        <field name="res_model">task.ai.alert</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_task_ai_alert_search"/>
    </record>

</odoo>
