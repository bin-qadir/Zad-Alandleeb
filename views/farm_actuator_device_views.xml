<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         farm.actuator.action.type — List (configuration table)
    ================================================================ -->
    <record id="view_farm_actuator_action_type_list" model="ir.ui.view">
        <field name="name">farm.actuator.action.type.list</field>
        <field name="model">farm.actuator.action.type</field>
        <field name="arch" type="xml">
            <list string="Action Types" editable="top">
                <field name="sequence" widget="handle"/>
                <field name="key"/>
                <field name="name"/>
                <field name="icon"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="action_farm_actuator_action_type" model="ir.actions.act_window">
        <field name="name">Actuator Action Types</field>
        <field name="res_model">farm.actuator.action.type</field>
        <field name="view_mode">list</field>
    </record>

    <!-- ================================================================
         farm.actuator.device — TREE / LIST View
         Columns: name, actuator_id, sensor_id, farm_id, field_id,
                  broker_id, status, last_seen, active
         Color rows by status
    ================================================================ -->
    <record id="view_farm_actuator_device_list" model="ir.ui.view">
        <field name="name">farm.actuator.device.list</field>
        <field name="model">farm.actuator.device</field>
        <field name="arch" type="xml">
            <list string="Actuator Devices"
                  decoration-success="status in ('online')"
                  decoration-warning="status in ('offline','maintenance')"
                  decoration-danger="status == 'error'"
                  decoration-muted="status == 'unknown' or not active">
                <field name="name"/>
                <field name="actuator_id"  string="Device ID"/>
                <field name="actuator_type"/>
                <field name="sensor_id"    string="Sensor"/>
                <field name="farm_id"/>
                <field name="field_id"     optional="show"/>
                <field name="broker_id"/>
                <field name="command_topic" optional="show"/>
                <field name="supported_action_keys" string="Actions" optional="show"/>
                <field name="last_seen"/>
                <field name="last_command"    optional="show"/>
                <field name="last_result"     optional="show" widget="badge"
                       decoration-success="last_result == 'success'"
                       decoration-danger="last_result == 'failed'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'online'"
                       decoration-warning="status in ('offline','maintenance')"
                       decoration-danger="status == 'error'"
                       decoration-secondary="status == 'unknown'"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         farm.actuator.device — KANBAN View
         Grouped by status; left border color-coded
    ================================================================ -->
    <record id="view_farm_actuator_device_kanban" model="ir.ui.view">
        <field name="name">farm.actuator.device.kanban</field>
        <field name="model">farm.actuator.device</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status" quick_create="false"
                    class="o_kanban_small_column"
                    group_delete="false" group_create="false">
                <field name="name"/>
                <field name="actuator_id"/>
                <field name="actuator_type"/>
                <field name="status"/>
                <field name="farm_id"/>
                <field name="field_id"/>
                <field name="sensor_id"/>
                <field name="broker_id"/>
                <field name="last_seen"/>
                <field name="last_command"/>
                <field name="last_result"/>
                <field name="command_topic"/>
                <field name="supported_action_keys"/>
                <field name="command_count"/>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <t t-set="border"
                           t-value="{
                               'online':      '#16a34a',
                               'offline':     '#94a3b8',
                               'maintenance': '#f59e0b',
                               'error':       '#ef4444',
                               'unknown':     '#cbd5e1'
                           }[record.status.raw_value] or '#cbd5e1'"/>
                        <div t-attf-style="border-left:4px solid #{border};border-radius:6px;padding:12px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);">

                            <!-- Name + status badge -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <span class="fw-bold text-truncate" style="font-size:13px"
                                      t-esc="record.name.value"/>
                                <span t-attf-class="badge {{
                                    record.status.raw_value == 'online'      ? 'text-bg-success'   :
                                    record.status.raw_value == 'offline'     ? 'text-bg-secondary' :
                                    record.status.raw_value == 'maintenance' ? 'text-bg-warning'   :
                                    record.status.raw_value == 'error'       ? 'text-bg-danger'    :
                                    'text-bg-light'
                                }}" style="font-size:10px;white-space:nowrap">
                                    <t t-esc="record.status.value"/>
                                </span>
                            </div>

                            <!-- Device ID -->
                            <div class="small text-muted mb-1">
                                <i class="fa fa-microchip me-1"/>
                                <code style="font-size:11px" t-esc="record.actuator_id.value"/>
                            </div>

                            <!-- Type badge -->
                            <div class="mb-2">
                                <span class="badge text-bg-light" style="font-size:10px">
                                    <t t-esc="record.actuator_type.value"/>
                                </span>
                            </div>

                            <!-- Supported actions -->
                            <div class="mb-2" t-if="record.supported_action_keys.value">
                                <t t-foreach="record.supported_action_keys.value.split(',')"
                                   t-as="a" t-key="a_index">
                                    <span class="badge text-bg-info me-1" style="font-size:10px">
                                        <t t-esc="a.trim()"/>
                                    </span>
                                </t>
                            </div>

                            <!-- Farm / Field -->
                            <div class="small text-muted">
                                <i class="fa fa-map-marker me-1"/>
                                <t t-esc="record.farm_id.value"/>
                                <t t-if="record.field_id.value">
                                    / <t t-esc="record.field_id.value"/>
                                </t>
                            </div>

                            <!-- Sensor -->
                            <div class="small text-muted" t-if="record.sensor_id.value">
                                <i class="fa fa-thermometer-half me-1"/>
                                <t t-esc="record.sensor_id.value"/>
                            </div>

                            <!-- Broker -->
                            <div class="small text-muted">
                                <i class="fa fa-server me-1"/>
                                <t t-esc="record.broker_id.value"/>
                            </div>

                            <!-- Last command -->
                            <div class="small mt-2" t-if="record.last_command.value">
                                <span class="text-muted">Last: </span>
                                <span t-attf-class="badge {{
                                    record.last_result.raw_value == 'success' ? 'text-bg-success' :
                                    record.last_result.raw_value == 'failed'  ? 'text-bg-danger'  :
                                    'text-bg-secondary'
                                }}" style="font-size:10px">
                                    <t t-esc="record.last_command.value"/>
                                </span>
                            </div>

                            <!-- Last seen -->
                            <div class="small text-muted mt-1" t-if="record.last_seen.value">
                                <i class="fa fa-clock-o me-1"/>
                                <t t-esc="record.last_seen.value"/>
                            </div>

                            <!-- Commands badge -->
                            <div class="mt-2" t-if="record.command_count.raw_value > 0">
                                <span class="badge text-bg-light" style="font-size:10px">
                                    <i class="fa fa-bolt me-1"/>
                                    <t t-esc="record.command_count.value"/> cmds
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         farm.actuator.device — FORM View
         Sections: General Info | Mapping | MQTT Configuration | Status/Notes
    ================================================================ -->
    <record id="view_farm_actuator_device_form" model="ir.ui.view">
        <field name="name">farm.actuator.device.form</field>
        <field name="model">farm.actuator.device</field>
        <field name="arch" type="xml">
            <form string="Actuator Device">
                <header>
                    <button name="action_test_command"    string="Send Test Ping"
                            type="object" class="btn-secondary" icon="fa-bolt"/>
                    <button name="action_mark_online"     string="Mark Online"
                            type="object" class="btn-success"
                            invisible="status == 'online'"/>
                    <button name="action_mark_offline"    string="Mark Offline"
                            type="object" class="btn-warning"
                            invisible="status == 'offline'"/>
                    <button name="action_mark_maintenance" string="Maintenance"
                            type="object"
                            invisible="status == 'maintenance'"/>
                    <field name="active" widget="boolean_button"
                           options="{'terminology': {
                               'string_true':  'Active',
                               'string_false': 'Disabled',
                               'hover_true':   'Disable device',
                               'hover_false':  'Activate device'
                           }}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_command_log" type="object"
                                class="oe_stat_button" icon="fa-bolt">
                            <field name="command_count" widget="statinfo" string="Commands"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Actuator name..."/></h1>
                        <h4 class="text-muted">
                            <i class="fa fa-microchip me-1"/>
                            <field name="actuator_id" placeholder="unique-device-id"/>
                        </h4>
                    </div>

                    <!-- Section: General Info -->
                    <group string="General Info">
                        <group>
                            <field name="actuator_type"/>
                        </group>
                        <group>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <!-- Section: Mapping (sensor / location / actions) -->
                    <group string="Mapping">
                        <group string="Location">
                            <field name="sensor_id"
                                   options="{'no_create': True}"
                                   help="Link to the sensor that drives this actuator"/>
                            <field name="farm_id"  options="{'no_create': True}"/>
                            <field name="field_id" domain="[('farm_id','=',farm_id)]"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Supported Actions">
                            <field name="supported_actions" widget="many2many_tags"
                                   nolabel="1" options="{'no_create': True}"/>
                            <field name="supported_action_keys" string="Keys (auto)"
                                   readonly="1"/>
                        </group>
                    </group>

                    <!-- Section: MQTT Configuration -->
                    <group string="MQTT Configuration">
                        <group>
                            <field name="broker_id"/>
                            <field name="command_topic"/>
                        </group>
                        <group>
                            <field name="command_qos"/>
                            <field name="command_retain"/>
                        </group>
                        <div class="alert alert-info col-12" role="alert" style="margin-top:4px">
                            <b>Topic pattern:</b>
                            <code>farm/actuators/&lt;actuator_id&gt;/set</code> |
                            <b>Payload example:</b>
                            <code>{"action":"cooling_on","device_id":"fan01","source":"odoo_smartfarm"}</code>
                        </div>
                    </group>

                    <!-- Section: Status / Notes -->
                    <group string="Status">
                        <group>
                            <field name="status" readonly="1"/>
                            <field name="last_seen" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_command"    readonly="1"/>
                            <field name="last_command_at" readonly="1"/>
                            <field name="last_result"     readonly="1" widget="badge"
                                   decoration-success="last_result == 'success'"
                                   decoration-danger="last_result == 'failed'"/>
                        </group>
                    </group>

                    <group string="Notes">
                        <field name="notes" nolabel="1"
                               placeholder="Maintenance notes, location details, wiring info..."/>
                    </group>

                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================
         farm.actuator.device — SEARCH View
         Filters: online, offline, maintenance, active
    ================================================================ -->
    <record id="view_farm_actuator_device_search" model="ir.ui.view">
        <field name="name">farm.actuator.device.search</field>
        <field name="model">farm.actuator.device</field>
        <field name="arch" type="xml">
            <search string="Search Actuators">
                <field name="name"/>
                <field name="actuator_id"/>
                <field name="farm_id"/>
                <field name="field_id"/>
                <field name="sensor_id"/>
                <field name="broker_id"/>

                <!-- Status filters -->
                <filter name="online"      string="Online"      domain="[('status','=','online')]"/>
                <filter name="offline"     string="Offline"     domain="[('status','=','offline')]"/>
                <filter name="maintenance" string="Maintenance" domain="[('status','=','maintenance')]"/>
                <filter name="error"       string="Error"       domain="[('status','=','error')]"/>
                <separator/>
                <filter name="active"      string="Active"      domain="[('active','=',True)]"/>
                <filter name="inactive"    string="Inactive"    domain="[('active','=',False)]"/>
                <separator/>

                <!-- Action type quick filters -->
                <filter name="cooling"    string="Cooling"    domain="[('supported_action_keys','like','cooling')]"/>
                <filter name="irrigation" string="Irrigation" domain="[('supported_action_keys','like','irrigation')]"/>
                <filter name="co2"        string="CO₂"        domain="[('supported_action_keys','like','co2_inject')]"/>

                <group expand="0" string="Group By">
                    <filter name="g_farm"   string="Farm"    context="{'group_by':'farm_id'}"/>
                    <filter name="g_type"   string="Type"    context="{'group_by':'actuator_type'}"/>
                    <filter name="g_status" string="Status"  context="{'group_by':'status'}"/>
                    <filter name="g_broker" string="Broker"  context="{'group_by':'broker_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         farm.actuator.device — Actions
    ================================================================ -->
    <record id="action_farm_actuator_device" model="ir.actions.act_window">
        <field name="name">Actuator Devices</field>
        <field name="res_model">farm.actuator.device</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_farm_actuator_device_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first actuator device!
            </p>
            <p>Actuators are physical devices — fans, pumps, valves, CO₂ controllers —
               that receive MQTT commands when decisions are executed.</p>
        </field>
    </record>

    <!-- ================================================================
         farm.actuator.command.log — List View + Action
    ================================================================ -->
    <record id="view_farm_actuator_command_log_list" model="ir.ui.view">
        <field name="name">farm.actuator.command.log.list</field>
        <field name="model">farm.actuator.command.log</field>
        <field name="arch" type="xml">
            <list string="Actuator Commands" create="0" edit="0"
                  decoration-success="status in ('sent','acked')"
                  decoration-danger="status == 'failed'"
                  decoration-warning="status == 'timeout'">
                <field name="create_date"      string="Sent At"/>
                <field name="actuator_device_id"/>
                <field name="farm_id"          optional="show"/>
                <field name="field_id"         optional="show"/>
                <field name="action_type"/>
                <field name="command_topic"    optional="show"/>
                <field name="sent_by"          widget="many2one_avatar_user" optional="show"/>
                <field name="decision_id"      optional="show"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('sent','acked')"
                       decoration-danger="status == 'failed'"
                       decoration-warning="status == 'timeout'"/>
                <field name="error_message"    optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_farm_actuator_command_log_search" model="ir.ui.view">
        <field name="name">farm.actuator.command.log.search</field>
        <field name="model">farm.actuator.command.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="actuator_device_id"/>
                <field name="farm_id"/>
                <field name="action_type"/>
                <filter name="sent"   string="Sent"   domain="[('status','=','sent')]"/>
                <filter name="failed" string="Failed" domain="[('status','=','failed')]"/>
                <filter name="today"  string="Today"
                        domain="[('create_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <group expand="0" string="Group By">
                    <filter name="g_actuator" string="Actuator"
                            context="{'group_by':'actuator_device_id'}"/>
                    <filter name="g_action"   string="Action Type"
                            context="{'group_by':'action_type'}"/>
                    <filter name="g_status"   string="Status"
                            context="{'group_by':'status'}"/>
                    <filter name="g_day"      string="Day"
                            context="{'group_by':'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_farm_actuator_command_log" model="ir.actions.act_window">
        <field name="name">Actuator Command Log</field>
        <field name="res_model">farm.actuator.command.log</field>
        <field name="view_mode">list</field>
        <field name="search_view_id" ref="view_farm_actuator_command_log_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>

    <!-- ================================================================
         farm.decision form — inherited: Execute via Actuator button
    ================================================================ -->
    <record id="view_farm_decision_form_actuator_btn" model="ir.ui.view">
        <field name="name">farm.decision.form.actuator.btn</field>
        <field name="model">farm.decision</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_decision_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_execute']" position="before">
                <button name="action_execute_via_actuator"
                        string="Execute via Actuator"
                        type="object"
                        class="btn-primary"
                        icon="fa-bolt"
                        invisible="status not in ('pending','acknowledged') or not actuator_device_id"/>
            </xpath>
            <xpath expr="//field[@name='rule_id']" position="after">
                <field name="actuator_device_id" options="{'no_create': True}"/>
                <field name="actuator_command_count" readonly="1"
                       invisible="actuator_command_count == 0"
                       string="Commands Sent"/>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         farm.sensor form — inherited: Actuators smart button
    ================================================================ -->
    <record id="view_farm_sensor_form_actuator_btn" model="ir.ui.view">
        <field name="name">farm.sensor.form.actuator.btn</field>
        <field name="model">farm.sensor</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_sensor_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_actuator_devices" type="object"
                        class="oe_stat_button" icon="fa-cogs"
                        invisible="actuator_device_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="actuator_device_count"/>
                        </span>
                        <span class="o_stat_text">Actuators</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
