<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_task_boq_line_list" model="ir.ui.view">
        <field name="name">task.boq.line.list</field>
        <field name="model">task.boq.line</field>
        <field name="arch" type="xml">
            <list string="BOQ Lines" default_order="sequence asc, id asc">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="division" optional="show"/>
                <field name="subdivision" optional="show"/>
                <field name="qty"/>
                <field name="product_uom_id" optional="show"/>
                <field name="material_cost" sum="Total"/>
                <field name="labor_cost" sum="Total"/>
                <field name="overhead_cost" sum="Total"/>
                <field name="total_cost" sum="Total"/>
                <field name="sale_price_unit" optional="show"/>
                <field name="sale_total" sum="Total"/>
                <field name="profit_amount" sum="Total"/>
                <field name="profit_percent" optional="show"/>
                <field name="procurement_state"/>
                <field name="execution_state"/>
                <field name="over_budget" optional="show"/>
                <field name="delayed_flag" optional="show"/>
                <field name="is_loss_line" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_task_boq_line_search" model="ir.ui.view">
        <field name="name">task.boq.line.search</field>
        <field name="model">task.boq.line</field>
        <field name="arch" type="xml">
            <search string="Search BOQ Lines">
                <field name="name"/>
                <field name="project_id"/>
                <field name="task_id"/>
                <field name="division"/>
                <field name="procurement_state"/>
                <field name="execution_state"/>

                <filter string="Loss Lines" name="loss_lines" domain="[('is_loss_line', '=', True)]"/>
                <filter string="Over Budget" name="over_budget" domain="[('over_budget', '=', True)]"/>
                <filter string="Delayed" name="delayed_flag" domain="[('delayed_flag', '=', True)]"/>
                <filter string="Need Review" name="need_review" domain="[('need_review', '=', True)]"/>

                <group expand="0" string="Group By">
                    <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    <filter string="Task" name="group_task" context="{'group_by': 'task_id'}"/>
                    <filter string="Division" name="group_division" context="{'group_by': 'division'}"/>
                    <filter string="Procurement Status" name="group_procurement" context="{'group_by': 'procurement_state'}"/>
                    <filter string="Execution Status" name="group_execution" context="{'group_by': 'execution_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_task_boq_line_form" model="ir.ui.view">
        <field name="name">task.boq.line.form</field>
        <field name="model">task.boq.line</field>
        <field name="arch" type="xml">
            <form string="BOQ Line">
                <header>
                    <button name="action_set_draft" type="object" string="Set Draft" invisible="execution_state == 'draft'"/>
                    <button name="action_submit_review" type="object" string="Submit Review" class="btn-primary" invisible="execution_state not in ('draft', 'cancel')"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" invisible="execution_state != 'review'"/>
                    <button name="action_start" type="object" string="Start" invisible="execution_state not in ('approved', 'review')"/>
                    <button name="action_done" type="object" string="Mark Done" class="btn-success" invisible="execution_state != 'in_progress'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="execution_state in ('done', 'cancel')"/>

                    <button name="action_create_rfq" type="object" string="Create RFQ" class="btn-primary" invisible="execution_state == 'cancel'"/>
                    <button name="action_open_purchase_orders" type="object" string="Open Purchase Orders" invisible="purchase_order_link_count == 0"/>
                    <button name="action_create_quotation" type="object" string="Create Quotation" class="btn-primary" invisible="sale_order_id != False"/>

                    <field name="execution_state" widget="statusbar" statusbar_visible="draft,review,approved,in_progress,done,cancel"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_alerts" class="oe_stat_button" icon="fa-exclamation-triangle">
                            <field name="alert_count" widget="statinfo" string="AI Alerts"/>
                        </button>
                        <button type="object" name="action_open_purchase_lines" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                        </button>
                        <button type="object" name="action_open_purchase_orders" class="oe_stat_button" icon="fa-truck">
                            <field name="purchase_order_link_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                        <button type="object" name="action_open_sale_lines" class="oe_stat_button" icon="fa-line-chart">
                            <field name="sale_order_line_count" widget="statinfo" string="Sale Lines"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1><field name="name" placeholder="BOQ description..."/></h1>
                    </div>

                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="project_id"/>
                            <field name="task_id" domain="[('project_id', '=', project_id)]"/>
                            <field name="division"/>
                            <field name="subdivision"/>
                        </group>
                        <group>
                            <field name="qty"/>
                            <field name="product_uom_id"/>
                            <field name="planned_hours"/>
                            <field name="effective_hours" readonly="1"/>
                            <field name="procurement_state"/>
                            <field name="need_review"/>
                        </group>
                    </group>

                    <group string="Quotation">
                        <group>
                            <field name="customer_id"/>
                            <field name="sale_order_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Financial Summary" col="4">
                        <field name="material_cost" readonly="1"/>
                        <field name="labor_cost" readonly="1"/>
                        <field name="overhead_cost" readonly="1"/>
                        <field name="total_cost" readonly="1"/>

                        <field name="sale_price_unit"/>
                        <field name="sale_total" readonly="1"/>
                        <field name="profit_amount" readonly="1"/>
                        <field name="profit_percent" readonly="1"/>

                        <field name="margin_percent" readonly="1"/>
                        <field name="over_budget" readonly="1"/>
                        <field name="delayed_flag" readonly="1"/>
                        <field name="is_loss_line" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Resource Lines">
                            <field name="resource_line_ids" context="{'default_boq_line_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="resource_type"/>
                                    <field name="name"/>
                                    <field name="product_id"/>
                                    <field name="partner_id"/>
                                    <field name="qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="cost_price"/>
                                    <field name="total_cost" readonly="1"/>
                                    <field name="sale_price"/>
                                    <field name="total_sale" readonly="1"/>
                                    <field name="required_date"/>
                                    <field name="purchase_state"/>
                                    <field name="stock_qty_available" optional="show"/>
                                    <field name="stock_virtual_available" optional="show"/>
                                    <field name="note" optional="hide"/>
                                </list>
                            </field>
                        </page>

                        <page string="AI / Notes">
                            <group>
                                <field name="ai_note" readonly="1"/>
                                <field name="note"/>
                            </group>
                            <field name="ai_alert_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="alert_type"/>
                                    <field name="severity"/>
                                    <field name="state"/>
                                    <field name="assigned_user_id"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>

                        <page string="Purchase Lines">
                            <field name="purchase_line_ids" readonly="1">
                                <list>
                                    <field name="order_id"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="product_qty"/>
                                    <field name="price_unit"/>
                                    <field name="date_planned"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>

                        <page string="Sale Lines">
                            <field name="sale_line_ids" readonly="1">
                                <list>
                                    <field name="order_id"/>
                                    <field name="product_id"/>
                                    <field name="name"/>
                                    <field name="product_uom_qty"/>
                                    <field name="price_unit"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_task_boq_line" model="ir.actions.act_window">
        <field name="name">BOQ Lines</field>
        <field name="res_model">task.boq.line</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_task_boq_line_search"/>
    </record>

</odoo>
