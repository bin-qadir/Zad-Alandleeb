<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         farm.decision.rule — List + Form + Search + Action
    ================================================================ -->
    <record id="view_farm_decision_rule_list" model="ir.ui.view">
        <field name="name">farm.decision.rule.list</field>
        <field name="model">farm.decision.rule</field>
        <field name="arch" type="xml">
            <list string="Decision Rules" editable="top"
                  decoration-muted="not active"
                  decoration-danger="priority == '2'"
                  decoration-warning="priority == '1'">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="metric"/>
                <field name="operator" optional="show"/>
                <field name="threshold" optional="show"/>
                <field name="action"/>
                <field name="priority" widget="priority"/>
                <field name="cooldown_minutes" optional="show" string="Cooldown (min)"/>
                <field name="auto_execute" optional="show"/>
                <field name="decision_count" string="Decisions"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_farm_decision_rule_form" model="ir.ui.view">
        <field name="name">farm.decision.rule.form</field>
        <field name="model">farm.decision.rule</field>
        <field name="arch" type="xml">
            <form string="Decision Rule">
                <header>
                    <field name="active" widget="boolean_button"
                           options="{'terminology': {'string_true': 'Active', 'string_false': 'Disabled'}}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_decisions" type="object"
                                class="oe_stat_button" icon="fa-lightbulb-o"
                                invisible="decision_count == 0">
                            <field name="decision_count" widget="statinfo" string="Decisions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Rule name..."/></h1>
                    </div>
                    <group>
                        <group string="Condition">
                            <field name="metric"/>
                            <field name="operator" invisible="metric == 'offline'"/>
                            <field name="threshold"
                                   invisible="metric == 'offline'"
                                   string="Threshold Value"/>
                            <field name="offline_minutes" invisible="metric != 'offline'"/>
                            <field name="cooldown_minutes"/>
                        </group>
                        <group string="Action">
                            <field name="action"/>
                            <field name="priority" widget="priority"/>
                            <field name="auto_execute"/>
                            <field name="sequence"/>
                        </group>
                    </group>
                    <group string="Scope (leave empty for all farms)">
                        <field name="farm_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                    <group string="Recommendation Template">
                        <field name="recommendation_template" nolabel="1"
                               placeholder="Use {sensor}, {farm}, {field}, {metric}, {value:.1f}, {threshold:.1f}, {action}"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_farm_decision_rule_search" model="ir.ui.view">
        <field name="name">farm.decision.rule.search</field>
        <field name="model">farm.decision.rule</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="metric"/>
                <field name="action"/>
                <filter name="active"     string="Active"      domain="[('active','=',True)]"/>
                <filter name="urgent"     string="Urgent Rules" domain="[('priority','=','2')]"/>
                <filter name="auto_exec"  string="Auto-Execute" domain="[('auto_execute','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="g_metric"   string="Metric"   context="{'group_by':'metric'}"/>
                    <filter name="g_action"   string="Action"   context="{'group_by':'action'}"/>
                    <filter name="g_priority" string="Priority" context="{'group_by':'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_farm_decision_rule" model="ir.actions.act_window">
        <field name="name">Decision Rules</field>
        <field name="res_model">farm.decision.rule</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_farm_decision_rule_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first decision rule!</p>
            <p>Rules define conditions (e.g. temperature &gt; 40°C) and the
               recommended action (e.g. activate cooling).</p>
        </field>
    </record>

    <!-- ================================================================
         farm.decision — Kanban View (the primary view — color coded)
    ================================================================ -->
    <record id="view_farm_decision_kanban" model="ir.ui.view">
        <field name="name">farm.decision.kanban</field>
        <field name="model">farm.decision</field>
        <field name="arch" type="xml">
            <kanban default_group_by="priority" quick_create="false"
                    class="o_kanban_small_column"
                    group_delete="false" group_create="false"
                    group_fold="false">
                <field name="sensor_id"/>
                <field name="farm_id"/>
                <field name="field_id"/>
                <field name="task_id"/>
                <field name="priority"/>
                <field name="status"/>
                <field name="action_type"/>
                <field name="summary"/>
                <field name="recommendation"/>
                <field name="condition_text"/>
                <field name="triggered_value"/>
                <field name="threshold_value"/>
                <field name="metric"/>
                <field name="color"/>
                <field name="create_date"/>
                <field name="auto_executed"/>

                <templates>
                    <t t-name="card">
                        <!-- colour strip: red=urgent, orange=high, green=normal, grey=resolved -->
                        <t t-set="strip_color"
                           t-value="{
                               '0': record.status.raw_value in ('executed','dismissed') and '#94a3b8' or '#16a34a',
                               '1': '#f59e0b',
                               '2': '#ef4444'
                           }[record.priority.raw_value] or '#94a3b8'"/>

                        <div t-attf-style="border-left:4px solid #{strip_color};border-radius:6px;padding:12px;background:#fff;box-shadow:0 1px 4px rgba(0,0,0,.06);">

                            <!-- Header: priority badge + status -->
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <field name="priority" widget="priority" readonly="1"/>
                                <span t-attf-class="badge {{
                                    record.status.raw_value == 'pending'      ? 'text-bg-danger'   :
                                    record.status.raw_value == 'acknowledged' ? 'text-bg-warning'  :
                                    record.status.raw_value == 'executed'     ? 'text-bg-success'  :
                                    'text-bg-secondary'
                                }}">
                                    <t t-esc="record.status.value"/>
                                </span>
                            </div>

                            <!-- Action type pill -->
                            <div class="mb-1">
                                <span class="badge text-bg-info" style="font-size:10px">
                                    <t t-esc="record.action_type.value"/>
                                </span>
                                <span class="badge text-bg-light ms-1" style="font-size:10px" t-if="record.auto_executed.raw_value">
                                    ⚡ auto
                                </span>
                            </div>

                            <!-- Summary -->
                            <div class="fw-bold mb-1 text-truncate" style="font-size:13px" t-esc="record.summary.value"/>

                            <!-- Condition -->
                            <div class="small text-muted mb-2 text-truncate" t-esc="record.condition_text.value"/>

                            <!-- Location -->
                            <div class="small text-muted">
                                <i class="fa fa-map-marker me-1"/>
                                <t t-esc="record.farm_id.value"/>
                                <t t-if="record.field_id.value"> / <t t-esc="record.field_id.value"/></t>
                            </div>

                            <!-- Sensor -->
                            <div class="small text-muted">
                                <i class="fa fa-microchip me-1"/>
                                <t t-esc="record.sensor_id.value"/>
                            </div>

                            <!-- Created at -->
                            <div class="small text-muted mt-1">
                                <i class="fa fa-clock-o me-1"/>
                                <t t-esc="record.create_date.value"/>
                            </div>

                            <!-- Action buttons -->
                            <div class="d-flex gap-1 mt-2" t-if="record.status.raw_value == 'pending'">
                                <button name="action_acknowledge" type="object"
                                        class="btn btn-sm btn-outline-warning flex-fill">
                                    👁 Ack
                                </button>
                                <button name="action_execute" type="object"
                                        class="btn btn-sm btn-outline-success flex-fill">
                                    ✓ Done
                                </button>
                                <button name="action_dismiss" type="object"
                                        class="btn btn-sm btn-outline-secondary">
                                    ✕
                                </button>
                            </div>
                            <div class="mt-2" t-if="record.status.raw_value == 'acknowledged'">
                                <button name="action_execute" type="object"
                                        class="btn btn-sm btn-success w-100">
                                    ✓ Mark Executed
                                </button>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ================================================================
         farm.decision — List View
    ================================================================ -->
    <record id="view_farm_decision_list" model="ir.ui.view">
        <field name="name">farm.decision.list</field>
        <field name="model">farm.decision</field>
        <field name="arch" type="xml">
            <list string="Decisions"
                  decoration-danger="priority == '2' and status == 'pending'"
                  decoration-warning="priority == '1' and status == 'pending'"
                  decoration-muted="status in ('executed','dismissed')">
                <field name="priority" widget="priority"/>
                <field name="create_date" string="Time"/>
                <field name="farm_id"/>
                <field name="sensor_id"/>
                <field name="metric"/>
                <field name="condition_text" string="Condition"/>
                <field name="action_type"/>
                <field name="summary" optional="hide"/>
                <field name="task_id" optional="show"/>
                <field name="auto_executed" optional="show"/>
                <field name="status" widget="badge"
                       decoration-danger="status == 'pending'"
                       decoration-warning="status == 'acknowledged'"
                       decoration-success="status == 'executed'"
                       decoration-muted="status == 'dismissed'"/>
                <button name="action_acknowledge" type="object" string="Ack"
                        class="btn-sm btn-warning" invisible="status != 'pending'"/>
                <button name="action_execute" type="object" string="Execute"
                        class="btn-sm btn-success" invisible="status not in ('pending','acknowledged')"/>
                <button name="action_dismiss" type="object" string="Dismiss"
                        class="btn-sm btn-secondary" invisible="status not in ('pending','acknowledged')"/>
            </list>
        </field>
    </record>

    <!-- ================================================================
         farm.decision — Form View
    ================================================================ -->
    <record id="view_farm_decision_form" model="ir.ui.view">
        <field name="name">farm.decision.form</field>
        <field name="model">farm.decision</field>
        <field name="arch" type="xml">
            <form string="Decision">
                <header>
                    <button name="action_acknowledge" string="Acknowledge"
                            type="object" class="btn-warning"
                            invisible="status != 'pending'"/>
                    <button name="action_execute" string="Mark Executed"
                            type="object" class="btn-success"
                            invisible="status not in ('pending','acknowledged')"/>
                    <button name="action_dismiss" string="Dismiss"
                            type="object"
                            invisible="status not in ('pending','acknowledged')"/>
                    <button name="action_reopen" string="Re-open"
                            type="object"
                            invisible="status not in ('executed','dismissed')"/>
                    <field name="status" widget="statusbar"
                           statusbar_visible="pending,acknowledged,executed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="summary"/>
                        <h1><field name="summary"/></h1>
                    </div>

                    <!-- Recommendation box -->
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="not recommendation or status in ('executed','dismissed')">
                        <h5><i class="fa fa-lightbulb-o me-1"/> Recommended Action</h5>
                        <field name="recommendation" readonly="1" nolabel="1"/>
                    </div>

                    <group>
                        <group string="Source">
                            <field name="sensor_id"/>
                            <field name="farm_id"  readonly="1"/>
                            <field name="field_id" readonly="1"/>
                            <field name="task_id"  readonly="1"/>
                            <field name="alert_id" optional="show"/>
                        </group>
                        <group string="Decision">
                            <field name="action_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="rule_id"/>
                            <field name="auto_executed" readonly="1"/>
                        </group>
                    </group>
                    <group string="Condition Details">
                        <group>
                            <field name="metric"/>
                            <field name="condition_text" readonly="1"/>
                        </group>
                        <group>
                            <field name="triggered_value"/>
                            <field name="threshold_value"/>
                        </group>
                    </group>
                    <group string="Execution" invisible="status not in ('executed','acknowledged')">
                        <group>
                            <field name="acknowledged_by" readonly="1"/>
                            <field name="acknowledged_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="executed_by" readonly="1"/>
                            <field name="executed_at" readonly="1"/>
                        </group>
                        <field name="execution_notes" colspan="2"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ================================================================
         farm.decision — Search View
    ================================================================ -->
    <record id="view_farm_decision_search" model="ir.ui.view">
        <field name="name">farm.decision.search</field>
        <field name="model">farm.decision</field>
        <field name="arch" type="xml">
            <search string="Search Decisions">
                <field name="summary"/>
                <field name="sensor_id"/>
                <field name="farm_id"/>
                <field name="metric"/>
                <field name="action_type"/>
                <filter name="pending"      string="Pending"      domain="[('status','=','pending')]"/>
                <filter name="acknowledged" string="Acknowledged" domain="[('status','=','acknowledged')]"/>
                <filter name="urgent"       string="Urgent"       domain="[('priority','=','2')]"/>
                <filter name="high"         string="High"         domain="[('priority','=','1')]"/>
                <filter name="executed"     string="Executed"     domain="[('status','=','executed')]"/>
                <filter name="dismissed"    string="Dismissed"    domain="[('status','=','dismissed')]"/>
                <separator/>
                <filter name="not_resolved" string="Active"
                        domain="[('status','not in',('executed','dismissed'))]"/>
                <filter name="today" string="Today"
                        domain="[('create_date','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
                <filter name="auto_executed" string="Auto-Executed" domain="[('auto_executed','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter name="g_farm"     string="Farm"        context="{'group_by':'farm_id'}"/>
                    <filter name="g_sensor"   string="Sensor"      context="{'group_by':'sensor_id'}"/>
                    <filter name="g_metric"   string="Metric"      context="{'group_by':'metric'}"/>
                    <filter name="g_action"   string="Action"      context="{'group_by':'action_type'}"/>
                    <filter name="g_priority" string="Priority"    context="{'group_by':'priority'}"/>
                    <filter name="g_status"   string="Status"      context="{'group_by':'status'}"/>
                    <filter name="g_day"      string="Day"         context="{'group_by':'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         farm.decision — Actions
    ================================================================ -->
    <record id="action_farm_decision" model="ir.actions.act_window">
        <field name="name">Decisions</field>
        <field name="res_model">farm.decision</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_farm_decision_search"/>
        <field name="context">{'search_default_not_resolved': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No active decisions!</p>
            <p>Decisions are generated automatically from sensor readings
               when conditions breach configured thresholds.</p>
        </field>
    </record>

    <record id="action_farm_decision_urgent" model="ir.actions.act_window">
        <field name="name">Urgent Decisions</field>
        <field name="res_model">farm.decision</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">[('priority','=','2'),('status','not in',('executed','dismissed'))]</field>
        <field name="search_view_id" ref="view_farm_decision_search"/>
    </record>

    <!-- Run engine now — server action -->
    <record id="action_run_decision_engine" model="ir.actions.server">
        <field name="name">Run Decision Engine Now</field>
        <field name="model_id" ref="model_farm_decision_engine"/>
        <field name="binding_model_id" ref="model_farm_decision_rule"/>
        <field name="state">code</field>
        <field name="code">
action = records.env['farm.decision.engine'].run_now()
        </field>
    </record>

    <!-- ================================================================
         project.task — Decisions smart button (inherited)
    ================================================================ -->
    <record id="view_task_form_decision_btn" model="ir.ui.view">
        <field name="name">project.task.form.decision.btn</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_task_decisions" type="object"
                        class="oe_stat_button" icon="fa-lightbulb-o"
                        invisible="task_decision_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="task_decision_count"/>
                        </span>
                        <span class="o_stat_text">Decisions</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         farm.sensor form — Pending Decisions smart button (inherited)
    ================================================================ -->
    <record id="view_farm_sensor_form_decision_btn" model="ir.ui.view">
        <field name="name">farm.sensor.form.decision.btn</field>
        <field name="model">farm.sensor</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_sensor_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_decisions" type="object"
                        class="oe_stat_button" icon="fa-lightbulb-o"
                        invisible="pending_decision_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="pending_decision_count"/>
                        </span>
                        <span class="o_stat_text">Decisions</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>

    <!-- ================================================================
         farm.sensor.alert list — add Recommended Action column
    ================================================================ -->
    <record id="view_sensor_alert_list_decision" model="ir.ui.view">
        <field name="name">farm.sensor.alert.list.decision</field>
        <field name="model">farm.sensor.alert</field>
        <field name="inherit_id" ref="smart_farm_alandleeb.view_farm_sensor_alert_list"/>
        <field name="arch" type="xml">
            <!-- Add recommended action badge after the message column -->
            <xpath expr="//field[@name='message']" position="after">
                <field name="recommended_action" optional="show" string="Recommended Action"
                       readonly="1"/>
            </xpath>
        </field>
    </record>

</odoo>
