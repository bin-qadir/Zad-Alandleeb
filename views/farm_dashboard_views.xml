<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Dashboard Action (pivot + graph on harvests)
    ============================================================ -->

    <!-- Harvest Pivot -->
    <record id="view_farm_harvest_pivot" model="ir.ui.view">
        <field name="name">farm.harvest.pivot</field>
        <field name="model">farm.harvest</field>
        <field name="arch" type="xml">
            <pivot string="Harvest Analysis" disable_linking="False">
                <field name="farm_id" type="row"/>
                <field name="crop_id" type="row"/>
                <field name="quality_grade" type="col"/>
                <field name="quantity_harvested" type="measure"/>
                <field name="total_value" type="measure"/>
                <field name="loss_quantity" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Harvest Graph -->
    <record id="view_farm_harvest_graph" model="ir.ui.view">
        <field name="name">farm.harvest.graph</field>
        <field name="model">farm.harvest</field>
        <field name="arch" type="xml">
            <graph string="Harvest Overview" type="bar" stacked="1">
                <field name="farm_id" type="row"/>
                <field name="quantity_harvested" type="measure"/>
                <field name="total_value" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Expense Pivot -->
    <record id="view_farm_expense_pivot" model="ir.ui.view">
        <field name="name">farm.expense.pivot</field>
        <field name="model">farm.expense</field>
        <field name="arch" type="xml">
            <pivot string="Expense Analysis">
                <field name="farm_id" type="row"/>
                <field name="expense_type" type="col"/>
                <field name="amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Expense Graph -->
    <record id="view_farm_expense_graph" model="ir.ui.view">
        <field name="name">farm.expense.graph</field>
        <field name="model">farm.expense</field>
        <field name="arch" type="xml">
            <graph string="Expenses by Type" type="pie">
                <field name="expense_type" type="row"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Crop Pivot -->
    <record id="view_farm_crop_pivot" model="ir.ui.view">
        <field name="name">farm.crop.pivot</field>
        <field name="model">farm.crop</field>
        <field name="arch" type="xml">
            <pivot string="Crop Analysis">
                <field name="farm_id" type="row"/>
                <field name="crop_type_id" type="row"/>
                <field name="state" type="col"/>
                <field name="area_planted" type="measure"/>
                <field name="expected_yield" type="measure"/>
                <field name="actual_yield" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Dashboard Actions -->
    <record id="action_farm_harvest_analysis" model="ir.actions.act_window">
        <field name="name">Harvest Analysis</field>
        <field name="res_model">farm.harvest</field>
        <field name="view_mode">graph,pivot,list</field>
    </record>

    <record id="action_farm_expense_analysis" model="ir.actions.act_window">
        <field name="name">Expense Analysis</field>
        <field name="res_model">farm.expense</field>
        <field name="view_mode">graph,pivot,list</field>
    </record>

    <record id="action_farm_crop_analysis" model="ir.actions.act_window">
        <field name="name">Crop Analysis</field>
        <field name="res_model">farm.crop</field>
        <field name="view_mode">pivot,graph,list</field>
    </record>

</odoo>
