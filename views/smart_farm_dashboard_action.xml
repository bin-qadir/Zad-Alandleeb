<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Smart Farm Financial Performance Dashboard
         Client Action — registers the Owl component as a menu action
    ============================================================ -->
    <record id="action_smart_farm_dashboard" model="ir.actions.client">
        <field name="name">Financial Performance Dashboard</field>
        <field name="tag">smart_farm_dashboard</field>
        <field name="target">main</field>
    </record>

    <!-- Menu entry under Smart Farm root -->
    <menuitem
        id="menu_smart_farm_dashboard_root"
        name="Dashboard"
        parent="smart_farm_alandleeb.menu_smart_farm_root"
        action="action_smart_farm_dashboard"
        sequence="1"
        groups="smart_farm_alandleeb.group_farm_user"/>

</odoo>
