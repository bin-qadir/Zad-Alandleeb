<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ═══════════════════════════════════════════════════════════════════════════
     FARM DIVISION PIPELINE  ·  Interactive Dashboard Views
     ═══════════════════════════════════════════════════════════════════════════ -->


<!-- ── FORM / DASHBOARD VIEW ─────────────────────────────────────────────── -->
<record id="view_farm_division_pipeline_form" model="ir.ui.view">
    <field name="name">farm.division.pipeline.form</field>
    <field name="model">farm.division.pipeline</field>
    <field name="arch" type="xml">
        <form string="Division Pipeline Dashboard">

            <!-- ── Status bar ─────────────────────────────────────────────── -->
            <header>
                <field name="pipeline_phase" widget="statusbar"
                       statusbar_visible="planning,material_request,procurement,resources,ready_for_execution,in_progress,inspection,approval,claim"/>
                <button name="action_refresh_kpis"
                        string="↻  Refresh KPIs"
                        type="object"
                        class="btn-secondary"/>
            </header>

            <!-- ── Smart buttons ──────────────────────────────────────────── -->
            <div class="oe_button_box" name="button_box">
                <button name="action_open_all_jo" type="object"
                        class="oe_stat_button" icon="fa-tasks">
                    <field name="total_jo_count" widget="statinfo" string="Job Orders"/>
                </button>
                <button name="action_open_in_progress" type="object"
                        class="oe_stat_button" icon="fa-play-circle">
                    <field name="in_progress_count" widget="statinfo" string="In Progress"/>
                </button>
                <button name="action_open_eligible_for_claim" type="object"
                        class="oe_stat_button" icon="fa-flag-checkered">
                    <field name="eligible_for_claim_count" widget="statinfo" string="Ready to Claim"/>
                </button>
                <button name="action_open_claimed" type="object"
                        class="oe_stat_button" icon="fa-money">
                    <field name="claimed_count" widget="statinfo" string="Claimed"/>
                </button>
            </div>

            <!-- ── Identity block ─────────────────────────────────────────── -->
            <group>
                <group>
                    <field name="project_id"/>
                    <field name="division_id"/>
                </group>
                <group>
                    <field name="contract_amount_total" widget="monetary"
                           options="{'currency_field': 'currency_id'}"
                           string="Contract Value"/>
                    <field name="approved_amount_total" widget="monetary"
                           options="{'currency_field': 'currency_id'}"
                           string="Approved (Claimable)"/>
                    <field name="currency_id" invisible="1"/>
                    <field name="display_name_full" invisible="1"/>
                    <field name="has_alerts" invisible="1"/>
                </group>
            </group>

            <!-- ══════════════════════════════════════════════════════════════
                 ALERT BOX  (hidden when no alerts)
                 ══════════════════════════════════════════════════════════════ -->
            <div class="dp-alert-box mx-3 mt-1" invisible="not has_alerts">
                <div class="dp-alert-title">
                    <i class="fa fa-exclamation-triangle" title="Alerts"/>
                    Attention Required
                </div>
                <div class="dp-alert-items">

                    <!-- Delayed -->
                    <button name="action_open_delayed" type="object"
                            class="dp-alert-chip dp-alert-chip--red"
                            invisible="delayed_count == 0">
                        <i class="fa fa-clock-o" title="Delayed"/>
                        <field name="delayed_count" nolabel="1" readonly="1"/> Delayed
                    </button>

                    <!-- Waiting Inspection (overdue) -->
                    <button name="action_open_waiting_inspection" type="object"
                            class="dp-alert-chip"
                            invisible="overdue_inspection_count == 0">
                        <i class="fa fa-eye" title="Waiting Inspection"/>
                        <field name="overdue_inspection_count" nolabel="1" readonly="1"/> Waiting Inspection
                    </button>

                    <!-- Over Budget -->
                    <button name="action_open_over_budget" type="object"
                            class="dp-alert-chip dp-alert-chip--red"
                            invisible="over_budget_count == 0">
                        <i class="fa fa-warning" title="Over Budget"/>
                        <field name="over_budget_count" nolabel="1" readonly="1"/> Over Budget
                    </button>

                    <!-- Unpaid -->
                    <button name="action_open_under_review" type="object"
                            class="dp-alert-chip"
                            invisible="unpaid_count == 0">
                        <i class="fa fa-hourglass-half" title="Unpaid"/>
                        <field name="unpaid_count" nolabel="1" readonly="1"/> Unpaid / Under Review
                    </button>

                </div>
            </div>

            <!-- ══════════════════════════════════════════════════════════════
                 FOUR DASHBOARD PANELS  (2 × 2 grid)
                 ══════════════════════════════════════════════════════════════ -->
            <div class="row g-3 mx-1 mt-1 mb-2">

                <!-- ╔═══════════════════════════════╗
                     ║  1 · PRE-EXECUTION PANEL      ║
                     ╚═══════════════════════════════╝ -->
                <div class="col-12 col-xl-6">
                    <div class="dp-panel dp-panel--preexec">
                        <div class="dp-panel-header">
                            <i class="fa fa-cogs" title="Pre-Execution"/>
                            Pre-Execution  ·  Readiness
                        </div>
                        <div class="dp-panel-body">

                            <!-- Planning -->
                            <div class="dp-bar-row">
                                <span class="dp-bar-label">
                                    <button name="action_open_in_planning" type="object"
                                            class="btn btn-link p-0 text-secondary"
                                            style="font-size:0.78rem;text-decoration:none;">
                                        <i class="fa fa-map-o me-1" title="Planning"/>Planning
                                    </button>
                                </span>
                                <field name="planning_bar_html" nolabel="1" readonly="1"/>
                            </div>

                            <!-- Material Readiness -->
                            <div class="dp-bar-row">
                                <span class="dp-bar-label">
                                    <i class="fa fa-cubes me-1 text-primary" title="Materials"/>Material
                                </span>
                                <field name="material_bar_html" nolabel="1" readonly="1"/>
                            </div>

                            <!-- Procurement -->
                            <div class="dp-bar-row">
                                <span class="dp-bar-label">
                                    <i class="fa fa-shopping-cart me-1 text-warning" title="Procurement"/>Procurement
                                </span>
                                <field name="procurement_bar_html" nolabel="1" readonly="1"/>
                            </div>

                            <!-- Resources -->
                            <div class="dp-bar-row">
                                <span class="dp-bar-label">
                                    <i class="fa fa-users me-1 text-success" title="Resources"/>Resources
                                </span>
                                <field name="resources_bar_html" nolabel="1" readonly="1"/>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- ╔═══════════════════════════════╗
                     ║  2 · EXECUTION PANEL          ║
                     ╚═══════════════════════════════╝ -->
                <div class="col-12 col-xl-6">
                    <div class="dp-panel dp-panel--exec">
                        <div class="dp-panel-header">
                            <i class="fa fa-play" title="Execution"/>
                            Execution  ·  Site Progress
                        </div>
                        <div class="dp-panel-body">
                            <div class="dp-cards-grid">

                                <!-- In Progress -->
                                <button name="action_open_in_progress" type="object"
                                        class="dp-card dp-card--blue">
                                    <span class="dp-card-num">
                                        <field name="in_progress_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">In Progress</span>
                                </button>

                                <!-- Waiting Inspection -->
                                <button name="action_open_waiting_inspection" type="object"
                                        class="dp-card dp-card--amber">
                                    <span class="dp-card-num">
                                        <field name="waiting_inspection_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Waiting Inspection</span>
                                </button>

                                <!-- Under Inspection -->
                                <button name="action_open_under_inspection" type="object"
                                        class="dp-card dp-card--purple">
                                    <span class="dp-card-num">
                                        <field name="under_inspection_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Under Inspection</span>
                                </button>

                                <!-- Completed -->
                                <button name="action_open_completed" type="object"
                                        class="dp-card dp-card--teal">
                                    <span class="dp-card-num">
                                        <field name="completed_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Completed</span>
                                </button>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- ╔═══════════════════════════════╗
                     ║  3 · CONTROL PANEL            ║
                     ╚═══════════════════════════════╝ -->
                <div class="col-12 col-xl-6">
                    <div class="dp-panel dp-panel--control">
                        <div class="dp-panel-header">
                            <i class="fa fa-check-circle" title="Control"/>
                            Control  ·  Inspection &amp; Approval
                        </div>
                        <div class="dp-panel-body">
                            <div class="dp-cards-grid">

                                <!-- Pending Approval -->
                                <button name="action_open_pending_approval" type="object"
                                        class="dp-card dp-card--amber">
                                    <span class="dp-card-num">
                                        <field name="pending_approval_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Pending Approval</span>
                                </button>

                                <!-- Approved -->
                                <button name="action_open_approved" type="object"
                                        class="dp-card dp-card--green">
                                    <span class="dp-card-num">
                                        <field name="approved_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Approved</span>
                                </button>

                                <!-- Rejected -->
                                <button name="action_open_rejected" type="object"
                                        class="dp-card dp-card--red">
                                    <span class="dp-card-num">
                                        <field name="rejected_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Rejected</span>
                                </button>

                                <!-- Rework -->
                                <button name="action_open_rework" type="object"
                                        class="dp-card dp-card--gray">
                                    <span class="dp-card-num">
                                        <field name="rework_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Rework</span>
                                </button>

                            </div>
                        </div>
                    </div>
                </div>

                <!-- ╔═══════════════════════════════╗
                     ║  4 · FINANCIAL PANEL          ║
                     ╚═══════════════════════════════╝ -->
                <div class="col-12 col-xl-6">
                    <div class="dp-panel dp-panel--financial">
                        <div class="dp-panel-header">
                            <i class="fa fa-usd" title="Financial"/>
                            Financial  ·  Claims &amp; Revenue
                        </div>
                        <div class="dp-panel-body">
                            <div class="dp-cards-grid">

                                <!-- Eligible for Claim -->
                                <button name="action_open_eligible_for_claim" type="object"
                                        class="dp-card dp-card--teal">
                                    <span class="dp-card-num">
                                        <field name="eligible_for_claim_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Eligible for Claim</span>
                                    <span class="dp-card-amt">
                                        <field name="eligible_for_claim_amount" nolabel="1" readonly="1"
                                               widget="monetary" options="{'currency_field':'currency_id'}"/>
                                    </span>
                                </button>

                                <!-- Claimed / Under Review -->
                                <button name="action_open_under_review" type="object"
                                        class="dp-card dp-card--blue">
                                    <span class="dp-card-num">
                                        <field name="under_review_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Under Review</span>
                                    <span class="dp-card-amt">
                                        <field name="under_review_amount" nolabel="1" readonly="1"
                                               widget="monetary" options="{'currency_field':'currency_id'}"/>
                                    </span>
                                </button>

                                <!-- Approved Claims -->
                                <button name="action_open_approved_claims" type="object"
                                        class="dp-card dp-card--green">
                                    <span class="dp-card-num">
                                        <field name="approved_claim_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Approved Claims</span>
                                    <span class="dp-card-amt">
                                        <field name="approved_claim_amount" nolabel="1" readonly="1"
                                               widget="monetary" options="{'currency_field':'currency_id'}"/>
                                    </span>
                                </button>

                                <!-- Rejected Claims -->
                                <button name="action_open_rejected_claims" type="object"
                                        class="dp-card dp-card--red">
                                    <span class="dp-card-num">
                                        <field name="rejected_claim_count" nolabel="1" readonly="1"/>
                                    </span>
                                    <span class="dp-card-lbl">Rejected Claims</span>
                                </button>

                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <!-- end 4-panel row -->

            <!-- ── Notes ──────────────────────────────────────────────────── -->
            <group>
                <field name="notes" placeholder="Division workflow notes, blockers, decisions…"/>
            </group>

            <!-- ── Chatter ────────────────────────────────────────────────── -->
            <div class="oe_chatter">
                <field name="message_follower_ids"/>
                <field name="activity_ids"/>
                <field name="message_ids"/>
            </div>

        </form>
    </field>
</record>


<!-- ── LIST VIEW ─────────────────────────────────────────────────────────── -->
<record id="view_farm_division_pipeline_list" model="ir.ui.view">
    <field name="name">farm.division.pipeline.list</field>
    <field name="model">farm.division.pipeline</field>
    <field name="arch" type="xml">
        <list string="Division Pipelines"
              decoration-muted="pipeline_phase == 'completed'"
              decoration-info="pipeline_phase in ('planning','material_request','procurement','resources','ready_for_execution')"
              decoration-primary="pipeline_phase == 'in_progress'"
              decoration-warning="pipeline_phase in ('inspection','approval')"
              decoration-success="pipeline_phase == 'claim'">

            <field name="sequence" widget="handle"/>
            <field name="project_id" optional="show"/>
            <field name="division_id"/>
            <field name="pipeline_phase" widget="badge"/>
            <field name="total_jo_count" string="Total JOs"/>

            <!-- Pre-Execution readiness -->
            <field name="planning_pct"           string="Planning %"    optional="show"/>
            <field name="material_readiness_pct" string="Material %"    optional="show"/>
            <field name="procurement_pct"        string="Procurement %" optional="show"/>
            <field name="resources_pct"          string="Resources %"   optional="show"/>

            <!-- Execution -->
            <field name="in_progress_count"        string="In Progress"     optional="show"/>
            <field name="waiting_inspection_count" string="Waiting Insp."   optional="show"/>
            <field name="completed_count"          string="Completed"       optional="show"/>

            <!-- Control -->
            <field name="approved_count"  string="Approved"  optional="show"/>
            <field name="rejected_count"  string="Rejected"  optional="show"/>
            <field name="rework_count"    string="Rework"    optional="show"/>

            <!-- Financial -->
            <field name="eligible_for_claim_count"  string="Eligible"       optional="show"/>
            <field name="under_review_count"        string="Under Review"   optional="show"/>
            <field name="approved_claim_count"      string="Appr. Claims"   optional="show"/>
            <field name="claimed_amount_total"      string="Claimed Amt"    optional="show"
                   widget="monetary" options="{'currency_field': 'currency_id'}"/>
            <field name="contract_amount_total"     string="Contract Amt"   optional="show"
                   widget="monetary" options="{'currency_field': 'currency_id'}"/>

            <!-- Alerts indicator -->
            <field name="has_alerts" string="Alerts" optional="show" widget="boolean"
                   decoration-danger="has_alerts"/>
            <field name="currency_id" column_invisible="1"/>
        </list>
    </field>
</record>


<!-- ── KANBAN VIEW ───────────────────────────────────────────────────────── -->
<record id="view_farm_division_pipeline_kanban" model="ir.ui.view">
    <field name="name">farm.division.pipeline.kanban</field>
    <field name="model">farm.division.pipeline</field>
    <field name="arch" type="xml">
        <kanban default_group_by="pipeline_phase" class="o_kanban_small_column">
            <field name="project_id"/>
            <field name="division_id"/>
            <field name="pipeline_phase"/>
            <field name="total_jo_count"/>
            <field name="in_progress_count"/>
            <field name="approved_count"/>
            <field name="claimed_amount_total"/>
            <field name="material_readiness_pct"/>
            <field name="has_alerts"/>

            <templates>
                <t t-name="card">
                    <div class="p-2">
                        <!-- Division -->
                        <div class="fw-bold text-truncate" style="font-size:0.9rem;">
                            <field name="division_id"/>
                        </div>
                        <div class="text-muted small text-truncate">
                            <i class="fa fa-building-o me-1" title="Project"/>
                            <field name="project_id"/>
                        </div>

                        <hr class="my-1"/>

                        <div class="d-flex justify-content-between small">
                            <span class="text-muted">JOs</span>
                            <strong><field name="total_jo_count"/></strong>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-muted">In Progress</span>
                            <strong class="text-primary"><field name="in_progress_count"/></strong>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-muted">Approved</span>
                            <strong class="text-success"><field name="approved_count"/></strong>
                        </div>
                        <div class="d-flex justify-content-between small">
                            <span class="text-muted">Material</span>
                            <strong class="text-info"><field name="material_readiness_pct"/>%</strong>
                        </div>

                        <t t-if="record.has_alerts.raw_value">
                            <div class="mt-1">
                                <span class="badge bg-warning text-dark" style="font-size:0.65rem;">
                                    <i class="fa fa-exclamation-triangle" title="Alert"/> Alerts
                                </span>
                            </div>
                        </t>
                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>


<!-- ── SEARCH VIEW ───────────────────────────────────────────────────────── -->
<record id="view_farm_division_pipeline_search" model="ir.ui.view">
    <field name="name">farm.division.pipeline.search</field>
    <field name="model">farm.division.pipeline</field>
    <field name="arch" type="xml">
        <search string="Division Pipeline">
            <field name="project_id"/>
            <field name="division_id"/>
            <field name="pipeline_phase"/>

            <filter name="filter_has_alerts"    string="⚠ Has Alerts"        domain="[('has_alerts','=',True)]"/>
            <filter name="filter_delayed"       string="Delayed JOs"          domain="[('delayed_count','>',0)]"/>
            <filter name="filter_over_budget"   string="Over Budget"          domain="[('over_budget_count','>',0)]"/>

            <separator/>
            <filter name="filter_preexec"    string="Pre-Execution"
                    domain="[('pipeline_phase','in',['planning','material_request','procurement','resources','ready_for_execution'])]"/>
            <filter name="filter_execution"  string="Execution"
                    domain="[('pipeline_phase','in',['in_progress','completed'])]"/>
            <filter name="filter_control"    string="Control"
                    domain="[('pipeline_phase','in',['inspection','approval'])]"/>
            <filter name="filter_financial"  string="Financial"
                    domain="[('pipeline_phase','=','claim')]"/>

            <separator/>
            <filter name="filter_in_progress"    string="In Progress"     domain="[('pipeline_phase','=','in_progress')]"/>
            <filter name="filter_has_rework"     string="Has Rework"      domain="[('rework_count','>',0)]"/>
            <filter name="filter_has_rejection"  string="Has Rejections"  domain="[('rejected_count','>',0)]"/>
            <filter name="filter_eligible_claim" string="Eligible to Claim" domain="[('eligible_for_claim_count','>',0)]"/>

            <group expand="0" string="Group By">
                <filter name="group_project"  string="Project"  context="{'group_by':'project_id'}"/>
                <filter name="group_division" string="Division" context="{'group_by':'division_id'}"/>
                <filter name="group_phase"    string="Phase"    context="{'group_by':'pipeline_phase'}"/>
            </group>
        </search>
    </field>
</record>


<!-- ── WINDOW ACTION ─────────────────────────────────────────────────────── -->
<record id="action_farm_division_pipeline" model="ir.actions.act_window">
    <field name="name">Division Pipeline</field>
    <field name="res_model">farm.division.pipeline</field>
    <field name="view_mode">list,kanban,form</field>
    <field name="search_view_id" ref="view_farm_division_pipeline_search"/>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            No division pipelines yet
        </p>
        <p>
            Create a pipeline record for each division within a project to track
            Pre-Execution, Execution, Control, and Financial workflow phases
            with live KPI cards and alerts.
        </p>
    </field>
</record>

</data>
</odoo>
