<odoo>
    <record id="view_boq_dashboard_report_list" model="ir.ui.view"><field name="name">boq.dashboard.report.list</field><field name="model">boq.dashboard.report</field><field name="arch" type="xml"><list create="false" edit="false" delete="false"><field name="project_id"/><field name="task_id"/><field name="stage_id"/><field name="date_deadline"/><field name="total_cost_planned"/><field name="total_cost_actual"/><field name="budget_variance"/><field name="budget_variance_percent"/><field name="total_sale_planned"/><field name="total_profit_planned"/><field name="total_profit_actual"/><field name="planned_margin_percent"/><field name="actual_margin_percent"/><field name="stock_move_count"/><field name="purchase_count"/><field name="timesheet_count"/><field name="ai_alert_count"/></list></field></record>
    <record id="view_boq_dashboard_report_pivot" model="ir.ui.view"><field name="name">boq.dashboard.report.pivot</field><field name="model">boq.dashboard.report</field><field name="arch" type="xml"><pivot><field name="project_id" type="row"/><field name="stage_id" type="row"/><field name="x_month" type="col"/><field name="total_cost_planned" type="measure"/><field name="total_cost_actual" type="measure"/><field name="budget_variance" type="measure"/><field name="total_profit_planned" type="measure"/><field name="total_profit_actual" type="measure"/><field name="ai_alert_count" type="measure"/></pivot></field></record>
    <record id="view_boq_dashboard_report_graph" model="ir.ui.view"><field name="name">boq.dashboard.report.graph</field><field name="model">boq.dashboard.report</field><field name="arch" type="xml"><graph type="bar"><field name="project_id"/><field name="total_cost_planned" type="measure"/><field name="total_cost_actual" type="measure"/><field name="total_profit_planned" type="measure"/><field name="total_profit_actual" type="measure"/></graph></field></record>
    <record id="view_boq_dashboard_report_search" model="ir.ui.view"><field name="name">boq.dashboard.report.search</field><field name="model">boq.dashboard.report</field><field name="arch" type="xml"><search><field name="project_id"/><field name="task_id"/><field name="stage_id"/><field name="partner_id"/><field name="x_month"/><filter name="filter_over_budget" string="Over Budget" domain="[('is_over_budget', '=', True)]"/><filter name="filter_low_margin" string="Low Margin" domain="[('is_low_margin', '=', True)]"/><filter name="filter_delayed" string="Delayed" domain="[('is_delayed', '=', True)]"/><filter name="filter_has_alerts" string="Has AI Alerts" domain="[('ai_alert_count', '&gt;', 0)]"/></search></field></record>
    <record id="action_boq_executive_dashboard" model="ir.actions.act_window"><field name="name">BOQ Executive Dashboard</field><field name="res_model">boq.dashboard.report</field><field name="view_mode">list,pivot,graph</field><field name="search_view_id" ref="view_boq_dashboard_report_search"/></record>
    <record id="view_boq_dashboard_kpi_list" model="ir.ui.view"><field name="name">boq.dashboard.kpi.list</field><field name="model">boq.dashboard.kpi</field><field name="arch" type="xml"><list create="false" edit="false" delete="false"><field name="company_id"/><field name="total_projects"/><field name="total_tasks"/><field name="total_cost_planned"/><field name="total_cost_actual"/><field name="total_sale_planned"/><field name="total_profit_planned"/><field name="total_profit_actual"/><field name="avg_actual_margin"/><field name="over_budget_tasks"/><field name="delayed_tasks"/><field name="low_margin_tasks"/><field name="ai_alerts"/></list></field></record>
    <record id="action_boq_kpi_dashboard" model="ir.actions.act_window"><field name="name">BOQ KPI Dashboard</field><field name="res_model">boq.dashboard.kpi</field><field name="view_mode">list,pivot,graph</field></record>
</odoo>
