<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Agriculture Season sequence -->
        <record id="seq_agriculture_season" model="ir.sequence">
            <field name="name">Agriculture Season</field>
            <field name="code">agriculture.season</field>
            <field name="prefix">AGR-%(year)s-</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

    </data>
</odoo>
