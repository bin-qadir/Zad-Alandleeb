<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--
            Job Orders stat button — injected into the Farm Project button_box.
        -->
        <record id="view_farm_project_form_execution_inherit" model="ir.ui.view">
            <field name="name">farm.project.form.execution.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">
                <!-- Job Orders — slot 7, inserted before anchor_execution_end -->
                <xpath expr="//div[@name='anchor_execution_end']" position="before">
                    <button name="action_open_job_orders" type="object"
                            class="oe_stat_button" icon="fa-tasks">
                        <field name="job_order_count" widget="statinfo" string="Job Orders"/>
                    </button>
                </xpath>

                <!-- Materials — slot 8, inserted before anchor_materials_end -->
                <xpath expr="//div[@name='anchor_materials_end']" position="before">
                    <button name="action_open_materials" type="object"
                            class="oe_stat_button" icon="fa-cubes">
                        <field name="material_consumption_count" widget="statinfo" string="Materials"/>
                    </button>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
