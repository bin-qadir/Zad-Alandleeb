<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════════════
             SEQUENCE
        ══════════════════════════════════════════════════════════════════ -->

        <record id="seq_farm_job_order" model="ir.sequence">
            <field name="name">Farm Job Order</field>
            <field name="code">farm.job.order</field>
            <field name="prefix">JO/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>


        <!-- ══════════════════════════════════════════════════════════════════
             SEARCH
        ══════════════════════════════════════════════════════════════════ -->

        <record id="view_farm_job_order_search" model="ir.ui.view">
            <field name="name">farm.job.order.search</field>
            <field name="model">farm.job.order</field>
            <field name="arch" type="xml">
                <search string="Job Orders">
                    <field name="name"         string="Job Order"/>
                    <field name="project_id"/>
                    <field name="analysis_id"/>
                    <field name="boq_line_id"  string="BOQ Subitem"/>
                    <field name="work_type_id"/>
                    <field name="division_id"/>
                    <separator/>
                    <filter name="draft"       string="Draft"
                            domain="[('state','=','draft')]"/>
                    <filter name="ready"       string="Ready"
                            domain="[('state','=','ready')]"/>
                    <filter name="in_progress" string="In Progress"
                            domain="[('state','=','in_progress')]"/>
                    <filter name="completed"   string="Completed"
                            domain="[('state','=','completed')]"/>
                    <filter name="closed"      string="Closed"
                            domain="[('state','=','closed')]"/>
                    <separator/>
                    <filter name="not_closed"  string="Active (excl. Closed)"
                            domain="[('state','!=','closed')]"/>
                    <!-- Data-integrity filter: find JOs linked to structural rows -->
                    <separator/>
                    <filter name="structural_line_error"
                            string="⚠ Invalid BOQ Ref"
                            domain="[('is_structural_line','=',True)]"/>
                    <group string="Group By">
                        <filter name="by_project"      string="Project"
                                context="{'group_by':'project_id'}"/>
                        <filter name="by_division"     string="Division"
                                context="{'group_by':'division_id'}"/>
                        <filter name="by_subdivision"  string="Subdivision"
                                context="{'group_by':'subdivision_id'}"/>
                        <filter name="by_state"        string="Status"
                                context="{'group_by':'state'}"/>
                        <filter name="by_work_type"    string="Work Type"
                                context="{'group_by':'work_type_id'}"/>
                    </group>
                </search>
            </field>
        </record>


        <!-- ══════════════════════════════════════════════════════════════════
             LIST
        ══════════════════════════════════════════════════════════════════ -->

        <record id="view_farm_job_order_list" model="ir.ui.view">
            <field name="name">farm.job.order.list</field>
            <field name="model">farm.job.order</field>
            <field name="arch" type="xml">
                <list string="Job Orders"
                      decoration-muted="state == 'draft'"
                      decoration-info="state == 'ready'"
                      decoration-warning="state == 'in_progress'"
                      decoration-success="state in ('completed', 'closed')"
                      decoration-danger="is_structural_line">
                    <!-- is_structural_line drives the danger row highlight; hidden from columns -->
                    <field name="is_structural_line" column_invisible="1"/>
                    <field name="name"              string="Job Order No"/>
                    <field name="display_code"      string="BOQ Code"/>
                    <field name="boq_line_id"       string="Subitem"/>
                    <field name="boq_hierarchy"     string="BOQ Hierarchy"  optional="show"/>
                    <field name="project_id"        string="Project"/>
                    <field name="boq_id"            string="BOQ"        optional="show"/>
                    <field name="division_id"       string="Division"   optional="show"/>
                    <field name="subdivision_id"    string="Subdivision" optional="show"/>
                    <field name="work_type_id"      string="Work Type"  optional="show"/>
                    <field name="planned_qty"       string="Plan Qty"/>
                    <field name="unit_id"           string="Unit" optional="show"/>
                    <field name="executed_qty"      string="Exec. Qty"/>
                    <field name="progress_percent"  string="Progress %"
                           widget="progressbar"/>
                    <field name="planned_start_date" string="Start" optional="show"/>
                    <field name="planned_end_date"   string="End"   optional="show"/>
                    <field name="planned_cost"      string="Planned Cost"
                           widget="monetary"
                           options="{'currency_field': 'currency_id'}"
                           optional="show"/>
                    <field name="actual_total_cost" string="Actual Cost"
                           widget="monetary"
                           options="{'currency_field': 'currency_id'}"
                           optional="show"/>
                    <field name="cost_variance"     string="Variance"
                           widget="monetary"
                           options="{'currency_field': 'currency_id'}"
                           decoration-danger="cost_variance &gt; 0"
                           decoration-success="cost_variance &lt;= 0 and actual_total_cost &gt; 0"
                           optional="show"/>
                    <field name="currency_id"       column_invisible="1"/>
                    <field name="state"             widget="badge"
                           decoration-muted="state == 'draft'"
                           decoration-info="state == 'ready'"
                           decoration-warning="state == 'in_progress'"
                           decoration-success="state in ('completed', 'closed')"/>
                </list>
            </field>
        </record>


        <!-- ══════════════════════════════════════════════════════════════════
             FORM
        ══════════════════════════════════════════════════════════════════ -->

        <record id="view_farm_job_order_form" model="ir.ui.view">
            <field name="name">farm.job.order.form</field>
            <field name="model">farm.job.order</field>
            <field name="arch" type="xml">
                <form string="Job Order">
                    <header>
                        <!-- Workflow buttons -->
                        <button name="action_set_ready"
                                type="object"
                                string="Mark Ready"
                                class="btn-secondary"
                                invisible="state != 'draft'"
                                groups="smart_farm_execution.group_smart_farm_execution_user"/>
                        <button name="action_start"
                                type="object"
                                string="Start Work"
                                class="btn-primary"
                                invisible="state != 'ready'"
                                groups="smart_farm_execution.group_smart_farm_execution_user"/>
                        <button name="action_complete"
                                type="object"
                                string="Complete"
                                class="btn-success"
                                invisible="state != 'in_progress'"
                                groups="smart_farm_execution.group_smart_farm_execution_user"/>
                        <button name="action_close"
                                type="object"
                                string="Close"
                                class="btn-secondary"
                                invisible="state != 'completed'"
                                groups="smart_farm_execution.group_smart_farm_execution_manager"
                                confirm="Close this Job Order? Ensure all materials, labour, and progress are fully recorded."/>
                        <button name="action_reset_draft"
                                type="object"
                                string="Reset to Draft"
                                class="btn-secondary"
                                invisible="state not in ('ready', 'in_progress')"
                                groups="smart_farm_execution.group_smart_farm_execution_manager"/>
                        <!-- Utility buttons -->
                        <button name="action_populate_resources"
                                type="object"
                                string="Populate Resources"
                                icon="fa-magic"
                                class="btn-secondary"
                                invisible="state not in ('draft', 'ready')"
                                groups="smart_farm_execution.group_smart_farm_execution_user"
                                confirm="Populate planned material lines from the BOQ template? Existing lines will be preserved."/>
                        <button name="action_request_materials"
                                type="object"
                                string="Request Materials"
                                icon="fa-cubes"
                                class="btn-warning"
                                invisible="state not in ('ready', 'in_progress')"
                                groups="smart_farm_execution.group_smart_farm_execution_user"
                                confirm="Request all planned materials? This will create a stock transfer request."/>
                        <button name="action_view_analysis"
                                type="object"
                                string="View Analysis"
                                icon="fa-bar-chart"
                                class="btn-secondary"
                                invisible="not analysis_id"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,ready,in_progress,completed,closed"/>
                    </header>

                    <sheet>
                        <!-- Smart buttons -->
                        <div class="oe_button_box" name="button_box">
                            <button class="oe_stat_button"
                                    type="object"
                                    name="action_view_materials"
                                    icon="fa-cubes">
                                <field name="material_count"
                                       widget="statinfo"
                                       string="Materials"/>
                            </button>
                            <button class="oe_stat_button"
                                    type="object"
                                    name="action_view_labour"
                                    icon="fa-clock-o">
                                <field name="labour_count"
                                       widget="statinfo"
                                       string="Labour"/>
                            </button>
                            <button class="oe_stat_button"
                                    type="object"
                                    name="action_view_progress_logs"
                                    icon="fa-bar-chart">
                                <field name="progress_log_count"
                                       widget="statinfo"
                                       string="Progress Logs"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <notebook>

                            <!-- ═════════════════════════════════════════════
                                 TAB 1 — GENERAL
                            ═════════════════════════════════════════════ -->
                            <page string="General" name="general_tab">
                                <group>
                                    <group string="Project &amp; Scope">
                                        <field name="project_id"
                                               options="{'no_create': True}"
                                               readonly="state not in ('draft', 'ready')"/>
                                        <field name="analysis_id"
                                               options="{'no_create': True}"
                                               readonly="state not in ('draft', 'ready')"/>
                                        <field name="boq_id" readonly="1"/>
                                        <field name="boq_line_id"
                                               options="{'no_create': True}"
                                               readonly="state not in ('draft', 'ready')"/>
                                        <field name="analysis_line_id"
                                               options="{'no_create': True}"
                                               readonly="state not in ('draft', 'ready')"/>
                                        <field name="display_code" readonly="1"/>
                                    </group>
                                    <group string="Classification">
                                        <field name="division_id"         readonly="1"/>
                                        <field name="subdivision_id"      readonly="1"/>
                                        <field name="sub_subdivision_id"  readonly="1"/>
                                        <field name="work_type_id"
                                               options="{'no_create': True}"/>
                                        <field name="discipline"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Planning">
                                        <field name="planned_qty"/>
                                        <field name="unit_id"
                                               options="{'no_create': True}"/>
                                        <field name="planned_start_date"/>
                                        <field name="planned_end_date"/>
                                    </group>
                                    <group string="Actual Dates" invisible="state == 'draft'">
                                        <field name="actual_start_date" readonly="1"/>
                                        <field name="actual_end_date"   readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ═════════════════════════════════════════════
                                 TAB 2 — PROGRESS
                            ═════════════════════════════════════════════ -->
                            <page string="Progress" name="progress_tab">
                                <!-- Alert: ready to complete -->
                                <div class="alert alert-success mb-3"
                                     role="alert"
                                     invisible="not (progress_percent &gt;= 100 and state == 'in_progress')">
                                    <strong>✓ 100% Reached.</strong>
                                    Executed quantity equals planned quantity.
                                    Click <strong>Complete</strong> in the header to finalise this Job Order.
                                </div>
                                <!-- Alert: over-executed -->
                                <div class="alert alert-warning mb-3"
                                     role="alert"
                                     invisible="not (progress_percent &gt; 100 and state in ('in_progress', 'completed'))">
                                    <strong>⚠ Over-executed.</strong>
                                    Executed quantity exceeds the planned quantity.
                                    Review quantities before closing.
                                </div>

                                <group>
                                    <group string="Execution Progress">
                                        <field name="planned_qty"      readonly="1"/>
                                        <field name="unit_id"          readonly="1"/>
                                        <field name="executed_qty"
                                               help="Auto-updated from Progress Logs below. Can also be entered manually."/>
                                        <field name="progress_percent"
                                               widget="progressbar"
                                               readonly="1"/>
                                    </group>
                                </group>

                                <!-- Progress log -->
                                <separator string="Progress Log (Audit Trail — auto-syncs Executed Qty)"/>
                                <div class="mb-2 d-flex gap-2">
                                    <button name="action_sync_progress_from_logs"
                                            type="object"
                                            string="Re-sync from Logs"
                                            icon="fa-refresh"
                                            class="btn btn-secondary btn-sm"
                                            confirm="Re-sync Executed Qty from the sum of all progress log increments?"/>
                                </div>
                                <field name="progress_log_ids">
                                    <list string="Progress Logs" editable="bottom">
                                        <field name="date"/>
                                        <field name="executed_increment"
                                               string="Qty Executed"/>
                                        <field name="note"
                                               string="Site Note"/>
                                        <field name="logged_by"
                                               readonly="1"
                                               optional="show"/>
                                    </list>
                                </field>
                            </page>

                            <!-- ═════════════════════════════════════════════
                                 TAB 3 — MATERIALS
                            ═════════════════════════════════════════════ -->
                            <page string="Materials" name="materials_tab">
                                <field name="material_ids">
                                    <list string="Material Consumption"
                                          editable="bottom"
                                          decoration-muted="state == 'cancelled'"
                                          decoration-success="state == 'consumed'">
                                        <field name="product_id"
                                               options="{'no_create': True}"/>
                                        <field name="description"/>
                                        <field name="uom_id"
                                               string="UoM"
                                               options="{'no_create': True}"/>
                                        <field name="planned_qty"    string="Plan Qty"/>
                                        <field name="requested_qty"  string="Req. Qty"
                                               optional="show"/>
                                        <field name="issued_qty"     string="Issued Qty"
                                               optional="show"/>
                                        <field name="consumed_qty"   string="Used Qty"/>
                                        <field name="unit_cost"      string="Unit Cost"/>
                                        <field name="planned_cost"   string="Plan Cost"
                                               readonly="1" optional="show"/>
                                        <field name="actual_cost"    string="Actual Cost"
                                               readonly="1"
                                               decoration-danger="actual_cost &gt; planned_cost and planned_cost &gt; 0"
                                               decoration-success="actual_cost &lt;= planned_cost and actual_cost &gt; 0"/>
                                        <field name="state"          widget="badge"
                                               decoration-muted="state == 'draft'"
                                               decoration-info="state == 'requested'"
                                               decoration-warning="state == 'issued'"
                                               decoration-success="state == 'consumed'"
                                               decoration-danger="state == 'cancelled'"/>
                                        <field name="stock_picking_id"   optional="hide" readonly="1"/>
                                        <field name="source_location_id" optional="hide"/>
                                        <field name="dest_location_id"   optional="hide"/>
                                    </list>
                                </field>
                                <group>
                                    <group string="Material Cost Summary">
                                        <field name="planned_material_cost"
                                               string="Planned Material Cost"
                                               readonly="1"/>
                                        <field name="actual_material_cost"
                                               string="Actual Material Cost"
                                               readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ═════════════════════════════════════════════
                                 TAB 4 — LABOUR
                            ═════════════════════════════════════════════ -->
                            <page string="Labour" name="labour_tab">
                                <field name="labour_ids">
                                    <list string="Labour Entries" editable="bottom">
                                        <field name="employee_id"
                                               options="{'no_create': True}"/>
                                        <field name="date"/>
                                        <field name="description"/>
                                        <field name="hours"         string="Hours"/>
                                        <field name="cost_per_hour" string="Rate / hr"/>
                                        <field name="total_cost"    string="Total Cost"
                                               readonly="1"/>
                                        <field name="timesheet_id"  optional="hide"/>
                                    </list>
                                </field>
                                <group>
                                    <group string="Labour Cost Summary">
                                        <field name="actual_labour_cost"
                                               string="Actual Labour Cost"
                                               readonly="1"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ═════════════════════════════════════════════
                                 TAB 5 — COST SUMMARY
                            ═════════════════════════════════════════════ -->
                            <page string="Cost Summary" name="cost_tab">
                                <field name="currency_id" invisible="1"/>
                                <group>
                                    <group string="Planned">
                                        <field name="planned_cost"
                                               string="Planned Total (from Analysis)"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="planned_material_cost"
                                               string="Planned Material Cost"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                    </group>
                                    <group string="Actual">
                                        <field name="actual_material_cost"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="actual_labour_cost"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="actual_subcontract_cost"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="actual_other_cost"
                                               string="Other Cost"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="actual_total_cost"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Variance">
                                        <field name="cost_variance"
                                               readonly="1"
                                               decoration-danger="cost_variance &gt; 0"
                                               decoration-success="cost_variance &lt;= 0 and actual_total_cost &gt; 0"/>
                                        <field name="cost_variance_percent"
                                               string="Variance %"
                                               readonly="1"
                                               widget="percentage"/>
                                    </group>
                                    <group string="Progress">
                                        <field name="planned_qty"      readonly="1"/>
                                        <field name="executed_qty"     readonly="1"/>
                                        <field name="progress_percent" readonly="1"
                                               widget="progressbar"/>
                                    </group>
                                </group>
                            </page>

                            <!-- ═════════════════════════════════════════════
                                 TAB 6 — NOTES
                            ═════════════════════════════════════════════ -->
                            <page string="Notes" name="notes_tab">
                                <group>
                                    <group string="General Notes">
                                        <field name="notes"
                                               nolabel="1"
                                               placeholder="General observations, context, approvals…"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Instructions">
                                        <field name="instruction_notes"
                                               nolabel="1"
                                               placeholder="Work instructions, safety notes, method statements…"/>
                                    </group>
                                </group>
                                <group>
                                    <group string="Inspection Notes">
                                        <field name="inspection_notes"
                                               nolabel="1"
                                               placeholder="Quality control, inspection findings, sign-off…"/>
                                    </group>
                                </group>
                            </page>

                        </notebook>
                    </sheet>

                    <chatter/>
                </form>
            </field>
        </record>


        <!-- ══════════════════════════════════════════════════════════════════
             ACTION
        ══════════════════════════════════════════════════════════════════ -->

        <record id="action_farm_job_order" model="ir.actions.act_window">
            <field name="name">Job Orders</field>
            <field name="res_model">farm.job.order</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_farm_job_order_search"/>
            <field name="context">{'search_default_not_closed': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No Job Orders yet.
                </p>
                <p>
                    Open an approved BOQ Analysis document and click
                    <strong>Generate Job Orders</strong>
                    to create execution records from approved analysis lines.
                </p>
            </field>
        </record>

    </data>
</odoo>
