<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===== farm.project — list ===== -->

        <record id="view_farm_project_list" model="ir.ui.view">
            <field name="name">farm.project.list</field>
            <field name="model">farm.project</field>
            <field name="arch" type="xml">
                <list string="Lavandula Projects">
                    <field name="name"/>
                    <field name="business_activity" widget="badge"
                           decoration-info="business_activity == 'construction'"
                           decoration-success="business_activity == 'agriculture'"
                           decoration-warning="business_activity == 'manufacturing'"
                           decoration-danger="business_activity == 'livestock'"
                           optional="show"/>
                    <field name="project_type" optional="show"/>
                    <field name="project_manager_id" optional="show"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'draft'"
                           decoration-success="state == 'running'"
                           decoration-muted="state == 'done'"/>
                    <field name="analytic_account_id" optional="show"/>
                    <field name="odoo_project_id" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ===== farm.project — form ===== -->

        <record id="view_farm_project_form" model="ir.ui.view">
            <field name="name">farm.project.form</field>
            <field name="model">farm.project</field>
            <field name="arch" type="xml">
                <form string="Farm Project">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,running,done"/>
                    </header>
                    <sheet>

                        <!-- ── KPI SMART BUTTON STRIP ────────────────────────
                             Modern KPI card row (replaces oe_button_box).
                             Placed as the FIRST element inside <sheet> — the
                             standard Odoo position for stat-button containers.
                             name="button_box" kept for xpath compatibility:
                             all inherited modules (boq, execution, contract…)
                             still inject via //div[@name='button_box'].
                        ──────────────────────────────────────────────────── -->
                        <div class="epd-mini-kpi-strip" name="button_box">

                            <!-- Fields — card IS the button -->
                            <button name="action_open_fields" type="object"
                                    class="epd-mini-kpi epd-mini-kpi--green"
                                    title="Open Fields">
                                <i class="fa fa-map-marker epd-mini-icon" title="Fields"/>
                                <div class="epd-mini-value">
                                    <field name="field_count" nolabel="1"/>
                                </div>
                                <div class="epd-mini-label">Fields</div>
                            </button>

                            <!-- Tasks — only when linked to an Odoo project -->
                            <button name="action_open_tasks" type="object"
                                    class="epd-mini-kpi epd-mini-kpi--blue"
                                    title="Open Tasks"
                                    invisible="not odoo_project_id">
                                <i class="fa fa-check-square-o epd-mini-icon" title="Tasks"/>
                                <div class="epd-mini-value">
                                    <field name="task_count" nolabel="1"/>
                                </div>
                                <div class="epd-mini-label">Tasks</div>
                            </button>

                            <!-- ── Activity Sub-Project smart buttons ──────── -->

                            <!-- Construction Projects -->
                            <button name="action_view_construction_projects" type="object"
                                    class="epd-mini-kpi epd-mini-kpi--blue"
                                    title="Construction Projects"
                                    invisible="construction_project_count == 0">
                                <i class="fa fa-building-o epd-mini-icon" title="Construction Projects"/>
                                <div class="epd-mini-value">
                                    <field name="construction_project_count" nolabel="1"/>
                                </div>
                                <div class="epd-mini-label">Construction</div>
                            </button>

                            <!-- Agriculture Projects -->
                            <button name="action_view_agriculture_projects" type="object"
                                    class="epd-mini-kpi epd-mini-kpi--green"
                                    title="Agriculture Projects"
                                    invisible="agriculture_project_count == 0">
                                <i class="fa fa-leaf epd-mini-icon" title="Agriculture Projects"/>
                                <div class="epd-mini-value">
                                    <field name="agriculture_project_count" nolabel="1"/>
                                </div>
                                <div class="epd-mini-label">Agriculture</div>
                            </button>

                            <!-- Manufacturing Projects -->
                            <button name="action_view_manufacturing_projects" type="object"
                                    class="epd-mini-kpi epd-mini-kpi--orange"
                                    title="Manufacturing Projects"
                                    invisible="manufacturing_project_count == 0">
                                <i class="fa fa-industry epd-mini-icon" title="Manufacturing Projects"/>
                                <div class="epd-mini-value">
                                    <field name="manufacturing_project_count" nolabel="1"/>
                                </div>
                                <div class="epd-mini-label">Manufacturing</div>
                            </button>

                            <!-- Livestock Projects -->
                            <button name="action_view_livestock_projects" type="object"
                                    class="epd-mini-kpi epd-mini-kpi--red"
                                    title="Livestock Projects"
                                    invisible="livestock_project_count == 0">
                                <i class="fa fa-paw epd-mini-icon" title="Livestock Projects"/>
                                <div class="epd-mini-value">
                                    <field name="livestock_project_count" nolabel="1"/>
                                </div>
                                <div class="epd-mini-label">Livestock</div>
                            </button>

                            <!-- ── Positional anchors (display:none) ─────────────
                                 Used by inherited modules to inject buttons in the
                                 correct logical group instead of always appending.
                                 Group order:
                                   Execution  → Job Orders, Contracts
                                   Planning   → Cost Structures, BOQ Analysis
                                   Procurement → Materials, Procurement, POs
                                   AI         → AI Risk, AI Brain
                            ──────────────────────────────────────────────────── -->
                            <div name="anchor_execution_end"  class="d-none"/>
                            <div name="anchor_planning_end"   class="d-none"/>
                            <div name="anchor_procurement_end" class="d-none"/>
                            <div name="anchor_ai_end"         class="d-none"/>

                        </div>

                        <!-- ── PROJECT TITLE ──────────────────────────────── -->
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Project Name…"/>
                            </h1>
                        </div>

                        <!-- ── MAIN ACTION BUTTONS ───────────────────────────
                             Anchor div for action buttons injected by sub-modules.
                             smart_farm_boq injects "New BOQ" here.
                        ──────────────────────────────────────────────────── -->
                        <div class="d-flex flex-wrap gap-3 mb-4"
                             name="main_action_buttons"/>

                        <!-- ── MAIN INFO — 2-column ───────────────────────────
                             LEFT  (group_project_details):
                               Business Activity, Lifecycle Stage
                               Analytic Account, Start Date, End Date
                               + Project Phase injected by smart_farm_boq

                             RIGHT (group_project_link):
                               Odoo Project, Project Manager, Tags, Project Type
                        ──────────────────────────────────────────────────── -->
                        <group>
                            <group string="Activity &amp; Classification"
                                   name="group_project_details">
                                <!--
                                    business_activity is editable in Smart Farm (no context default).
                                    When opened from an activity app (default_business_activity set in
                                    context) it becomes readonly — the app enforces its own activity.
                                -->
                                <field name="business_activity" widget="radio"
                                       options="{'horizontal': true}"
                                       readonly="context.get('default_business_activity', False) != False"/>
                                <field name="analytic_account_id"
                                       options="{'no_create': True}"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <!-- project_phase_id injected here by smart_farm_boq -->
                            </group>
                            <group string="Responsibility &amp; Type"
                                   name="group_project_link">
                                <field name="odoo_project_id"
                                       options="{'no_create': True}"/>
                                <field name="project_manager_id"
                                       options="{'no_create': True}"/>
                                <field name="project_tag_ids"
                                       widget="many2many_tags"
                                       options="{'no_create': True, 'no_open': True}"
                                       placeholder="Tags…"/>
                            </group>
                        </group>

                        <!-- ── NOTEBOOK TABS ─────────────────────────────── -->
                        <notebook>

                            <!-- 1 · Description -->
                            <page string="Description" name="tab_description">
                                <field name="description"
                                       placeholder="Add a project description…"/>
                            </page>

                            <!-- 2 · Location -->
                            <page string="Location" name="tab_location">
                                <group>
                                    <group string="Address">
                                        <field name="country_id"
                                               options="{'no_create': True}"/>
                                        <field name="state_id"
                                               options="{'no_create': True}"
                                               domain="[('country_id', '=', country_id)]"/>
                                        <field name="city"/>
                                    </group>
                                    <group string="GPS Coordinates">
                                        <field name="latitude"/>
                                        <field name="longitude"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="location_text"
                                           placeholder="Additional location details, landmarks, access route…"/>
                                </group>
                            </page>

                            <!-- 3 · Consists -->
                            <page string="Consists" name="tab_consists">
                                <field name="consists_notes"
                                       placeholder="Describe what this project consists of — scope, major components, deliverables…"/>
                            </page>

                            <!-- 4 · Documents -->
                            <page string="Documents" name="tab_documents">
                                <group>
                                    <field name="document_notes"
                                           string="Document Notes"
                                           placeholder="List key documents, reference numbers, contract details, or filing notes…"/>
                                </group>
                                <div class="alert alert-info mt-2" role="alert">
                                    <i class="fa fa-paperclip me-2" title="Attach Files"/>
                                    <strong>Attach Files</strong> — Contracts, permits,
                                    specifications, and reports can be attached using the
                                    <strong>chatter below</strong> (paperclip icon).
                                    All attachments are version-tracked and searchable.
                                </div>
                            </page>

                            <!-- 5 · Drawings -->
                            <page string="Drawings" name="tab_drawings">
                                <group>
                                    <field name="drawing_notes"
                                           string="Drawing References / Notes"
                                           placeholder="Drawing numbers, revision history, or reference links…"/>
                                </group>
                                <div class="alert alert-info mt-2" role="alert">
                                    <i class="fa fa-file-image-o me-2" title="Drawing Files"/>
                                    <strong>Drawing Files</strong> (PDF, DWG, DXF) —
                                    attach via the chatter below.
                                </div>
                            </page>

                            <!-- 6 · Area -->
                            <page string="Area" name="tab_area">
                                <group string="Area Breakdown">
                                    <group>
                                        <field name="total_project_area"
                                               string="Total Project Area (ha)"/>
                                        <field name="cultivated_area"
                                               string="Cultivated Area (ha)"/>
                                        <field name="builtup_area"
                                               string="Built-up Area (ha)"/>
                                    </group>
                                </group>
                            </page>

                            <!-- 7 · Fields -->
                            <page string="Fields" name="tab_fields">
                                <field name="field_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="crop_type_id"/>
                                        <field name="area_m2" string="Area (m²)"/>
                                        <field name="notes" optional="show"/>
                                    </list>
                                </field>
                            </page>

                            <!-- 8 · Teams -->
                            <page string="Teams" name="tab_teams">
                                <group string="Project Team Members">
                                    <field name="team_member_ids"
                                           nolabel="1"
                                           widget="many2many_tags"
                                           options="{'no_create': True}"
                                           placeholder="Add team members…"/>
                                </group>
                            </page>

                            <!-- 9 · Zones -->
                            <page string="Zones" name="tab_zones">
                                <field name="zone_notes"
                                       placeholder="Describe project zones, internal sub-areas, or land parcels…"/>
                            </page>

                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ===== Search view ===== -->

        <record id="view_farm_project_search" model="ir.ui.view">
            <field name="name">farm.project.search</field>
            <field name="model">farm.project</field>
            <field name="arch" type="xml">
                <search string="Lavandula Projects">
                    <field name="name"/>
                    <field name="business_activity" string="Business Activity"/>
                    <field name="project_type" string="Project Type"/>
                    <field name="project_manager_id"/>
                    <field name="analytic_account_id"/>
                    <!-- Activity filters -->
                    <filter string="Construction" name="filter_construction"
                            domain="[('business_activity', '=', 'construction')]"/>
                    <filter string="Agriculture" name="filter_agriculture"
                            domain="[('business_activity', '=', 'agriculture')]"/>
                    <filter string="Manufacturing" name="filter_manufacturing"
                            domain="[('business_activity', '=', 'manufacturing')]"/>
                    <filter string="Livestock" name="filter_livestock"
                            domain="[('business_activity', '=', 'livestock')]"/>
                    <separator/>
                    <!-- State filters -->
                    <filter string="Draft" name="filter_draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Running" name="filter_running"
                            domain="[('state', '=', 'running')]"/>
                    <filter string="Done" name="filter_done"
                            domain="[('state', '=', 'done')]"/>
                    <separator/>
                    <!-- Group by -->
                    <group expand="0" string="Group By">
                        <filter string="Business Activity" name="group_activity"
                                context="{'group_by': 'business_activity'}"/>
                        <!-- project_phase_id group-by injected by smart_farm_boq search inherit -->
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                        <filter string="Project Manager" name="group_manager"
                                context="{'group_by': 'project_manager_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ===== Action ===== -->

        <record id="action_farm_project" model="ir.actions.act_window">
            <field name="name">Lavandula Projects</field>
            <field name="res_model">farm.project</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_farm_project_search"/>
        </record>

    </data>
</odoo>
