<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_farm_field_list" model="ir.ui.view">
            <field name="name">farm.field.list</field>
            <field name="model">farm.field</field>
            <field name="arch" type="xml">
                <list string="Farm Fields">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="crop_type_id"/>
                    <field name="area_m2" string="Area (m²)"/>
                </list>
            </field>
        </record>

        <record id="view_farm_field_form" model="ir.ui.view">
            <field name="name">farm.field.form</field>
            <field name="model">farm.field</field>
            <field name="arch" type="xml">
                <form string="Farm Field">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Field Name…"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Details">
                                <field name="project_id"/>
                                <field name="crop_type_id"/>
                                <field name="area_m2" string="Area (m²)"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Notes">
                                <field name="notes" placeholder="Add notes…"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_farm_field" model="ir.actions.act_window">
            <field name="name">Fields</field>
            <field name="res_model">farm.field</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
