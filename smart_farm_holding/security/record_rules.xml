<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            ══════════════════════════════════════════════════════════════════
            SMART FARM HOLDING — DATA ISOLATION RECORD RULES
            ══════════════════════════════════════════════════════════════════

            STRATEGY:
            • Holding Managers bypass all rules (no rule restricts them)
            • Activity Company Managers and Users see only their allowed companies
            • Rules use `allowed_company_ids` from the user context (standard Odoo
              multi-company mechanism) + our enterprise groups

            MODELS COVERED (Smart Farm engine — all filtered by company):
            • farm.project     — all activities (construction/agriculture/mfg/livestock)
            • farm.job.order   — all execution records
            • farm.boq         — bill of quantities
            • farm.material.request — material procurement requests

            NOTE: Separate activity-specific models (agriculture.season,
            livestock.herd, manufacturing.plan, construction.project) are no longer
            used. All activities run on the unified Smart Farm engine.
            ══════════════════════════════════════════════════════════════════
        -->

        <!-- ── farm.project ──────────────────────────────────────────────── -->

        <record id="rule_farm_project_company" model="ir.rule">
            <field name="name">Farm Project — Company Isolation</field>
            <field name="model_id" ref="smart_farm_project.model_farm_project"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[
                (4, ref('group_activity_user')),
                (4, ref('group_activity_company_manager')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- ── smartfarm.company.activity ────────────────────────────────── -->

        <!-- Only Holding Managers can see ALL company configs -->
        <record id="rule_company_activity_manager" model="ir.rule">
            <field name="name">Company Activity Config — Holding Manager Bypass</field>
            <field name="model_id" ref="model_smartfarm_company_activity"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_holding_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
