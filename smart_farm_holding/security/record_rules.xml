<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            ══════════════════════════════════════════════════════════════════
            SMART FARM HOLDING — DATA ISOLATION RECORD RULES
            ══════════════════════════════════════════════════════════════════

            STRATEGY:
            • Holding Managers bypass all rules (no rule restricts them)
            • Activity Company Managers and Users see only their allowed companies
            • Rules use `allowed_company_ids` from the user context (standard Odoo
              multi-company mechanism) + our enterprise groups

            MODELS COVERED:
            • farm.project                (Agriculture / Manufacturing / Livestock projects)
            • agriculture.season          (Agriculture operations)
            • agriculture.crop.plan
            • agriculture.field.operation
            • agriculture.harvest
            • agriculture.packing
            • manufacturing.plan          (Manufacturing operations)
            • manufacturing.work.order
            • manufacturing.qc.check
            • manufacturing.dispatch
            • livestock.herd              (Livestock operations)
            • livestock.animal
            • livestock.health.check
            • livestock.feeding.plan
            • livestock.sale
            • construction.project        (Construction operations)
            ══════════════════════════════════════════════════════════════════
        -->

        <!-- ── farm.project ──────────────────────────────────────────────── -->

        <record id="rule_farm_project_company" model="ir.rule">
            <field name="name">Farm Project — Company Isolation</field>
            <field name="model_id" ref="smart_farm_project.model_farm_project"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
            <field name="groups" eval="[
                (4, ref('group_activity_user')),
                (4, ref('group_activity_company_manager')),
            ]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

