<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            ══════════════════════════════════════════════════════════════════
            HOLDING MENUS — frozen until Construction is complete
            ══════════════════════════════════════════════════════════════════

            "Holding Dashboard" and "All Companies" cross-company menus are
            hidden at DB level (active=False).  They are NOT deleted —
            the views, models, and security groups are fully preserved.

            Once Construction is stabilised and Agriculture / Manufacturing /
            Livestock workflows are ready, these menus will be re-enabled.

            The only holding-visible items are admin-only configuration
            entries (Company Activity Setup, Enterprise Groups), which are
            restricted to group_holding_manager and rarely needed.
            ══════════════════════════════════════════════════════════════════
        -->

        <!-- Holding Dashboard — deactivated, re-enable after all activities complete -->
        <menuitem
            id="menu_holding_dashboard"
            name="Holding Dashboard"
            parent="smart_farm_base.menu_smart_farm_root"
            action="action_holding_dashboard"
            sequence="1"
            groups="smart_farm_holding.group_holding_manager,smart_farm_holding.group_activity_company_manager"/>

        <!-- All Companies parent — deactivated -->
        <menuitem
            id="menu_holding_cross_company"
            name="All Companies"
            parent="smart_farm_base.menu_smart_farm_root"
            sequence="2"
            groups="smart_farm_holding.group_holding_manager"/>

        <!-- Cross-company sub-items (preserved, accessible via parent when re-enabled) -->
        <menuitem
            id="menu_holding_all_farm_projects"
            name="All Projects"
            parent="menu_holding_cross_company"
            action="smart_farm_project.action_farm_project"
            sequence="10"/>
        <menuitem
            id="menu_holding_all_construction"
            name="Construction Projects"
            parent="menu_holding_cross_company"
            action="smart_farm_construction.action_con_projects"
            sequence="20"/>
        <menuitem
            id="menu_holding_all_agriculture"
            name="Agriculture Projects"
            parent="menu_holding_cross_company"
            action="smart_farm_agriculture.action_agr_projects"
            sequence="30"/>
        <menuitem
            id="menu_holding_all_manufacturing"
            name="Manufacturing Projects"
            parent="menu_holding_cross_company"
            action="smart_farm_manufacturing.action_mfg_projects"
            sequence="40"/>
        <menuitem
            id="menu_holding_all_livestock"
            name="Livestock Projects"
            parent="menu_holding_cross_company"
            action="smart_farm_livestock.action_ls_projects"
            sequence="50"/>

        <!-- Configuration: Company Activity Setup (admin-only, preserved) -->
        <menuitem
            id="menu_company_activity_setup"
            name="Company Activity Setup"
            parent="smart_farm_base.menu_smart_farm_config"
            action="action_company_activity_setup"
            sequence="5"
            groups="smart_farm_holding.group_holding_manager"/>

        <!-- Configuration: Enterprise Groups (admin-only, preserved) -->
        <menuitem
            id="menu_holding_config_security"
            name="Enterprise Groups"
            parent="smart_farm_base.menu_smart_farm_config"
            action="base_setup.action_general_configuration"
            sequence="6"
            groups="smart_farm_holding.group_holding_manager"/>

        <!-- ══ Deactivate the Holding Dashboard and All Companies menus ══ -->
        <record id="menu_holding_dashboard"       model="ir.ui.menu"><field name="active" eval="False"/></record>
        <record id="menu_holding_cross_company"   model="ir.ui.menu"><field name="active" eval="False"/></record>

        <!-- ══ Deactivate Configuration entries not needed in day-to-day use ══ -->
        <record id="menu_company_activity_setup"      model="ir.ui.menu"><field name="active" eval="False"/></record>
        <record id="menu_holding_config_security"     model="ir.ui.menu"><field name="active" eval="False"/></record>

    </data>
</odoo>
