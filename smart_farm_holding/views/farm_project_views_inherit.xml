<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===== farm.project form — holding overlay ===== -->
        <!--
            When smart_farm_holding is installed, business_activity is derived
            from the company-activity mapping on existing (non-draft) projects.

            Rules:
              - Draft / new project: user may freely select the activity (radio).
              - Activity-app context (default_business_activity in ctx): readonly
                regardless of state — the app enforces its own activity.
              - Running / done project: readonly — activity is fixed at this point.

            This view:
              1. Makes business_activity readonly only when appropriate.
              2. Injects project_label above it so users see "Construction Project" etc.
              3. Injects company_id into the right group.
        -->

        <record id="view_farm_project_holding_form_inherit" model="ir.ui.view">
            <field name="name">farm.project.holding.form.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">

                <!-- 1. Allow editing on draft/new; lock when activity-app context OR after draft -->
                <field name="business_activity" position="attributes">
                    <attribute name="readonly">context.get('default_business_activity', False) != False or state not in ('draft', False)</attribute>
                </field>

                <!-- 2. Inject project_label above business_activity -->
                <field name="business_activity" position="before">
                    <field name="project_label"
                           string="Project Type"
                           readonly="1"
                           invisible="not project_label"/>
                </field>

                <!-- 3. Inject company_id into the right-hand group -->
                <group name="group_project_link" position="inside">
                    <field name="company_id"
                           options="{'no_create': True}"
                           readonly="1"/>
                </group>

            </field>
        </record>

    </data>
</odoo>
