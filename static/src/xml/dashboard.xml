<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="smart_farm_alandleeb.Dashboard">
    <div class="sf_dashboard">

        <!-- ── Top Bar ──────────────────────────────────────────────── -->
        <div class="sf_topbar">
            <div class="sf_topbar_brand">
                <span class="sf_leaf">🌿</span>
                <div>
                    <h1 class="sf_title">Financial Performance</h1>
                    <p class="sf_subtitle">Smart Farm · Al Andleeb</p>
                </div>
            </div>

            <!-- Filters -->
            <div class="sf_filters">
                <div class="sf_filter_group">
                    <label class="sf_filter_label">Project</label>
                    <select multiple="multiple" class="sf_select"
                            t-on-change="onProjectChange">
                        <t t-foreach="state.filterOptions.projects" t-as="proj" t-key="proj.id">
                            <option t-att-value="proj.id" t-esc="proj.name"/>
                        </t>
                    </select>
                </div>

                <div class="sf_filter_group">
                    <label class="sf_filter_label">Stage</label>
                    <select multiple="multiple" class="sf_select"
                            t-on-change="onStageChange">
                        <t t-foreach="state.filterOptions.stages" t-as="stage" t-key="stage.id">
                            <option t-att-value="stage.id" t-esc="stage.name"/>
                        </t>
                    </select>
                </div>

                <div class="sf_filter_group">
                    <label class="sf_filter_label">From</label>
                    <input type="date" class="sf_input" t-on-change="onDateFromChange"
                           t-att-value="state.filters.date_from"/>
                </div>

                <div class="sf_filter_group">
                    <label class="sf_filter_label">To</label>
                    <input type="date" class="sf_input" t-on-change="onDateToChange"
                           t-att-value="state.filters.date_to"/>
                </div>

                <div class="sf_filter_actions">
                    <button class="sf_btn_primary" t-on-click="onApplyFilters">Apply</button>
                    <button class="sf_btn_ghost"   t-on-click="onResetFilters">Reset</button>
                </div>
            </div>
        </div>

        <!-- ── Loading / Error states ───────────────────────────────── -->
        <t t-if="state.loading">
            <div class="sf_loading">
                <div class="sf_spinner"/>
                <p>Loading dashboard…</p>
            </div>
        </t>

        <t t-elif="state.error">
            <div class="sf_error">
                <span class="sf_error_icon">⚠</span>
                <p t-esc="state.error"/>
                <button class="sf_btn_primary" t-on-click="() => this._loadData()">Retry</button>
            </div>
        </t>

        <!-- ── Dashboard body ───────────────────────────────────────── -->
        <t t-elif="state.data">
            <t t-set="kpi" t-value="state.data.kpi"/>

            <!-- ── Row 1: Primary KPI Cards ───────────────────────── -->
            <div class="sf_kpi_row sf_kpi_primary">

                <!-- Total Cost -->
                <div class="sf_kpi_card sf_kpi_cost">
                    <div class="sf_kpi_icon">💰</div>
                    <div class="sf_kpi_body">
                        <div class="sf_kpi_label">Total Project Cost</div>
                        <div class="sf_kpi_value" t-esc="fmt(kpi.total_cost)"/>
                        <div class="sf_kpi_sub">
                            Budget: <t t-esc="fmt(kpi.total_budget)"/>
                        </div>
                    </div>
                </div>

                <!-- Total Sales -->
                <div class="sf_kpi_card sf_kpi_sales">
                    <div class="sf_kpi_icon">📈</div>
                    <div class="sf_kpi_body">
                        <div class="sf_kpi_label">Total Sales</div>
                        <div class="sf_kpi_value" t-esc="fmt(kpi.total_sales)"/>
                        <div class="sf_kpi_sub">From confirmed quotations</div>
                    </div>
                </div>

                <!-- Total Profit -->
                <div t-attf-class="sf_kpi_card {{ isProfitable() ? 'sf_kpi_profit' : 'sf_kpi_loss' }}">
                    <div class="sf_kpi_icon" t-esc="isProfitable() ? '✅' : '🔴'"/>
                    <div class="sf_kpi_body">
                        <div class="sf_kpi_label">Net Profit / Loss</div>
                        <div class="sf_kpi_value" t-esc="fmt(kpi.total_profit)"/>
                        <div class="sf_kpi_sub">
                            <t t-esc="isProfitable() ? 'Profitable' : 'Below breakeven'"/>
                        </div>
                    </div>
                </div>

                <!-- Profit Margin -->
                <div t-attf-class="sf_kpi_card {{ kpi.profit_margin >= 0 ? 'sf_kpi_margin_pos' : 'sf_kpi_margin_neg' }}">
                    <div class="sf_kpi_icon">📊</div>
                    <div class="sf_kpi_body">
                        <div class="sf_kpi_label">Profit Margin</div>
                        <div class="sf_kpi_value" t-esc="fmtPct(kpi.profit_margin)"/>
                        <div class="sf_kpi_pct_bar">
                            <div class="sf_kpi_pct_fill"
                                 t-attf-style="width: {{ Math.min(Math.abs(kpi.profit_margin), 100) }}%; background: {{ kpi.profit_margin >= 0 ? '#16a34a' : '#ef4444' }}"/>
                        </div>
                    </div>
                </div>

            </div>

            <!-- ── Row 2: Secondary KPI Cards ─────────────────────── -->
            <div class="sf_kpi_row sf_kpi_secondary">

                <!-- Tasks -->
                <div class="sf_kpi_card sf_kpi_sm sf_kpi_neutral">
                    <div class="sf_kpi_sm_icon">📋</div>
                    <div class="sf_kpi_sm_val" t-esc="kpi.task_count"/>
                    <div class="sf_kpi_sm_lbl">Total Tasks</div>
                </div>

                <!-- Over budget -->
                <div class="sf_kpi_card sf_kpi_sm sf_kpi_danger">
                    <div class="sf_kpi_sm_icon">🔺</div>
                    <div class="sf_kpi_sm_val" t-esc="kpi.over_budget"/>
                    <div class="sf_kpi_sm_lbl">Over Budget</div>
                </div>

                <!-- Under budget -->
                <div class="sf_kpi_card sf_kpi_sm sf_kpi_success">
                    <div class="sf_kpi_sm_icon">✓</div>
                    <div class="sf_kpi_sm_val" t-esc="kpi.under_budget"/>
                    <div class="sf_kpi_sm_lbl">Under Budget</div>
                </div>

                <!-- Material cost -->
                <div class="sf_kpi_card sf_kpi_sm sf_kpi_green">
                    <div class="sf_kpi_sm_icon">🧱</div>
                    <div class="sf_kpi_sm_val" t-esc="fmt(kpi.total_material)"/>
                    <div class="sf_kpi_sm_lbl">Materials</div>
                </div>

                <!-- Labor cost -->
                <div class="sf_kpi_card sf_kpi_sm sf_kpi_blue">
                    <div class="sf_kpi_sm_icon">👷</div>
                    <div class="sf_kpi_sm_val" t-esc="fmt(kpi.total_labor)"/>
                    <div class="sf_kpi_sm_lbl">Labor</div>
                </div>

                <!-- Overhead cost -->
                <div class="sf_kpi_card sf_kpi_sm sf_kpi_amber">
                    <div class="sf_kpi_sm_icon">⚙</div>
                    <div class="sf_kpi_sm_val" t-esc="fmt(kpi.total_overhead)"/>
                    <div class="sf_kpi_sm_lbl">Overhead</div>
                </div>

            </div>

            <!-- ── Row 3: Charts ───────────────────────────────────── -->
            <div class="sf_charts_row">

                <!-- Bar chart: Cost vs Sales per project -->
                <div class="sf_chart_card sf_chart_wide">
                    <div class="sf_chart_header">
                        <span class="sf_chart_title">Cost vs Selling Price — By Project</span>
                        <span class="sf_chart_legend_hint">🟥 Cost · 🟩 Selling Price</span>
                    </div>
                    <div class="sf_chart_body">
                        <canvas t-ref="barCanvas" class="sf_canvas"/>
                    </div>
                </div>

                <!-- Pie chart: cost breakdown -->
                <div class="sf_chart_card sf_chart_narrow">
                    <div class="sf_chart_header">
                        <span class="sf_chart_title">Cost Breakdown</span>
                    </div>
                    <div class="sf_chart_body">
                        <canvas t-ref="pieCanvas" class="sf_canvas"/>
                    </div>
                </div>

            </div>

            <!-- ── Row 4: Line chart ───────────────────────────────── -->
            <div class="sf_charts_row">
                <div class="sf_chart_card sf_chart_full">
                    <div class="sf_chart_header">
                        <span class="sf_chart_title">Cost Trend Over Time</span>
                        <span class="sf_chart_legend_hint">🔴 Total · 🟢 Materials · 🔵 Labor</span>
                    </div>
                    <div class="sf_chart_body">
                        <canvas t-ref="lineCanvas" class="sf_canvas"/>
                    </div>
                </div>
            </div>

            <!-- ── Row 5: Top Tasks Table ──────────────────────────── -->
            <div class="sf_table_card">
                <div class="sf_chart_header">
                    <span class="sf_chart_title">Top Tasks by Cost</span>
                    <span class="sf_chart_legend_hint">Top 10 · sorted by total cost</span>
                </div>
                <div class="sf_table_wrap">
                    <table class="sf_table">
                        <thead>
                            <tr>
                                <th>Task</th>
                                <th>Project</th>
                                <th>Stage</th>
                                <th class="sf_num">Total Cost</th>
                                <th class="sf_num">Budget</th>
                                <th class="sf_num">Selling Price</th>
                                <th class="sf_num">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-if="state.data.top_tasks.length === 0">
                                <tr>
                                    <td colspan="7" class="sf_table_empty">No tasks found for current filters</td>
                                </tr>
                            </t>
                            <t t-foreach="state.data.top_tasks" t-as="task" t-key="task.id">
                                <tr t-attf-class="{{ task.over_budget ? 'sf_row_danger' : '' }}">
                                    <td class="sf_task_name" t-esc="task.name"/>
                                    <td class="sf_task_proj" t-esc="task.project"/>
                                    <td><span class="sf_stage_badge" t-esc="task.stage"/></td>
                                    <td class="sf_num sf_cost" t-esc="fmt(task.total_cost)"/>
                                    <td class="sf_num" t-esc="task.budget ? fmt(task.budget) : '—'"/>
                                    <td class="sf_num sf_sell" t-esc="task.selling ? fmt(task.selling) : '—'"/>
                                    <td class="sf_num">
                                        <span t-attf-class="sf_status_badge {{ task.over_budget ? 'sf_status_over' : 'sf_status_ok' }}">
                                            <t t-esc="task.over_budget ? '▲ Over' : '✓ OK'"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>

        </t><!-- end t-elif state.data -->

    </div>
</t>

</templates>
