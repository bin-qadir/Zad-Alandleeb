<odoo>
    <record id="view_boq_dashboard_mail_config_list" model="ir.ui.view"><field name="name">boq.dashboard.mail.config.list</field><field name="model">boq.dashboard.mail.config</field><field name="arch" type="xml"><list><field name="name"/><field name="company_id"/><field name="date_scope"/><field name="attach_excel"/><field name="attach_pdf"/><field name="last_sent_at"/><field name="last_sent_count"/><field name="active"/></list></field></record>
