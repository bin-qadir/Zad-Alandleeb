<odoo>
    <template id="report_boq_dashboard_snapshot">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>BOQ Dashboard Snapshot</h2>
                    <p><strong>Company:</strong> <span t-esc="company.name"/></p>
                    <p><strong>Date From:</strong> <span t-esc="filters.get('date_from') or '-'"/> &nbsp;&nbsp;<strong>Date To:</strong> <span t-esc="filters.get('date_to') or '-'"/></p>
                    <h3>Summary</h3>
                    <table class="table table-sm table-bordered">
                        <tr><td>Total Projects</td><td><span t-esc="summary['total_projects']"/></td></tr>
                        <tr><td>Total Tasks</td><td><span t-esc="summary['total_tasks']"/></td></tr>
                        <tr><td>Planned Cost</td><td><span t-esc="summary['total_cost_planned']"/></td></tr>
                        <tr><td>Actual Cost</td><td><span t-esc="summary['total_cost_actual']"/></td></tr>
                        <tr><td>Planned Sale</td><td><span t-esc="summary['total_sale_planned']"/></td></tr>
                        <tr><td>Planned Profit</td><td><span t-esc="summary['total_profit_planned']"/></td></tr>
                        <tr><td>Actual Profit</td><td><span t-esc="summary['total_profit_actual']"/></td></tr>
                        <tr><td>Average Actual Margin</td><td><span t-esc="summary['avg_actual_margin']"/>%</td></tr>
                        <tr><td>Over Budget Tasks</td><td><span t-esc="summary['over_budget_tasks']"/></td></tr>
                        <tr><td>Delayed Tasks</td><td><span t-esc="summary['delayed_tasks']"/></td></tr>
                        <tr><td>Low Margin Tasks</td><td><span t-esc="summary['low_margin_tasks']"/></td></tr>
                        <tr><td>AI Alerts</td><td><span t-esc="summary['ai_alerts']"/></td></tr>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>
