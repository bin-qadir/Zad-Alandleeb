<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ===== farm.material.request — list ===== -->

        <record id="view_farm_mr_list" model="ir.ui.view">
            <field name="name">farm.material.request.list</field>
            <field name="model">farm.material.request</field>
            <field name="arch" type="xml">
                <list string="Material Requests">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="job_order_id" optional="show"/>
                    <field name="requested_by" optional="show"/>
                    <field name="request_date"/>
                    <field name="state" widget="badge"
                           decoration-info="state == 'to_approve'"
                           decoration-warning="state == 'rfq' or state == 'ordered'"
                           decoration-success="state == 'approved' or state == 'received'"
                           decoration-danger="state == 'rejected'"/>
                    <field name="total_estimated_cost" string="Est. Cost"/>
                    <field name="total_actual_cost" string="Actual Cost" optional="show"/>
                    <field name="purchase_order_count" string="POs" optional="show"/>
                    <field name="currency_id" column_invisible="1"/>
                </list>
            </field>
        </record>

        <!-- ===== farm.material.request — form ===== -->

        <record id="view_farm_mr_form" model="ir.ui.view">
            <field name="name">farm.material.request.form</field>
            <field name="model">farm.material.request</field>
            <field name="arch" type="xml">
                <form string="Material Request">
                    <header>
                        <!-- Workflow buttons -->
                        <button name="action_submit"
                                string="Submit to PM"
                                type="object"
                                class="btn-primary"
                                invisible="state != 'draft'"/>
                        <button name="action_approve"
                                string="Approve"
                                type="object"
                                class="btn-success"
                                invisible="state != 'to_approve'"
                                groups="base.group_system"/>
                        <button name="action_reject"
                                string="Reject"
                                type="object"
                                class="btn-danger"
                                invisible="state != 'to_approve'"
                                groups="base.group_system"/>
                        <button name="action_reset_to_draft"
                                string="Reset to Draft"
                                type="object"
                                invisible="state not in ('rejected','draft')"
                                confirm="Reset this request to draft?"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,to_approve,approved,ordered,received"/>
                    </header>

                    <!-- Stat buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                name="action_open_purchase_orders"
                                type="object"
                                icon="fa-shopping-cart"
                                invisible="purchase_order_count == 0">
                            <field name="purchase_order_count"
                                   widget="statinfo"
                                   string="POs"/>
                        </button>
                    </div>

                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>

                        <!-- Rejection banner -->
                        <div class="alert alert-danger"
                             role="alert"
                             invisible="state != 'rejected'">
                            <strong>Rejected</strong> by
                            <field name="approved_by" readonly="1" nolabel="1"/>
                            — <field name="rejection_reason" readonly="1" nolabel="1"/>
                        </div>

                        <group>
                            <group string="Request Details">
                                <field name="project_id"
                                       options="{'no_create': True}"
                                       readonly="state not in ('draft','to_approve')"/>
                                <field name="job_order_id"
                                       options="{'no_create': True}"
                                       readonly="state not in ('draft','to_approve')"/>
                                <field name="requested_by"
                                       options="{'no_create': True}"
                                       readonly="state not in ('draft','to_approve')"/>
                                <field name="request_date"
                                       readonly="state not in ('draft','to_approve')"/>
                            </group>
                            <group string="Approval">
                                <field name="approved_by"
                                       readonly="1"
                                       invisible="not approved_by"/>
                                <field name="approval_date"
                                       readonly="1"
                                       invisible="not approval_date"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="total_estimated_cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1"/>
                                <field name="total_actual_cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"
                                       readonly="1"
                                       invisible="total_actual_cost == 0"/>
                            </group>
                        </group>

                        <!-- Material lines -->
                        <notebook>
                            <page string="Materials" name="tab_materials">
                                <field name="line_ids"
                                       readonly="state not in ('draft','to_approve')"
                                       nolabel="1">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="product_id"/>
                                        <field name="product_description" optional="hide"/>
                                        <field name="uom_id"/>
                                        <field name="boq_line_id"
                                               options="{'no_create': True}"
                                               optional="show"/>
                                        <field name="contract_qty"
                                               readonly="1"
                                               optional="show"
                                               decoration-muted="contract_qty == 0"/>
                                        <field name="previously_requested_qty"
                                               readonly="1"
                                               optional="show"
                                               decoration-warning="previously_requested_qty &gt; 0"/>
                                        <field name="remaining_qty"
                                               readonly="1"
                                               optional="show"
                                               decoration-danger="remaining_qty == 0"/>
                                        <field name="requested_qty"
                                               decoration-danger="requested_qty &gt; remaining_qty and remaining_qty &gt; 0"/>
                                        <field name="unit_cost"/>
                                        <field name="estimated_cost"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'parent.currency_id'}"/>
                                        <field name="vendor_id"
                                               options="{'no_create': True}"
                                               optional="show"/>
                                        <field name="received_qty"
                                               readonly="1"
                                               optional="show"
                                               decoration-success="received_qty &gt;= requested_qty"
                                               decoration-warning="received_qty &gt; 0 and received_qty &lt; requested_qty"/>
                                        <field name="actual_cost"
                                               readonly="1"
                                               widget="monetary"
                                               options="{'currency_field': 'parent.currency_id'}"
                                               optional="show"/>
                                        <field name="purchase_order_id"
                                               readonly="1"
                                               optional="show"/>
                                        <field name="product_uom_category_id"
                                               column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <page string="Notes" name="tab_notes">
                                <field name="notes"
                                       placeholder="Internal notes, site instructions, special requirements…"/>
                                <field name="rejection_reason"
                                       invisible="state != 'rejected'"
                                       readonly="1"
                                       string="Rejection Reason"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- ===== farm.material.request — search ===== -->

        <record id="view_farm_mr_search" model="ir.ui.view">
            <field name="name">farm.material.request.search</field>
            <field name="model">farm.material.request</field>
            <field name="arch" type="xml">
                <search string="Material Requests">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="job_order_id"/>
                    <field name="requested_by"/>
                    <!-- State filters -->
                    <filter string="Draft" name="filter_draft"
                            domain="[('state', '=', 'draft')]"/>
                    <filter string="Pending Approval" name="filter_pending"
                            domain="[('state', '=', 'to_approve')]"/>
                    <filter string="Approved" name="filter_approved"
                            domain="[('state', 'in', ('approved', 'rfq', 'ordered'))]"/>
                    <filter string="Received" name="filter_received"
                            domain="[('state', '=', 'received')]"/>
                    <filter string="Rejected" name="filter_rejected"
                            domain="[('state', '=', 'rejected')]"/>
                    <separator/>
                    <filter string="My Requests" name="filter_mine"
                            domain="[('requested_by', '=', uid)]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Project" name="group_project"
                                context="{'group_by': 'project_id'}"/>
                        <filter string="Job Order" name="group_jo"
                                context="{'group_by': 'job_order_id'}"/>
                        <filter string="Status" name="group_state"
                                context="{'group_by': 'state'}"/>
                        <filter string="Requested By" name="group_by_user"
                                context="{'group_by': 'requested_by'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ===== Reject wizard form ===== -->

        <record id="view_farm_mr_reject_wizard_form" model="ir.ui.view">
            <field name="name">farm.material.request.reject.wizard.form</field>
            <field name="model">farm.material.request.reject.wizard</field>
            <field name="arch" type="xml">
                <form string="Reject Material Request">
                    <sheet>
                        <group>
                            <field name="request_id" readonly="1"/>
                            <field name="rejection_reason"
                                   placeholder="Explain why this request is being rejected…"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_confirm_reject"
                                string="Confirm Reject"
                                type="object"
                                class="btn-danger"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <!-- ===== Action ===== -->

        <record id="action_farm_material_request" model="ir.actions.act_window">
            <field name="name">Material Requests</field>
            <field name="res_model">farm.material.request</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_farm_mr_search"/>
            <field name="context">{'search_default_filter_pending': 0}</field>
        </record>

        <record id="action_farm_material_request_pending" model="ir.actions.act_window">
            <field name="name">Pending Approvals</field>
            <field name="res_model">farm.material.request</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_farm_mr_search"/>
            <field name="domain">[('state', '=', 'to_approve')]</field>
        </record>

    </data>
</odoo>
