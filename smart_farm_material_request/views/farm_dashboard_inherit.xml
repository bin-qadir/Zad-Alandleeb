<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Inject Material Request KPI section into the Executive Dashboard.
            Replaces the placeholder div added by smart_farm_dashboard.
        -->

        <record id="view_farm_dashboard_mr_inherit" model="ir.ui.view">
            <field name="name">farm.dashboard.form.mr.inherit</field>
            <field name="model">farm.dashboard</field>
            <field name="inherit_id" ref="smart_farm_dashboard.view_farm_dashboard_form"/>
            <field name="arch" type="xml">

                <xpath expr="//div[@id='epd_procurement_section_placeholder']"
                       position="replace">

                    <!-- ══════════════════════════════════════════
                         § 4 — PROCUREMENT
                    ══════════════════════════════════════════ -->
                    <div class="epd-section">
                        <div class="epd-section-hdr">
                            <i class="fa fa-shopping-cart"/> Procurement
                        </div>
                        <div class="epd-section-body">

                            <div class="epd-row-label">Material Request Status</div>
                            <div class="row g-3 mb-4">

                                <div class="col-lg-3 col-md-6">
                                    <div class="epd-proc-chip epd-proc-pending position-relative">
                                        <button name="action_view_mr_pending" type="object" class="sf-card-btn"/>
                                        <div class="epd-proc-icon"><i class="fa fa-clock-o"/></div>
                                        <div class="epd-proc-val">
                                            <field name="mr_count_pending" nolabel="1"/>
                                        </div>
                                        <div class="epd-proc-lbl">Pending Approval</div>
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="epd-proc-chip epd-proc-approved position-relative">
                                        <button name="action_view_mr_approved" type="object" class="sf-card-btn"/>
                                        <div class="epd-proc-icon"><i class="fa fa-check-circle"/></div>
                                        <div class="epd-proc-val">
                                            <field name="mr_count_approved" nolabel="1"/>
                                        </div>
                                        <div class="epd-proc-lbl">Approved / Ordered</div>
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="epd-proc-chip epd-proc-received position-relative">
                                        <button name="action_view_mr_received" type="object" class="sf-card-btn"/>
                                        <div class="epd-proc-icon"><i class="fa fa-archive"/></div>
                                        <div class="epd-proc-val">
                                            <field name="mr_count_received" nolabel="1"/>
                                        </div>
                                        <div class="epd-proc-lbl">Fully Received</div>
                                    </div>
                                </div>

                                <div class="col-lg-3 col-md-6">
                                    <div class="epd-proc-chip epd-proc-rejected position-relative">
                                        <button name="action_view_mr_rejected" type="object" class="sf-card-btn"/>
                                        <div class="epd-proc-icon"><i class="fa fa-times-circle"/></div>
                                        <div class="epd-proc-val">
                                            <field name="mr_count_rejected" nolabel="1"/>
                                        </div>
                                        <div class="epd-proc-lbl">Rejected</div>
                                    </div>
                                </div>

                            </div><!-- /status chips -->

                            <div class="epd-row-label">Financial Summary</div>
                            <div class="row g-3 mb-4">
                                <div class="col-lg-6">
                                    <div class="epd-proc-fin">
                                        <div class="epd-proc-fin-icon text-primary">
                                            <i class="fa fa-calculator"/>
                                        </div>
                                        <div class="epd-proc-fin-body">
                                            <div class="epd-proc-fin-lbl">Total Estimated (MRs)</div>
                                            <div class="epd-proc-fin-val">
                                                <field name="mr_total_estimated_cost" widget="monetary"
                                                       options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="epd-proc-fin">
                                        <div class="epd-proc-fin-icon text-success">
                                            <i class="fa fa-truck"/>
                                        </div>
                                        <div class="epd-proc-fin-body">
                                            <div class="epd-proc-fin-lbl">Total Actual (Received)</div>
                                            <div class="epd-proc-fin-val">
                                                <field name="mr_total_actual_cost" widget="monetary"
                                                       options="{'currency_field': 'currency_id'}" nolabel="1"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="epd-row-label">Quick Actions</div>
                            <div class="epd-action-row">
                                <button name="action_view_all_mr" type="object"
                                        class="epd-act-btn epd-btn-navy">
                                    <i class="fa fa-list-alt me-1"/> All Requests
                                </button>
                                <button name="action_view_mr_pending" type="object"
                                        class="epd-act-btn epd-btn-amber">
                                    <i class="fa fa-clock-o me-1"/> Pending Approvals
                                </button>
                            </div>

                        </div><!-- /section-body -->
                    </div><!-- /§4 -->

                </xpath>

            </field>
        </record>

    </data>
</odoo>
