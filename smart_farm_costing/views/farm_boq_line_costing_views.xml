<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Extend the BOQ Line form with the unit-cost notebook.

            TAB ISOLATION MECHANISM
            ───────────────────────
            Each tab uses a DEDICATED One2many field (material_cost_ids,
            labor_cost_ids, …) with a domain restriction set at the Python
            field level.  Because the fields are distinct, Odoo renders them
            as completely independent widgets.  A line stored with
            job_type='labour' appears ONLY in the Labours tab — never in any
            other tab.

            context="{'default_job_type': '...'}" on each One2many widget
            ensures new lines created inside that tab automatically get the
            correct job_type without any user action.

            Job Type column
            ───────────────
            The job_type field is shown as a visible badge column in every
            tab so the user can always see the classification of each line.
            It is readonly in the list (auto-filled from product or from the
            tab default) — editing happens through product selection.

            Product selector domain
            ───────────────────────
            Each tab restricts the product_id selector to only products
            matching the tab's job_type, preventing accidental cross-type
            product selection.

            Tab order (visible for subitems only, i.e. parent_id set):
              1. Description     — from base view
              2. Materials       — material_cost_ids       (job_type = material)
              3. Labours         — labor_cost_ids          (job_type = labour)
              4. Subcontractor   — subcontractor_cost_ids  (job_type = subcontractor)
              5. Tools           — tools_cost_ids          (job_type = tools)
              6. Equipment       — equipment_cost_ids      (job_type = equipment)
              7. Others          — other_cost_ids          (job_type = other)
              8. Summary         — computed totals, risk, final unit cost
              9. Notes           — free-form notes field
        -->

        <record id="view_farm_boq_line_form_costing" model="ir.ui.view">
            <field name="name">farm.boq.line.form.costing</field>
            <field name="model">farm.boq.line</field>
            <field name="inherit_id" ref="smart_farm_boq.view_farm_boq_line_form"/>
            <field name="arch" type="xml">

                <!-- Save as Template button — above the notebook -->
                <xpath expr="//notebook" position="before">
                    <div class="mb-2 text-end" invisible="not parent_id">
                        <button name="action_save_as_template"
                                type="object"
                                string="Save as Template"
                                icon="fa-bookmark"
                                class="btn btn-secondary btn-sm"/>
                    </div>
                </xpath>

                <xpath expr="//notebook" position="inside">

                    <!-- ══════════════════════════════════════════════════════
                         2. MATERIALS  —  material_cost_ids  (job_type=material)
                         context sets default job_type for new lines in this tab.
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Materials" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <field name="material_cost_ids"
                               context="{'default_job_type': 'material'}">
                            <list editable="bottom">
                                <field name="job_type"   string="Job Type | نوع العمل"
                                       widget="badge"
                                       readonly="1"
                                       decoration-success="job_type == 'material'"
                                       options="{'no_open': True}"/>
                                <field name="product_id"  string="Product"
                                       optional="show"
                                       domain="[('job_type', '=', 'material')]"/>
                                <field name="description" string="Description"/>
                                <field name="uom_id"      string="Unit" optional="show"/>
                                <field name="quantity"    string="Qty"/>
                                <field name="unit_cost"   string="Unit Cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="total_cost"  string="Total" readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </list>
                        </field>
                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         3. LABOURS  —  labor_cost_ids  (job_type=labour)
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Labours" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <field name="labor_cost_ids"
                               context="{'default_job_type': 'labour'}">
                            <list editable="bottom">
                                <field name="job_type"   string="Job Type | نوع العمل"
                                       widget="badge"
                                       readonly="1"
                                       decoration-info="job_type == 'labour'"
                                       options="{'no_open': True}"/>
                                <field name="product_id"  string="Resource"
                                       optional="show"
                                       domain="[('job_type', '=', 'labour')]"/>
                                <field name="description" string="Description"/>
                                <field name="uom_id"      string="Unit" optional="show"/>
                                <field name="quantity"    string="Qty"/>
                                <field name="unit_cost"   string="Rate"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="total_cost"  string="Total" readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </list>
                        </field>
                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         4. SUBCONTRACTOR  —  subcontractor_cost_ids
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Subcontractor" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <field name="subcontractor_cost_ids"
                               context="{'default_job_type': 'subcontractor'}">
                            <list editable="bottom">
                                <field name="job_type"   string="Job Type | نوع العمل"
                                       widget="badge"
                                       readonly="1"
                                       decoration-warning="job_type == 'subcontractor'"
                                       options="{'no_open': True}"/>
                                <field name="product_id"  string="Vendor / Service"
                                       optional="show"
                                       domain="[('job_type', '=', 'subcontractor')]"/>
                                <field name="description" string="Description"/>
                                <field name="uom_id"      string="Unit" optional="show"/>
                                <field name="quantity"    string="Qty"/>
                                <field name="unit_cost"   string="Unit Cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="total_cost"  string="Total" readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </list>
                        </field>
                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         5. TOOLS  —  tools_cost_ids  (job_type=tools)
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Tools" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <field name="tools_cost_ids"
                               context="{'default_job_type': 'tools'}">
                            <list editable="bottom">
                                <field name="job_type"   string="Job Type | نوع العمل"
                                       widget="badge"
                                       readonly="1"
                                       decoration-warning="job_type == 'tools'"
                                       options="{'no_open': True}"/>
                                <field name="product_id"  string="Tool"
                                       optional="show"
                                       domain="[('job_type', '=', 'tools')]"/>
                                <field name="description" string="Description"/>
                                <field name="uom_id"      string="Unit" optional="show"/>
                                <field name="quantity"    string="Qty"/>
                                <field name="unit_cost"   string="Unit Cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="total_cost"  string="Total" readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </list>
                        </field>
                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         6. EQUIPMENT  —  equipment_cost_ids  (job_type=equipment)
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Equipment" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <field name="equipment_cost_ids"
                               context="{'default_job_type': 'equipment'}">
                            <list editable="bottom">
                                <field name="job_type"   string="Job Type | نوع العمل"
                                       widget="badge"
                                       readonly="1"
                                       decoration-warning="job_type == 'equipment'"
                                       options="{'no_open': True}"/>
                                <field name="product_id"  string="Equipment"
                                       optional="show"
                                       domain="[('job_type', '=', 'equipment')]"/>
                                <field name="description" string="Description"/>
                                <field name="uom_id"      string="Unit" optional="show"/>
                                <field name="quantity"    string="Qty"/>
                                <field name="unit_cost"   string="Unit Cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="total_cost"  string="Total" readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </list>
                        </field>
                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         7. OTHERS  —  other_cost_ids  (job_type=other)
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Others" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <field name="other_cost_ids"
                               context="{'default_job_type': 'other'}">
                            <list editable="bottom">
                                <field name="job_type"   string="Job Type | نوع العمل"
                                       widget="badge"
                                       readonly="1"
                                       decoration-muted="job_type == 'other'"
                                       options="{'no_open': True}"/>
                                <field name="product_id"  string="Item"
                                       optional="show"
                                       domain="[('job_type', '=', 'other')]"/>
                                <field name="description" string="Description"/>
                                <field name="uom_id"      string="Unit" optional="show"/>
                                <field name="quantity"    string="Qty"/>
                                <field name="unit_cost"   string="Unit Cost"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <field name="total_cost"  string="Total" readonly="1"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </list>
                        </field>
                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         8. SUMMARY
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Summary" invisible="not parent_id">
                        <field name="currency_id" invisible="1"/>
                        <group>

                            <group string="Cost Breakdown">
                                <field name="material_total"      readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="labor_total"         readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="subcontractor_total" readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="tools_total"         readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="equipment_total"     readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="other_total"         readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="total_direct_cost"   readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </group>

                            <group string="Risk &amp; Final Unit Cost">
                                <field name="risk_percent"/>
                                <field name="risk_amount"      readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="final_unit_cost"  readonly="1" widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                            </group>

                        </group>

                    </page>

                    <!-- ══════════════════════════════════════════════════════
                         9. NOTES
                    ══════════════════════════════════════════════════════════ -->
                    <page string="Notes" invisible="not parent_id">
                        <field name="notes"
                               placeholder="Internal notes, site conditions, assumptions…"
                               nolabel="1"/>
                    </page>

                </xpath>

            </field>
        </record>

    </data>
</odoo>
