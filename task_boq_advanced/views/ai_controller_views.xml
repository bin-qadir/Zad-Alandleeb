<odoo>
    <record id="ai_rule_list" model="ir.ui.view">
        <field name="name">ai.rule.list</field>
        <field name="model">ai.controller.rule</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="rule_type"/><field name="threshold_percent"/><field name="threshold_days"/><field name="alert_level"/><field name="active"/></list></field>
    </record>
    <record id="ai_alert_list" model="ir.ui.view">
        <field name="name">ai.alert.list</field>
        <field name="model">ai.controller.alert</field>
        <field name="arch" type="xml"><list><field name="name"/><field name="task_id"/><field name="level"/><field name="status"/><field name="summary"/></list></field>
    </record>
    <record id="action_ai_rules" model="ir.actions.act_window"><field name="name">AI Rules</field><field name="res_model">ai.controller.rule</field><field name="view_mode">list,form</field></record>
    <record id="action_ai_alerts" model="ir.actions.act_window"><field name="name">AI Alerts</field><field name="res_model">ai.controller.alert</field><field name="view_mode">list,form</field></record>
</odoo>
