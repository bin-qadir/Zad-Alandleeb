<odoo>
    <record id="timesheet_form_boq" model="ir.ui.view">
        <field name="name">timesheet.form.boq</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="hr_timesheet.timesheet_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/group" position="inside">
                <field name="boq_task_id"/>
                <field name="boq_line_id"/>
            </xpath>
        </field>
    </record>
</odoo>
