<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_manufacturing_work_order_list" model="ir.ui.view">
            <field name="name">manufacturing.work.order.list</field>
            <field name="model">manufacturing.work.order</field>
            <field name="arch" type="xml">
                <list string="Work Orders" decoration-success="state=='done'"
                      decoration-warning="state=='in_progress'">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="plan_id"/>
                    <field name="product_id"/>
                    <field name="planned_qty"/>
                    <field name="actual_qty"/>
                    <field name="planned_date"/>
                    <field name="operator_id" widget="many2one_avatar_user"/>
                    <field name="estimated_cost" sum="Est."/>
                    <field name="actual_cost" sum="Act."/>
                    <field name="currency_id" invisible="True"/>
                    <field name="qc_result" widget="badge"/>
                    <field name="state" widget="badge"/>
                </list>
            </field>
        </record>

        <record id="view_manufacturing_work_order_form" model="ir.ui.view">
            <field name="name">manufacturing.work.order.form</field>
            <field name="model">manufacturing.work.order</field>
            <field name="arch" type="xml">
                <form string="Work Order">
                    <header>
                        <button name="action_set_ready" string="Set Ready"    type="object"
                                invisible="state != 'draft'" class="btn-primary"/>
                        <button name="action_start"     string="Start"        type="object"
                                invisible="state != 'ready'" class="btn-primary"/>
                        <button name="action_done"      string="Done"         type="object"
                                invisible="state != 'in_progress'" class="btn-success"/>
                        <button name="action_cancel"    string="Cancel"       type="object"
                                invisible="state in ['done','cancelled']"/>
                        <button name="action_reset_draft" string="Reset"      type="object"
                                invisible="state != 'cancelled'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,ready,in_progress,done"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_qc_checks" type="object"
                                    class="oe_stat_button" icon="fa-check-circle">
                                <field name="qc_check_count" widget="statinfo" string="QC Checks"/>
                            </button>
                        </div>

                        <div class="oe_title">
                            <label for="name"/>
                            <h1><field name="name" placeholder="Work Order Name…"/></h1>
                        </div>

                        <group>
                            <group string="Context">
                                <field name="plan_id"/>
                                <field name="product_id"/>
                                <field name="uom_id"/>
                                <field name="work_type_id"/>
                                <field name="workcenter"/>
                            </group>
                            <group string="Quantities &amp; Schedule">
                                <field name="planned_qty"/>
                                <field name="actual_qty"/>
                                <field name="planned_date"/>
                                <field name="actual_date"/>
                                <field name="planned_duration_hours"/>
                                <field name="actual_duration_hours"/>
                            </group>
                        </group>

                        <group>
                            <group string="Costs">
                                <field name="estimated_cost"/>
                                <field name="actual_cost"/>
                                <field name="currency_id" invisible="True"/>
                            </group>
                            <group string="QC">
                                <field name="operator_id" widget="many2one_avatar_user"/>
                                <field name="qc_result" widget="badge"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="QC Checks">
                                <field name="qc_check_ids" mode="list">
                                    <list>
                                        <field name="name"/>
                                        <field name="check_date"/>
                                        <field name="check_type"/>
                                        <field name="inspector_id" widget="many2one_avatar_user"/>
                                        <field name="sample_qty"/>
                                        <field name="pass_qty"/>
                                        <field name="fail_qty"/>
                                        <field name="result" widget="badge"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Notes">
                                <field name="notes"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="action_manufacturing_work_order" model="ir.actions.act_window">
            <field name="name">Work Orders</field>
            <field name="res_model">manufacturing.work.order</field>
            <field name="view_mode">list,form</field>
        </record>

    </data>
</odoo>
