<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="module_category_manufacturing_sf" model="ir.module.category">
            <field name="name">Manufacturing (Lavandula)</field>
            <field name="description">Lavandula — Manufacturing &amp; Packing operational module.</field>
            <field name="sequence">70</field>
        </record>

        <record id="group_manufacturing_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_manufacturing_sf"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_manufacturing_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_manufacturing_sf"/>
            <field name="implied_ids" eval="[(4, ref('group_manufacturing_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
