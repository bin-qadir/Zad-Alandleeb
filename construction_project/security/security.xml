<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── Category ──────────────────────────────────────────────────────── -->

    <record id="module_category_construction" model="ir.module.category">
        <field name="name">Construction</field>
        <field name="description">Construction ERP — project management, BOQ, costing, execution.</field>
        <field name="sequence">50</field>
    </record>

    <!-- ─── Groups ─────────────────────────────────────────────────────────── -->

    <record id="group_construction_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">
            Construction users can read and create projects, divisions, and subdivisions.
        </field>
    </record>

    <record id="group_construction_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_construction"/>
        <field name="implied_ids" eval="[(4, ref('group_construction_user'))]"/>
        <field name="comment">
            Construction managers have full access to all construction records.
        </field>
    </record>

</odoo>
