<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_mail_tracker_convert_task_wizard_form" model="ir.ui.view">
            <field name="name">mail.tracker.convert.task.wizard.form</field>
            <field name="model">mail.tracker.convert.task.wizard</field>
            <field name="arch" type="xml">
                <form string="Convert Email to Task">
                    <sheet>

                        <div class="alert alert-info border-start border-info border-3 mb-3"
                             role="alert">
                            <i class="fa fa-info-circle me-1"/>
                            A project task will be created and linked back to this email.
                            All email attachments will be copied to the task.
                        </div>

                        <group string="Email Reference" invisible="not tracker_id">
                            <field name="tracker_id" string="Source Email" readonly="1"/>
                        </group>

                        <separator string="Task Details"/>

                        <group>
                            <group>
                                <field name="name" string="Task Title" required="1"/>
                                <field name="project_id" string="Project" required="1"/>
                                <field name="user_ids" string="Assigned To"
                                       widget="many2many_tags"
                                       options="{'no_create': True}"/>
                            </group>
                            <group>
                                <field name="priority" string="Priority"
                                       widget="priority"/>
                                <field name="date_deadline" string="Deadline"/>
                                <field name="tag_ids" string="Tags"
                                       widget="many2many_tags"
                                       options="{'color_field': 'color'}"/>
                            </group>
                        </group>

                        <group string="Description">
                            <field name="description" nolabel="1" widget="html"/>
                        </group>

                    </sheet>
                    <footer>
                        <button name="action_confirm"
                                string="Create Task"
                                type="object"
                                class="btn-primary"/>
                        <button name="action_cancel"
                                string="Cancel"
                                type="object"
                                class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
