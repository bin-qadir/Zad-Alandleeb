<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════════════
             SECURITY GROUPS
             ────────────────────────────────────────────────────────────────
             user          → see own assigned emails
             manager       → see department-wide emails + user rights
             top_management→ see ALL escalated emails + manager rights
        ═══════════════════════════════════════════════════════════════════ -->

        <record id="group_mail_tracker_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="base.module_category_productivity"/>
            <field name="comment">Can view and manage emails assigned to them.</field>
        </record>

        <record id="group_mail_tracker_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="base.module_category_productivity"/>
            <field name="implied_ids" eval="[(4, ref('group_mail_tracker_user'))]"/>
            <field name="comment">Can view all emails in their department.</field>
        </record>

        <record id="group_mail_tracker_top" model="res.groups">
            <field name="name">Top Management</field>
            <field name="category_id" ref="base.module_category_productivity"/>
            <field name="implied_ids" eval="[(4, ref('group_mail_tracker_manager'))]"/>
            <field name="comment">Can view all escalated emails and override assignments.</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             RECORD RULES
             ────────────────────────────────────────────────────────────────
             Rule hierarchy:
               user         → assigned to me OR I created it
               manager      → department match (overrides user rule for dept)
               top_mgmt     → no restriction (sees all)
        ═══════════════════════════════════════════════════════════════════ -->

        <!-- User: sees own assigned + own created emails -->
        <record id="rule_mail_tracker_user" model="ir.rule">
            <field name="name">Mail Tracker: own emails</field>
            <field name="model_id" ref="model_mail_tracker_record"/>
            <field name="domain_force">[
                '|',
                ('assigned_user_id', '=', user.id),
                ('create_uid', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_mail_tracker_user'))]"/>
        </record>

        <!-- Manager: sees all emails in their department (or unassigned department) -->
        <record id="rule_mail_tracker_manager" model="ir.rule">
            <field name="name">Mail Tracker: department emails</field>
            <field name="model_id" ref="model_mail_tracker_record"/>
            <field name="domain_force">[
                '|',
                ('department_id', '=', False),
                ('department_id.manager_id.user_id', '=', user.id)
            ]</field>
            <field name="groups" eval="[(4, ref('group_mail_tracker_manager'))]"/>
        </record>

        <!-- Top Management: unrestricted read on escalated emails -->
        <record id="rule_mail_tracker_top" model="ir.rule">
            <field name="name">Mail Tracker: top management — all records</field>
            <field name="model_id" ref="model_mail_tracker_record"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_mail_tracker_top'))]"/>
        </record>

    </data>
</odoo>
