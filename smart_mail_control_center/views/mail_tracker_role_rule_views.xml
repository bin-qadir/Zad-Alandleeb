<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════
             mail.tracker.role.rule — List view
        ══════════════════════════════════════════════════════ -->

        <record id="view_mail_tracker_role_rule_list" model="ir.ui.view">
            <field name="name">mail.tracker.role.rule.list</field>
            <field name="model">mail.tracker.role.rule</field>
            <field name="arch" type="xml">
                <list string="Role Assignment Rules" editable="bottom">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="mail_type"/>
                    <field name="assigned_user_id"/>
                    <field name="department_id"/>
                    <field name="active" optional="show"/>
                </list>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════
             mail.tracker.role.rule — Form view
        ══════════════════════════════════════════════════════ -->

        <record id="view_mail_tracker_role_rule_form" model="ir.ui.view">
            <field name="name">mail.tracker.role.rule.form</field>
            <field name="model">mail.tracker.role.rule</field>
            <field name="arch" type="xml">
                <form string="Role Assignment Rule">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Rule name…"/></h1>
                        </div>
                        <group>
                            <group string="Trigger">
                                <field name="mail_type"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                            <group string="Assignment">
                                <field name="assigned_user_id"/>
                                <field name="department_id"/>
                            </group>
                        </group>
                        <group string="Notes">
                            <field name="notes" nolabel="1" placeholder="Describe when this rule applies…"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════
             Window action
        ══════════════════════════════════════════════════════ -->

        <record id="action_mail_tracker_role_rule" model="ir.actions.act_window">
            <field name="name">Role Assignment Rules</field>
            <field name="res_model">mail.tracker.role.rule</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No role assignment rules yet.
                </p>
                <p>
                    Create rules to automatically assign incoming emails to the
                    right user based on email type (BOQ, Claim, Invoice, etc.).
                </p>
            </field>
        </record>

    </data>
</odoo>
