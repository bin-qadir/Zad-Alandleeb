<?xml version="1.0" encoding="utf-8"?>
<odoo>
<data>

<!-- ══════════════════════════════════════════════════════════════════════
     MYTHOS AGENT — List View
     ══════════════════════════════════════════════════════════════════════ -->

<record id="view_mythos_agent_list" model="ir.ui.view">
    <field name="name">mythos.agent.list</field>
    <field name="model">mythos.agent</field>
    <field name="arch" type="xml">
        <list string="Mythos AI Agents"
              default_order="sequence,agent_layer,name"
              decoration-muted="not active">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="agent_layer" widget="badge"
                   decoration-info="agent_layer == 'pre_contract'"
                   decoration-primary="agent_layer == 'contract'"
                   decoration-success="agent_layer == 'execution'"
                   decoration-warning="agent_layer in ('procurement', 'quality_handover')"
                   decoration-danger="agent_layer in ('risk_control', 'financial_claims')"
                   decoration-muted="agent_layer == 'executive_dashboard'"/>
            <field name="agent_function" widget="badge"
                   decoration-info="True" optional="show"/>
            <field name="last_status" widget="badge"
                   decoration-muted="last_status == 'never_run'"
                   decoration-success="last_status == 'success'"
                   decoration-warning="last_status == 'warning'"
                   decoration-danger="last_status == 'failed'"/>
            <field name="last_run_datetime" string="Last Run" optional="show"/>
            <field name="run_count" string="Runs" optional="show"/>
            <field name="insight_count" string="Insights" optional="show"/>
            <field name="action_count" string="Actions" optional="show"/>
            <field name="active" column_invisible="True"/>
        </list>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════════════
     MYTHOS AGENT — Form View
     ══════════════════════════════════════════════════════════════════════ -->

<record id="view_mythos_agent_form" model="ir.ui.view">
    <field name="name">mythos.agent.form</field>
    <field name="model">mythos.agent</field>
    <field name="arch" type="xml">
        <form string="Mythos Agent">
            <header>
                <!-- Run Agent placeholder button -->
                <button name="action_run_agent"
                        type="object"
                        string="Run Agent"
                        class="btn-primary"
                        icon="fa-play"
                        confirm="Trigger a run for this agent? (Phase 1 placeholder — logs entry only)"/>

                <!-- Status badge -->
                <field name="last_status" widget="statusbar"
                       statusbar_visible="never_run,success,warning,failed"
                       readonly="1"/>
            </header>
            <sheet>

                <!-- ── Stat buttons ───────────────────────────────────────── -->
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_logs"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-list-alt">
                        <field name="log_count" widget="statinfo" string="Logs"/>
                    </button>
                    <button name="action_view_alerts"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-bell"
                            invisible="alert_count == 0">
                        <field name="alert_count" widget="statinfo" string="Alerts"/>
                    </button>
                    <button type="object"
                            name="action_view_logs"
                            class="oe_stat_button"
                            icon="fa-users"
                            invisible="child_count == 0">
                        <field name="child_count" widget="statinfo" string="Sub-Agents"/>
                    </button>
                    <div class="oe_stat_button" type="object" icon="fa-play-circle">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="run_count" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Runs</span>
                        </div>
                    </div>
                    <div class="oe_stat_button" type="object" icon="fa-lightbulb-o">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="insight_count" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Insights</span>
                        </div>
                    </div>
                    <div class="oe_stat_button" type="object" icon="fa-bolt">
                        <div class="o_field_widget o_stat_info">
                            <span class="o_stat_value">
                                <field name="action_count" nolabel="1"/>
                            </span>
                            <span class="o_stat_text">Actions</span>
                        </div>
                    </div>
                </div>

                <!-- ── Title ─────────────────────────────────────────────── -->
                <div class="oe_title">
                    <h1>
                        <field name="name"
                               placeholder="Agent Name…"
                               style="font-size: 1.4rem;"/>
                    </h1>
                    <div class="text-muted small">
                        <field name="code" readonly="1" nolabel="1"
                               style="font-family: monospace;"/>
                    </div>
                </div>

                <!-- ── KPI strip ─────────────────────────────────────────── -->
                <div class="row mt-3 mb-4">
                    <div class="col-md-3 text-center border-end">
                        <div class="fw-bold fs-4">
                            <field name="last_status" widget="badge"
                                   decoration-muted="last_status == 'never_run'"
                                   decoration-success="last_status == 'success'"
                                   decoration-warning="last_status == 'warning'"
                                   decoration-danger="last_status == 'failed'"
                                   nolabel="1"/>
                        </div>
                        <div class="text-muted small">Last Status</div>
                    </div>
                    <div class="col-md-3 text-center border-end">
                        <div class="fw-bold fs-5">
                            <field name="last_run_datetime" nolabel="1"
                                   widget="datetime" readonly="1"/>
                        </div>
                        <div class="text-muted small">Last Run</div>
                    </div>
                    <div class="col-md-3 text-center border-end">
                        <div class="fw-bold fs-4">
                            <field name="agent_layer" widget="badge"
                                   decoration-info="True" nolabel="1"/>
                        </div>
                        <div class="text-muted small">Layer</div>
                    </div>
                    <div class="col-md-3 text-center">
                        <div class="fw-bold fs-4">
                            <field name="agent_function" widget="badge"
                                   decoration-primary="True" nolabel="1"/>
                        </div>
                        <div class="text-muted small">Function</div>
                    </div>
                </div>

                <!-- ── Main fields ───────────────────────────────────────── -->
                <group>
                    <group string="Classification">
                        <field name="business_activity"/>
                        <field name="domain_type"/>
                        <field name="agent_type"/>
                        <field name="parent_id"
                               invisible="agent_type != 'employee'"/>
                        <field name="agent_layer"/>
                        <field name="agent_function"/>
                        <field name="sequence"/>
                        <field name="priority"/>
                    </group>
                    <group string="Status">
                        <field name="state"/>
                        <field name="active"/>
                        <field name="last_run_datetime" readonly="1"/>
                        <field name="last_status" readonly="1"/>
                        <field name="run_count" readonly="1"/>
                    </group>
                </group>

                <group string="Description">
                    <field name="description" nolabel="1"
                           placeholder="Describe what this agent monitors and what actions it can take…"/>
                </group>

                <!-- ── Tabs ──────────────────────────────────────────────── -->
                <notebook>
                    <!-- Employee sub-agents — only shown for main agents -->
                    <page string="Employee Agents" name="tab_children"
                          invisible="agent_type != 'main'">
                        <field name="child_ids">
                            <list string="Employee Agents"
                                  decoration-muted="state == 'paused'">
                                <field name="name"/>
                                <field name="code" optional="show"
                                       style="font-family:monospace"/>
                                <field name="domain_type" widget="badge"
                                       decoration-info="domain_type == 'pre_contract'"
                                       decoration-primary="domain_type == 'contract'"
                                       decoration-success="domain_type == 'execution'"
                                       decoration-danger="domain_type == 'financial'"
                                       decoration-warning="domain_type == 'quality_risk'"
                                       decoration-muted="domain_type == 'system'"/>
                                <field name="state" widget="badge"
                                       decoration-success="state == 'active'"
                                       decoration-warning="state == 'draft'"
                                       decoration-muted="state == 'paused'"/>
                                <field name="priority" optional="show"/>
                            </list>
                        </field>
                    </page>
                    <!-- ── Recent logs tab ─────────────────────────────── -->
                    <page string="Recent Logs" name="tab_logs">
                        <field name="log_ids" readonly="1">
                            <list string="Log Entries" decoration-danger="result == 'failed'"
                                  decoration-warning="result == 'warning'"
                                  decoration-success="result == 'success'"
                                  decoration-muted="result == 'success'">
                                <field name="datetime"/>
                                <field name="title"/>
                                <field name="result" widget="badge"
                                       decoration-success="result == 'success'"
                                       decoration-warning="result == 'warning'"
                                       decoration-danger="result == 'failed'"/>
                                <field name="user_id" optional="show"/>
                                <field name="related_model" optional="show"/>
                            </list>
                        </field>
                    </page>
                </notebook>

            </sheet>
            <chatter/>
        </form>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════════════
     MYTHOS AGENT — Domain List View
     Focused columns for "Agents by Domain" — name, code, domain, type,
     parent, state, priority.  General list (view_mythos_agent_list) keeps
     its layer/function columns and is used by the Command Center.
     ══════════════════════════════════════════════════════════════════════ -->

<record id="view_mythos_agent_domain_list" model="ir.ui.view">
    <field name="name">mythos.agent.domain.list</field>
    <field name="model">mythos.agent</field>
    <field name="arch" type="xml">
        <list string="Agents by Domain"
              default_order="domain_type,agent_type,sequence,name"
              decoration-muted="not active">
            <field name="sequence" widget="handle"/>
            <field name="name"/>
            <field name="code" optional="show"/>
            <field name="domain_type" widget="badge"
                   decoration-info="domain_type == 'pre_contract'"
                   decoration-primary="domain_type == 'contract'"
                   decoration-success="domain_type == 'execution'"
                   decoration-danger="domain_type == 'financial'"
                   decoration-warning="domain_type == 'quality_risk'"
                   decoration-muted="domain_type == 'system'"/>
            <field name="agent_type" widget="badge"
                   decoration-primary="agent_type == 'main'"
                   decoration-info="agent_type == 'employee'"/>
            <field name="parent_id" optional="show"/>
            <field name="state" widget="badge"
                   decoration-success="state == 'active'"
                   decoration-warning="state == 'draft'"
                   decoration-muted="state == 'paused'"/>
            <field name="priority" optional="show"/>
            <field name="active" column_invisible="True"/>
        </list>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════════════
     MYTHOS AGENT — Search View
     ══════════════════════════════════════════════════════════════════════ -->

<record id="view_mythos_agent_search" model="ir.ui.view">
    <field name="name">mythos.agent.search</field>
    <field name="model">mythos.agent</field>
    <field name="arch" type="xml">
        <search string="Search Agents">
            <field name="name"/>
            <field name="code"/>
            <field name="parent_id"/>
            <!-- ── Domain filters ─────────────────────────────────── -->
            <separator/>
            <filter string="Pre-Contract"   name="domain_pre_contract"
                    domain="[('domain_type','=','pre_contract')]"/>
            <filter string="Contract"       name="domain_contract"
                    domain="[('domain_type','=','contract')]"/>
            <filter string="Execution"      name="domain_execution"
                    domain="[('domain_type','=','execution')]"/>
            <filter string="Financial"      name="domain_financial"
                    domain="[('domain_type','=','financial')]"/>
            <filter string="Quality &amp; Risk" name="domain_quality_risk"
                    domain="[('domain_type','=','quality_risk')]"/>
            <filter string="System"         name="domain_system"
                    domain="[('domain_type','=','system')]"/>
            <!-- ── Agent type filters ─────────────────────────────── -->
            <separator/>
            <filter string="Main Agents"     name="type_main"
                    domain="[('agent_type','=','main')]"/>
            <filter string="Employee Agents" name="type_employee"
                    domain="[('agent_type','=','employee')]"/>
            <!-- ── State filters ──────────────────────────────────── -->
            <separator/>
            <filter string="Active" name="state_active"
                    domain="[('state','=','active')]"/>
            <filter string="Paused" name="state_paused"
                    domain="[('state','=','paused')]"/>
            <!-- ── Group By ───────────────────────────────────────── -->
            <group expand="0" string="Group By">
                <filter string="Domain"     name="group_domain"
                        context="{'group_by':'domain_type'}"/>
                <filter string="Agent Type" name="group_type"
                        context="{'group_by':'agent_type'}"/>
                <filter string="Layer"      name="group_layer"
                        context="{'group_by':'agent_layer'}"/>
                <filter string="State"      name="group_state"
                        context="{'group_by':'state'}"/>
            </group>
        </search>
    </field>
</record>

<!-- ══════════════════════════════════════════════════════════════════════
     MYTHOS AGENT — Action
     ══════════════════════════════════════════════════════════════════════ -->

<record id="action_mythos_agent" model="ir.actions.act_window">
    <field name="name">Agents by Domain</field>
    <field name="res_model">mythos.agent</field>
    <field name="view_mode">list,form</field>
    <field name="view_ids" eval="[(5, 0, 0),
        (0, 0, {'view_mode': 'list', 'view_id': ref('view_mythos_agent_domain_list')}),
        (0, 0, {'view_mode': 'form', 'view_id': ref('view_mythos_agent_form')}),
    ]"/>
    <field name="search_view_id" ref="view_mythos_agent_search"/>
    <field name="domain">[('business_activity', '=', 'construction')]</field>
    <field name="context">{'default_business_activity': 'construction', 'search_default_group_domain': 1}</field>
    <field name="target">current</field>
</record>

<!-- ══════════════════════════════════════════════════════════════════════
     MYTHOS COMMAND CENTER — layer-grouped overview action
     ══════════════════════════════════════════════════════════════════════ -->

<record id="action_mythos_command_center" model="ir.actions.act_window">
    <field name="name">Mythos Command Center</field>
    <field name="res_model">mythos.agent</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_mythos_agent_search"/>
    <field name="domain">[('business_activity', '=', 'construction'), ('active', '=', True)]</field>
    <field name="context">{'default_business_activity': 'construction', 'search_default_group_layer': 1}</field>
    <field name="target">current</field>
</record>

</data>
</odoo>
