<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="action_type_cooling"      model="farm.actuator.action.type">
            <field name="key">cooling</field>
            <field name="name">Cooling / Ventilation</field>
            <field name="sequence">10</field>
            <field name="icon">fa-snowflake-o</field>
            <field name="color">1</field>
        </record>

        <record id="action_type_heating"      model="farm.actuator.action.type">
            <field name="key">heating</field>
            <field name="name">Heating</field>
            <field name="sequence">20</field>
            <field name="icon">fa-fire</field>
            <field name="color">2</field>
        </record>

        <record id="action_type_irrigation"   model="farm.actuator.action.type">
            <field name="key">irrigation</field>
            <field name="name">Irrigation / Pump</field>
            <field name="sequence">30</field>
            <field name="icon">fa-tint</field>
            <field name="color">4</field>
        </record>

        <record id="action_type_dehumidify"   model="farm.actuator.action.type">
            <field name="key">dehumidify</field>
            <field name="name">Dehumidification</field>
            <field name="sequence">40</field>
            <field name="icon">fa-cloud</field>
            <field name="color">3</field>
        </record>

        <record id="action_type_co2_inject"   model="farm.actuator.action.type">
            <field name="key">co2_inject</field>
            <field name="name">CO₂ Injection</field>
            <field name="sequence">50</field>
            <field name="icon">fa-leaf</field>
            <field name="color">10</field>
        </record>

        <record id="action_type_co2_reduce"   model="farm.actuator.action.type">
            <field name="key">co2_reduce</field>
            <field name="name">CO₂ Reduction / Venting</field>
            <field name="sequence">60</field>
            <field name="icon">fa-arrows-alt</field>
            <field name="color">5</field>
        </record>

        <record id="action_type_manual_check" model="farm.actuator.action.type">
            <field name="key">manual_check</field>
            <field name="name">Manual Inspection</field>
            <field name="sequence">70</field>
            <field name="icon">fa-user</field>
            <field name="color">6</field>
        </record>

        <record id="action_type_alert_only"   model="farm.actuator.action.type">
            <field name="key">alert_only</field>
            <field name="name">Alert Only (No Actuator)</field>
            <field name="sequence">80</field>
            <field name="icon">fa-bell</field>
            <field name="color">0</field>
        </record>

    </data>
</odoo>
