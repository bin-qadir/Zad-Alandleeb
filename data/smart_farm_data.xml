<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequences -->
        <record id="seq_farm_farm" model="ir.sequence">
            <field name="name">Farm</field>
            <field name="code">farm.farm</field>
            <field name="prefix">FARM/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_farm_field" model="ir.sequence">
            <field name="name">Farm Field</field>
            <field name="code">farm.field</field>
            <field name="prefix">FLD/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_farm_crop" model="ir.sequence">
            <field name="name">Farm Crop</field>
            <field name="code">farm.crop</field>
            <field name="prefix">CRP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_farm_harvest" model="ir.sequence">
            <field name="name">Farm Harvest</field>
            <field name="code">farm.harvest</field>
            <field name="prefix">HRV/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_farm_expense" model="ir.sequence">
            <field name="name">Farm Expense</field>
            <field name="code">farm.expense</field>
            <field name="prefix">EXP/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Default Livestock Categories -->
        <record id="livestock_cat_cattle" model="farm.livestock.category">
            <field name="name">Cattle</field>
            <field name="code">CAT</field>
        </record>
        <record id="livestock_cat_sheep" model="farm.livestock.category">
            <field name="name">Sheep</field>
            <field name="code">SHP</field>
        </record>
        <record id="livestock_cat_goat" model="farm.livestock.category">
            <field name="name">Goats</field>
            <field name="code">GT</field>
        </record>
        <record id="livestock_cat_poultry" model="farm.livestock.category">
            <field name="name">Poultry</field>
            <field name="code">PLT</field>
        </record>
        <record id="livestock_cat_camel" model="farm.livestock.category">
            <field name="name">Camels</field>
            <field name="code">CML</field>
        </record>

        <!-- Default Crop Types -->
        <record id="crop_type_date" model="farm.crop.type">
            <field name="name">Date Palm</field>
            <field name="category">fruit</field>
            <field name="average_duration">365</field>
        </record>
        <record id="crop_type_wheat" model="farm.crop.type">
            <field name="name">Wheat</field>
            <field name="category">grain</field>
            <field name="average_duration">120</field>
        </record>
        <record id="crop_type_alfalfa" model="farm.crop.type">
            <field name="name">Alfalfa</field>
            <field name="category">fodder</field>
            <field name="average_duration">60</field>
        </record>
        <record id="crop_type_tomato" model="farm.crop.type">
            <field name="name">Tomato</field>
            <field name="category">vegetable</field>
            <field name="average_duration">90</field>
        </record>
        <record id="crop_type_cucumber" model="farm.crop.type">
            <field name="name">Cucumber</field>
            <field name="category">vegetable</field>
            <field name="average_duration">60</field>
        </record>


        <!-- Sequence for farm.control.action references -->
        <record id="seq_farm_control_action" model="ir.sequence">
            <field name="name">Farm Control Action</field>
            <field name="code">farm.control.action</field>
            <field name="prefix">ACT/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
