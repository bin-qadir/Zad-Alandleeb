<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Extend the Farm Project form — adds:
              • Project Phase statusbar in header
              • "New BOQ" action button
              • Phases + B.O.Q stat buttons
              • "Scope (BOQ)" notebook tab with embedded BOQ list
        -->
        <record id="view_farm_project_form_boq_inherit" model="ir.ui.view">
            <field name="name">farm.project.form.boq.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">

                <!-- Project Phase — statusbar in header (before state statusbar) -->
                <field name="state" position="before">
                    <field name="project_phase_id"
                           widget="statusbar"
                           options="{'clickable': '1'}"/>
                </field>

                <!-- "New BOQ" action button in main_action_buttons -->
                <xpath expr="//div[@name='main_action_buttons']" position="inside">
                    <button name="action_new_boq"
                            type="object"
                            string="New BOQ"
                            icon="fa-plus"
                            class="btn btn-primary btn-lg px-4"/>
                </xpath>

                <!-- Phases — slot 2, inserted before anchor_phases_end -->
                <xpath expr="//div[@name='anchor_phases_end']" position="before">
                    <button name="action_open_phases" type="object"
                            class="oe_stat_button" icon="fa-flag"
                            invisible="phase_count == 0">
                        <field name="phase_count" widget="statinfo" string="Phases"/>
                    </button>
                </xpath>

                <!-- B.O.Q — slot 4, inserted before anchor_planning_end -->
                <xpath expr="//div[@name='anchor_planning_end']" position="before">
                    <button name="action_open_boqs" type="object"
                            class="oe_stat_button" icon="fa-sitemap">
                        <field name="boq_count" widget="statinfo" string="B.O.Q"/>
                    </button>
                </xpath>

                <!-- ── Scope (BOQ) notebook tab ──────────────────────────── -->
                <!-- Appended after all existing tabs (after tab_zones) -->
                <page name="tab_zones" position="after">
                    <page string="النطاق (BOQ) / Scope" name="tab_boq_scope">
                        <field name="boq_ids" nolabel="1">
                            <list string="Cost Structures"
                                  default_order="sequence"
                                  create="0"
                                  delete="0"
                                  open_form_view="1">
                                <field name="name"
                                       string="Reference / المرجع"
                                       readonly="1"/>
                                <field name="description"
                                       string="Description / الوصف"/>
                                <field name="revision_no"
                                       string="Rev / المراجعة"
                                       readonly="1"/>
                                <field name="project_phase_id"
                                       string="Phase / المرحلة"
                                       readonly="1"/>
                                <field name="sequence"
                                       string="Seq / التسلسل"/>
                                <field name="date"
                                       string="Date / التاريخ"/>
                                <field name="state"
                                       string="Status / الحالة"
                                       widget="badge"
                                       decoration-success="state == 'approved'"
                                       decoration-info="state == 'in_progress'"
                                       decoration-warning="state == 'submitted'"
                                       decoration-muted="state == 'draft'"/>
                                <field name="total"
                                       string="Amount / المبلغ"
                                       widget="monetary"
                                       options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" column_invisible="1"/>
                                <button name="action_open_structure"
                                        type="object"
                                        icon="fa-sitemap"
                                        title="Open Structure"/>
                            </list>
                        </field>
                    </page>
                </page>

            </field>
        </record>

        <!-- Inject project_phase_id into the project list view -->
        <record id="view_farm_project_list_boq_inherit" model="ir.ui.view">
            <field name="name">farm.project.list.boq.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_list"/>
            <field name="arch" type="xml">
                <field name="project_type" position="before">
                    <field name="project_phase_id" optional="show"/>
                </field>
            </field>
        </record>

        <!-- Inject project_phase_id Group By into the project search view -->
        <record id="view_farm_project_search_boq_inherit" model="ir.ui.view">
            <field name="name">farm.project.search.boq.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_search"/>
            <field name="arch" type="xml">
                <filter name="group_manager" position="before">
                    <filter string="Project Phase" name="group_phase"
                            context="{'group_by': 'project_phase_id'}"/>
                </filter>
            </field>
        </record>

    </data>
</odoo>
