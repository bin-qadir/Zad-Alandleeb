<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Extend the Farm Project form — adds the Project Phase field to the
            project header area.

            BOQ structure is accessed via Cost Structure → Project Cost Structure,
            not from within the Farm Project form.
        -->
        <record id="view_farm_project_form_boq_inherit" model="ir.ui.view">
            <field name="name">farm.project.form.boq.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">

                <!-- "New BOQ" action button in main_action_buttons -->
                <xpath expr="//div[@name='main_action_buttons']" position="inside">
                    <button name="action_new_boq"
                            type="object"
                            string="New BOQ"
                            icon="fa-plus"
                            class="btn btn-primary btn-lg px-4"/>
                </xpath>

                <!-- Cost Structures — card IS the button -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_open_boqs" type="object"
                            class="epd-mini-kpi epd-mini-kpi--navy"
                            title="Open Cost Structures">
                        <i class="fa fa-sitemap epd-mini-icon" title="Cost Structures"/>
                        <div class="epd-mini-value">
                            <field name="boq_count" nolabel="1"/>
                        </div>
                        <div class="epd-mini-label">Cost Structures</div>
                    </button>
                </xpath>

                <!-- Project Phase — inserted into the Project Details group (left column) -->
                <xpath expr="//group[@name='group_project_details']" position="inside">
                    <field name="project_phase_id"
                           string="Project Phase"
                           options="{'no_create': True, 'no_open': True}"/>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
