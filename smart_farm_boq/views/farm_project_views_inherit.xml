<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!--
            Extend the Farm Project form — adds the Project Phase statusbar and BOQ buttons.

            project_phase_id is injected as a header statusbar so users see:
              Pre-Tender → Tender → Contract → Execution → Closing
            alongside the operational state bar.

            BOQ structure is accessed via Cost Structure → Project Cost Structure,
            not from within the Farm Project form.
        -->
        <record id="view_farm_project_form_boq_inherit" model="ir.ui.view">
            <field name="name">farm.project.form.boq.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_form"/>
            <field name="arch" type="xml">

                <!-- Project Phase — statusbar in header (before state statusbar) -->
                <field name="state" position="before">
                    <field name="project_phase_id"
                           widget="statusbar"
                           options="{'clickable': '1'}"/>
                </field>

                <!-- "New BOQ" action button in main_action_buttons -->
                <xpath expr="//div[@name='main_action_buttons']" position="inside">
                    <button name="action_new_boq"
                            type="object"
                            string="New BOQ"
                            icon="fa-plus"
                            class="btn btn-primary btn-lg px-4"/>
                </xpath>

                <!-- Cost Structures — PLANNING group, inserted before anchor_planning_end -->
                <xpath expr="//div[@name='anchor_planning_end']" position="before">
                    <button name="action_open_boqs" type="object"
                            class="epd-mini-kpi epd-mini-kpi--navy"
                            title="Open Cost Structures">
                        <i class="fa fa-sitemap epd-mini-icon" title="Cost Structures"/>
                        <div class="epd-mini-value">
                            <field name="boq_count" nolabel="1"/>
                        </div>
                        <div class="epd-mini-label">Cost Structures</div>
                    </button>
                </xpath>

            </field>
        </record>

        <!-- Inject project_phase_id into the project list view -->
        <record id="view_farm_project_list_boq_inherit" model="ir.ui.view">
            <field name="name">farm.project.list.boq.inherit</field>
            <field name="model">farm.project</field>
            <field name="inherit_id" ref="smart_farm_project.view_farm_project_list"/>
            <field name="arch" type="xml">
                <field name="project_type" position="before">
                    <field name="project_phase_id" optional="show"/>
                </field>
            </field>
        </record>

    </data>
</odoo>
