<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_farm_boq_print_wizard_form" model="ir.ui.view">
            <field name="name">farm.boq.print.wizard.form</field>
            <field name="model">farm.boq.print.wizard</field>
            <field name="arch" type="xml">
                <form string="Print / Export Report">
                    <sheet>
                        <div class="oe_title">
                            <h2>Print Project Cost Structure</h2>
                            <h4 class="text-muted">طباعة هيكل تكلفة المشروع</h4>
                        </div>

                        <group>
                            <field name="boq_id" readonly="1"/>
                            <field name="report_type" widget="radio"/>
                        </group>
                    </sheet>

                    <footer>
                        <button name="action_print"
                                type="object"
                                string="Print"
                                class="btn-primary"
                                icon="fa-print"/>
                        <button string="Cancel"
                                class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
