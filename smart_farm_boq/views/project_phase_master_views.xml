<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════════════
             Project Phase Master — List View
             ══════════════════════════════════════════════════════════════════ -->

        <record id="view_project_phase_master_list" model="ir.ui.view">
            <field name="name">project.phase.master.list</field>
            <field name="model">project.phase.master</field>
            <field name="arch" type="xml">
                <list string="Project Phases" default_order="sequence">
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="project_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="boq_count"       string="BOQs"/>
                    <field name="task_count"      string="Tasks"/>
                    <field name="job_order_count" string="Job Orders"/>
                    <field name="active"          optional="hide"/>
                </list>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             Project Phase Master — Form View
             ══════════════════════════════════════════════════════════════════ -->

        <record id="view_project_phase_master_form" model="ir.ui.view">
            <field name="name">project.phase.master.form</field>
            <field name="model">project.phase.master</field>
            <field name="arch" type="xml">
                <form string="Project Phase">

                    <sheet>

                        <!-- Archived ribbon -->
                        <widget name="web_ribbon"
                                title="Archived"
                                bg_color="bg-danger"
                                invisible="active"/>
                        <field name="active" invisible="1"/>

                        <!-- ── Smart buttons ──────────────────────────────── -->
                        <div class="oe_button_box" name="button_box">

                            <button name="action_open_boqs"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-sitemap"
                                    invisible="boq_count == 0">
                                <field name="boq_count"
                                       widget="statinfo"
                                       string="BOQs / جداول الكميات"/>
                            </button>

                            <button name="action_open_tasks"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-tasks"
                                    invisible="task_count == 0">
                                <field name="task_count"
                                       widget="statinfo"
                                       string="Tasks / المهام"/>
                            </button>

                            <button name="action_open_job_orders"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-wrench"
                                    invisible="job_order_count == 0">
                                <field name="job_order_count"
                                       widget="statinfo"
                                       string="Job Orders / أوامر العمل"/>
                            </button>

                        </div>

                        <!-- ── Top identity row ───────────────────────────── -->
                        <div class="oe_title">
                            <label for="name"/>
                            <h1>
                                <field name="name"
                                       placeholder="Phase Name / اسم المرحلة"/>
                            </h1>
                        </div>

                        <!-- ── Main fields ────────────────────────────────── -->
                        <group>
                            <group string="Phase Details / تفاصيل المرحلة">
                                <field name="code"
                                       placeholder="PH-01"/>
                                <field name="sequence"/>
                                <field name="active"/>
                            </group>
                            <group string="Project &amp; Timeline / المشروع والجدول الزمني">
                                <field name="project_id"
                                       options="{'no_create': True}"
                                       placeholder="Optional / اختياري"/>
                                <field name="start_date"/>
                                <field name="end_date"/>
                            </group>
                        </group>

                        <!-- ── Notebook ───────────────────────────────────── -->
                        <notebook>

                            <!-- Overview: Description -->
                            <page string="Overview / نظرة عامة" name="overview">
                                <field name="description"
                                       widget="text"
                                       placeholder="Enter a description for this phase… / أدخل وصفاً لهذه المرحلة…"/>
                            </page>

                            <!-- BOQs tab: embedded list of linked BOQs -->
                            <page string="BOQs / جداول الكميات" name="boqs">
                                <field name="boq_ids" nolabel="1">
                                    <list string="Cost Structures"
                                          create="0" delete="0"
                                          default_order="sequence">
                                        <field name="name"     string="Reference"/>
                                        <field name="description" string="Description / الوصف"/>
                                        <field name="project_id"  string="Project"/>
                                        <field name="revision_no" string="Rev"/>
                                        <field name="sequence"    string="Seq"/>
                                        <field name="date"        string="Date"/>
                                        <field name="state"       string="Status"
                                               widget="badge"
                                               decoration-success="state == 'approved'"
                                               decoration-info="state == 'in_progress'"
                                               decoration-warning="state == 'submitted'"
                                               decoration-muted="state == 'draft'"/>
                                        <field name="total"       string="Amount"
                                               widget="monetary"
                                               options="{'currency_field': 'currency_id'}"/>
                                        <field name="currency_id" column_invisible="1"/>
                                    </list>
                                </field>
                            </page>

                            <!-- Tasks tab: informational note with button -->
                            <page string="Tasks / المهام" name="tasks"
                                  invisible="task_count == 0">
                                <div class="o_form_empty_state text-center py-4">
                                    <p class="text-muted">
                                        Tasks are linked through the farm project.
                                        Click the Tasks button above to view them.
                                    </p>
                                </div>
                            </page>

                            <!-- Job Orders tab: informational note with button -->
                            <page string="Job Orders / أوامر العمل" name="job_orders"
                                  invisible="job_order_count == 0">
                                <div class="o_form_empty_state text-center py-4">
                                    <p class="text-muted">
                                        Job Orders are linked through BOQs in this phase.
                                        Click the Job Orders button above to view them.
                                    </p>
                                </div>
                            </page>

                        </notebook>

                    </sheet>

                    <!-- Chatter -->
                    <chatter/>

                </form>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             Project Phase Master — Search View
             ══════════════════════════════════════════════════════════════════ -->

        <record id="view_project_phase_master_search" model="ir.ui.view">
            <field name="name">project.phase.master.search</field>
            <field name="model">project.phase.master</field>
            <field name="arch" type="xml">
                <search string="Project Phases">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="project_id"/>
                    <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                    <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter string="Project" name="group_project"
                                context="{'group_by': 'project_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             Window Action
             ══════════════════════════════════════════════════════════════════ -->

        <record id="action_project_phase_master" model="ir.actions.act_window">
            <field name="name">Project Phases</field>
            <field name="res_model">project.phase.master</field>
            <field name="view_mode">list,form</field>
            <field name="context">{'search_default_active': 1}</field>
        </record>

        <!-- ══════════════════════════════════════════════════════════════════
             Menu Item (under Cost Structure)
             ══════════════════════════════════════════════════════════════════ -->

        <menuitem
            id="menu_project_phase_master"
            name="Project Phases"
            parent="menu_smart_farm_boq"
            action="action_project_phase_master"
            sequence="40"/>

    </data>
</odoo>
